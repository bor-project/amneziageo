<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AmneziaGeo.Windows.Ui.MainWindow"
        Title="AmneziaGeo"
        Width="1180" Height="760"
        MinWidth="900" MinHeight="560"
        Background="{DynamicResource AgBgBrush}"
        FontFamily="IBM Plex Sans, Segoe UI, sans-serif"
        Foreground="{DynamicResource AgFgBrush}">

  <Window.Resources>
    <!-- "sync" glyph (two circular arrows): the per-source refresh / update icon. -->
    <StreamGeometry x:Key="AgRefreshGeometry">M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z</StreamGeometry>
  </Window.Resources>

  <Window.Styles>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BoxShadow" Value="0 1 3 0 #14000000" />
    </Style>

    <Style Selector="Border.subcard">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.inset">
      <Setter Property="Background" Value="{DynamicResource AgInsetBrush}" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="LetterSpacing" Value="0.7" />
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
    </Style>

    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="IBM Plex Mono, Cascadia Mono, Consolas, monospace" />
    </Style>

    <Style Selector="Button.seg">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.seg.active">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.chip">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Button.chip.active">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.softbtn">
      <Setter Property="Background" Value="{DynamicResource AgInsetBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,8" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <Style Selector="Button.icon">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- Button.seg / chip / softbtn / icon : suppress the Fluent theme's own hover / press background;
         the hover & press feedback itself is the global Opacity fade (see below). Selection state stays
         on the .active background rules above. -->
    <Style Selector="Button.seg:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.seg:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <!-- disabled placeholder (e.g. the RU/EN language toggle) reads as inactive -->
    <Style Selector="Button.seg:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="Button.chip:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.chip:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.softbtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.softbtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="Button.icon:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.icon:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Button.accent : keep the accent fill on hover / press; feedback is the global Opacity fade. -->
    <Style Selector="Button.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgAccentBrush}" />
    </Style>
    <Style Selector="Button.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgAccentBrush}" />
    </Style>

    <!-- Button.connectpill : the flicker-critical connect / stop button -->
    <Style Selector="Button.connectpill">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16,7" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinWidth" Value="104" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.connectpill /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.connectpill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.connectpill:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.connectpill:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.connectpill:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- Button.radiopick : the active-profile radio in the list header (crisp, no hover fill) -->
    <Style Selector="Button.radiopick">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2" />
      <Setter Property="MinWidth" Value="0" />    </Style>
    <Style Selector="Button.radiopick /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.radiopick:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.radiopick:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Button.rowselect : a flat, full-width selectable list row (routing lists) with a radio -->
    <Style Selector="Button.rowselect">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />    </Style>
    <Style Selector="Button.rowselect.active">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
    </Style>
    <Style Selector="Button.rowselect /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.rowselect:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.rowselect:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>

    <!-- Strict: instant button state changes (no fade) and no press-scale jiggle. The Fluent button's
         only declared animation is a 75ms scale(0.98) on press; null the root Transitions and flatten
         the transform so hover/press feedback is immediate, like the rest of the UI. -->
    <Style Selector="Button">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <!-- No hover animation at all: hovering changes nothing (no background, border, colour, or opacity).
         Only a brief press feedback remains. Selection uses the .active background rules above. -->
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="none" />
      <Setter Property="Opacity" Value="0.6" />
    </Style>

    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Neutral, status-independent border for every text input: the same secondary border in all
         states — no pointer-over / focus colour change and no accent focus underline, so the Fluent
         theme's animated border can't flicker between primary / secondary / none. -->
    <Style Selector="TextBox">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:focus-within">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="ComboBox.field">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>

    <!-- Strict, flicker-free ComboBox.field (closed box): null the inherited Background fade on the
         FluentTheme parts (Avalonia 11.3.x) and repoint each state to opaque Ag* brushes, so hover /
         press / focus are instant with no interpolated wrong-colour frame. Dropdown rows are styled
         app-wide in App.axaml (the popup is outside this window's template scope). -->
    <Style Selector="ComboBox.field /template/ Border#Background">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <!-- hover / press: no colour change — hold the resting fill / border; feedback is an Opacity fade. -->
    <Style Selector="ComboBox.field:pointerover /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:pressed /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:pressed">
      <Setter Property="Opacity" Value="0.6" />
    </Style>
    <!-- focus: keep the neutral border too (no accent) so the box is status-independent. -->
    <Style Selector="ComboBox.field:focus-visible /template/ Border#HighlightBackground">
      <Setter Property="IsVisible" Value="True" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="ComboBox.field /template/ ContentControl#ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBox.field /template/ PathIcon#DropDownGlyph">
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
    </Style>
    <Style Selector="ComboBox.field:disabled /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:disabled /template/ ContentControl#ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource AgMuted2Brush}" />
    </Style>

    <!-- PathIcon.spin : continuous rotation while a source download / re-materialize is in flight -->
    <Style Selector="PathIcon.spin">
      <!-- 50%,50% = RelativePoint center. A plain "0.5,0.5" parses as ABSOLUTE 0.5px (≈ top-left),
           which makes the icon orbit a corner instead of spinning about its own centre. -->
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
      <Setter Property="RenderTransform" Value="rotate(0)" />
    </Style>
    <Style Selector="PathIcon.spin">
      <Style.Animations>
        <Animation Duration="0:0:0.9" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="RotateTransform.Angle" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="RotateTransform.Angle" Value="360" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Button.sourcerow : the clickable source body; a left-click opens its delete menu (flyout) -->
    <Style Selector="Button.sourcerow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />    </Style>
    <Style Selector="Button.sourcerow /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.sourcerow:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.sourcerow:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Window.Styles>

  <Grid>
  <DockPanel LastChildFill="True">

    <!-- HEADER : unified connection-control command bar -->
    <Border DockPanel.Dock="Top" Height="54"
            Background="{DynamicResource AgSidebarBrush}"
            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">

        <!-- LEFT: segmented nav pill -->
        <Border Grid.Column="0" VerticalAlignment="Center"
                Background="{DynamicResource AgInsetBrush}"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="3">
          <StackPanel Orientation="Horizontal" Spacing="2">
            <Button Classes="seg" Classes.active="{Binding IsHome}"
                    Command="{Binding NavHomeCommand}"
                    Content="Главная" MinWidth="84" />
            <Button Classes="seg" Classes.active="{Binding IsRouting}"
                    Command="{Binding NavRoutingCommand}"
                    Content="Маршрутизация" MinWidth="116" />
            <Button Classes="seg" Classes.active="{Binding IsSettings}"
                    Command="{Binding NavSettingsCommand}"
                    Content="Настройки" MinWidth="92" />
          </StackPanel>
        </Border>

        <!-- RIGHT: unified connection control (status + connect as one pill) -->
        <Border Grid.Column="2" VerticalAlignment="Center"
                Background="{DynamicResource AgInsetBrush}"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="11" Padding="4">
          <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">

            <!-- live status segment -->
            <StackPanel Orientation="Horizontal" Spacing="9"
                        VerticalAlignment="Center" Margin="9,0,11,0">
              <Ellipse Width="10" Height="10" Fill="{Binding AgentStatusBrush}"
                       VerticalAlignment="Center" />
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding AgentStatusText}"
                           FontSize="12.5" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ActiveProfileName}"
                           FontSize="10.5" Classes="muted"
                           TextTrimming="CharacterEllipsis" MaxWidth="170" />
              </StackPanel>
            </StackPanel>

            <!-- 1px vertical divider -->
            <Border Width="1" Margin="0,5" Background="{DynamicResource AgBorder2Brush}" />

            <!-- connect / stop action (EXISTING bindings, verbatim) -->
            <Button Classes="connectpill" Margin="6,0,0,0"
                    Background="{Binding ConnectButtonBrush}"
                    Content="{Binding ConnectButtonText}"
                    Command="{Binding ToggleConnectionCommand}"
                    IsEnabled="{Binding CanToggleConnection}" />
          </StackPanel>
        </Border>

      </Grid>
    </Border>

    <!-- BODY -->
    <Grid ColumnDefinitions="400,*">

      <!-- LEFT SIDEBAR -->
      <DockPanel Grid.Column="0" Background="{DynamicResource AgSidebarBrush}" LastChildFill="True">
        <DockPanel.Styles>
          <Style Selector="Border.card">
            <Setter Property="Padding" Value="15" />
          </Style>
        </DockPanel.Styles>

        <Grid>

        <!-- Profiles list (Home / Settings tabs) -->
        <Border Classes="card" Margin="16,16,16,16" Padding="0" IsVisible="{Binding !IsRouting}">
          <DockPanel LastChildFill="True">
            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Margin="15,14,15,10">
              <TextBlock Grid.Column="0" Classes="section" Text="ПРОФИЛИ" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                      Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Balancers.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
              </Border>
              <Button Grid.Column="3" Classes="softbtn" Click="OnAddClick">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="Профиль" />
                </StackPanel>
              </Button>
            </Grid>

            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding Balancers}" Margin="12,2,12,12">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="subcard" Margin="0,4">
                      <StackPanel>

                        <!-- Header (always visible): a plain panel. The left circle selects the
                             active profile; only the chevron expands / collapses. -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="12,9">
                          <Button Grid.Column="0" Classes="radiopick" VerticalAlignment="Center"
                                  Command="{Binding SelectCommand}"
                                  ToolTip.Tip="Сделать активным профилем">
                            <Grid Width="18" Height="18">
                              <Ellipse Width="16" Height="16" StrokeThickness="2"
                                       Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                              <Ellipse Width="16" Height="16" StrokeThickness="2"
                                       Stroke="{DynamicResource AgAccentBrush}" Fill="Transparent"
                                       IsVisible="{Binding IsActive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                              <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                                       IsVisible="{Binding IsActive}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                          </Button>
                          <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5" />
                            <!-- one-line summary only while collapsed; the expanded editor shows the details -->
                            <TextBlock Text="{Binding Detail}" FontSize="11.5" Classes="muted"
                                       TextTrimming="CharacterEllipsis"
                                       IsVisible="{Binding !IsExpanded}" />
                          </StackPanel>
                          <Button Grid.Column="2" Classes="icon" VerticalAlignment="Center" Padding="8,6"
                                  Command="{Binding ToggleExpandCommand}"
                                  ToolTip.Tip="Развернуть / свернуть">
                            <Panel>
                              <TextBlock Text="▼" IsVisible="{Binding IsExpanded}" Classes="muted" />
                              <TextBlock Text="▶" IsVisible="{Binding !IsExpanded}" Classes="muted" />
                            </Panel>
                          </Button>
                        </Grid>

                        <!-- Expanded body -->
                        <Border IsVisible="{Binding IsExpanded}"
                                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0"
                                Padding="13,14">
                          <StackPanel Spacing="15">

                            <!-- Name -->
                            <StackPanel Spacing="6">
                              <TextBlock Classes="label" Text="НАЗВАНИЕ" />
                              <TextBox Classes="field" Text="{Binding Name}" IsReadOnly="True" />
                            </StackPanel>

                            <!-- Balancer + interval -->
                            <StackPanel Spacing="9">
                              <TextBlock Classes="label" Text="БАЛАНСИРОВЩИК" />
                              <Border Background="{DynamicResource AgInsetBrush}"
                                      BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                      CornerRadius="9" Padding="3">
                                <Grid ColumnDefinitions="*,3,*">
                                  <Button Grid.Column="0" Classes="seg"
                                          Classes.active="{Binding IsPriorityMode}"
                                          Command="{Binding SetPriorityModeCommand}"
                                          Content="По приоритету" HorizontalAlignment="Stretch" />
                                  <Button Grid.Column="2" Classes="seg"
                                          Classes.active="{Binding IsLatencyMode}"
                                          Command="{Binding SetLatencyModeCommand}"
                                          Content="По доступности" HorizontalAlignment="Stretch" />
                                </Grid>
                              </Border>
                              <Grid ColumnDefinitions="*,Auto,4,Auto,4,Auto">
                                <TextBlock Grid.Column="0" Classes="muted" FontSize="11.5"
                                           Text="Интервал проверки" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Classes="chip"
                                        Classes.active="{Binding IsInterval10}"
                                        Command="{Binding SetInterval10Command}" Content="10с" />
                                <Button Grid.Column="3" Classes="chip"
                                        Classes.active="{Binding IsInterval30}"
                                        Command="{Binding SetInterval30Command}" Content="30с" />
                                <Button Grid.Column="5" Classes="chip"
                                        Classes.active="{Binding IsInterval60}"
                                        Command="{Binding SetInterval60Command}" Content="60с" />
                              </Grid>
                            </StackPanel>

                            <!-- Routing -->
                            <StackPanel Spacing="6">
                              <TextBlock Classes="label" Text="СПИСОК МАРШРУТИЗАЦИИ" />
                              <ComboBox Classes="field" ItemsSource="{Binding RoutingListOptions}"
                                        SelectedItem="{Binding SelectedRoutingList, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                  </DataTemplate>
                                </ComboBox.ItemTemplate>
                              </ComboBox>
                              <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding CanToggleRouting}" Margin="0,5,0,0">
                                <ToggleSwitch Grid.Column="0" IsChecked="{Binding UseRouting, Mode=TwoWay}"
                                              OnContent="" OffContent=""
                                              MinWidth="0" />
                                <TextBlock Grid.Column="1" Margin="11,0,0,0"
                                           Text="Использовать маршрутизацию" FontSize="12.5" FontWeight="Medium"
                                           VerticalAlignment="Center" />
                              </Grid>
                            </StackPanel>

                            <!-- Configs -->
                            <StackPanel Spacing="8">
                              <Grid ColumnDefinitions="Auto,Auto">
                                <TextBlock Grid.Column="0" Classes="label" Text="КОНФИГУРАЦИИ" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                                        Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding Members.Count}" FontSize="10.5" Classes="muted" FontWeight="SemiBold" />
                                </Border>
                              </Grid>
                              <Grid ColumnDefinitions="*,Auto">
                                <ComboBox Grid.Column="0" Classes="field"
                                          ItemsSource="{Binding AvailableConfigs}"
                                          SelectedItem="{Binding AddMemberSelection, Mode=TwoWay}"
                                          PlaceholderText="Выбрать..." Margin="0,0,8,0" />
                                <Button Grid.Column="1" Classes="accent"
                                        Command="{Binding AddMemberCommand}">
                                  <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="+" />
                                    <TextBlock Text="Добавить" />
                                  </StackPanel>
                                </Button>
                              </Grid>

                              <ItemsControl ItemsSource="{Binding Members}">
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Background="{DynamicResource AgPanelBrush}"
                                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                            CornerRadius="9" Padding="9,8" Margin="0,3">
                                      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <Ellipse Grid.Column="0" Width="9" Height="9"
                                                 Fill="{DynamicResource AgMuted2Brush}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Margin="9,0,0,0" Text="{Binding}"
                                                   FontSize="12.5" FontWeight="Medium"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="0">
                                          <Button Classes="icon" Content="▲"
                                                  Command="{Binding $parent[ItemsControl].DataContext.MoveUpCommand}"
                                                  CommandParameter="{Binding}"
                                                  FontSize="8" Padding="3,0" />
                                          <Button Classes="icon" Content="▼"
                                                  Command="{Binding $parent[ItemsControl].DataContext.MoveDownCommand}"
                                                  CommandParameter="{Binding}"
                                                  FontSize="8" Padding="3,0" />
                                        </StackPanel>
                                        <Button Grid.Column="3" Classes="icon" Content="✕" Margin="4,0,0,0"
                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveMemberCommand}"
                                                CommandParameter="{Binding}" />
                                      </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>

                          </StackPanel>
                        </Border>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Border>

        <!-- Routing lists (Routing tab) -->
        <Border Classes="card" Margin="16,16,16,16" Padding="0" IsVisible="{Binding IsRouting}">
          <DockPanel LastChildFill="True">
            <!-- bases nav: opens the geo-data bases panel on the right (active when no rule is open) -->
            <Button DockPanel.Dock="Top" Classes="rowselect" Classes.active="{Binding !HasRoutingEditor}"
                    Margin="12,12,12,0" Command="{Binding CloseRoutingEditorCommand}">
              <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                  <Ellipse Width="16" Height="16" StrokeThickness="2"
                           Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                           IsVisible="{Binding !HasRoutingEditor}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <TextBlock Grid.Column="1" Margin="11,0,0,0" Text="Базы гео-данных"
                           FontWeight="SemiBold" FontSize="13.5" VerticalAlignment="Center" />
              </Grid>
            </Button>

            <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource AgBorderBrush}" Margin="12,12,12,2" />

            <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Margin="15,8,15,10">
              <TextBlock Grid.Column="0" Classes="section" Text="ПРАВИЛА" VerticalAlignment="Center" />
              <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                      Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding RoutingLists.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
              </Border>
              <Button Grid.Column="3" Classes="softbtn" Command="{Binding NewRoutingListCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="Правило" />
                </StackPanel>
              </Button>
            </Grid>

            <ScrollViewer>
              <StackPanel Margin="12,2,12,12">
                <ItemsControl ItemsSource="{Binding RoutingLists}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Classes="rowselect" Classes.active="{Binding IsSelected}" Margin="0,3"
                              Command="{Binding $parent[ItemsControl].DataContext.SelectRoutingListCommand}"
                              CommandParameter="{Binding}">
                        <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                          <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                            <Ellipse Width="16" Height="16" StrokeThickness="2"
                                     Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                                     IsVisible="{Binding IsSelected}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Grid>
                          <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5" />
                            <TextBlock Text="{Binding Detail}" FontSize="11.5" Classes="muted"
                                       TextTrimming="CharacterEllipsis" />
                          </StackPanel>
                        </Grid>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock IsVisible="{Binding !HasRoutingLists}"
                           Text="Нет правил. Нажмите «+ Правило»."
                           Classes="muted" FontSize="12" Margin="6,12" TextWrapping="Wrap" />
              </StackPanel>
            </ScrollViewer>
          </DockPanel>
        </Border>

        </Grid>
      </DockPanel>

      <!-- RIGHT CONTENT -->
      <Border Grid.Column="1" Classes="card" Margin="0,16,16,16" Padding="0">
        <Grid>

          <!-- HOME -->
          <DockPanel IsVisible="{Binding IsHome}" LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Margin="24,20,24,16">
              <TextBlock Classes="section" Text="СОСТОЯНИЕ БАЛАНСИРОВЩИКА" />
              <TextBlock Text="Активный профиль и латентности будут отображаться здесь, когда агент будет подключён."
                         Classes="muted" FontSize="12" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0"
                    Background="{DynamicResource AgInsetBrush}" Margin="24,8,24,18" CornerRadius="12">
              <ScrollViewer>
                <StackPanel Margin="16,13" Spacing="6">
                  <TextBlock Text="Логи появятся когда агент будет подключён и доступен через IPC."
                             Classes="muted mono" FontSize="12" />
                </StackPanel>
              </ScrollViewer>
            </Border>
          </DockPanel>

          <!-- ROUTING : selected list editor (inline, replaces the dialog) -->
          <Panel IsVisible="{Binding IsRouting}">

            <!-- empty state: geo-source management (and a hint to pick a list) -->
            <DockPanel IsVisible="{Binding !HasRoutingEditor}" LastChildFill="True" Margin="24,22">

              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="Базы гео-данных" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="softbtn" Command="{Binding UpdateSourcesCommand}" Content="Обновить все" />
              </Grid>

              <StackPanel DockPanel.Dock="Top" Spacing="6">
                <TextBlock Classes="label" Text="ДОБАВИТЬ БАЗУ" />
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <ComboBox Grid.Column="0" Classes="field" Width="118" Margin="0,0,8,0"
                            ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                            IsEnabled="{Binding !SourceKindLocked}"
                            ToolTip.Tip="Тип определён по имени файла в URL" />
                  <TextBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                           Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
                  <Button Grid.Column="2" Classes="accent" Command="{Binding AddSourceCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="+" />
                      <TextBlock Text="Добавить" />
                    </StackPanel>
                  </Button>
                </Grid>
                <TextBlock Classes="muted" FontSize="11.5" Margin="0,2,0,0" TextWrapping="Wrap"
                           Text="geosite — категории доменов, geoip — страны. Файл скачивается сразу. Значок ⟳ обновляет базу, «Обновить все» — все сразу; нажмите на базу, чтобы удалить." />
                <TextBlock Classes="label" Text="ИСТОЧНИКИ" Margin="0,10,0,0" />
              </StackPanel>

              <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                      Background="{DynamicResource AgInsetBrush}" CornerRadius="12" Margin="0,8,0,0">
                <ScrollViewer>
                  <StackPanel Margin="10,10">
                    <ItemsControl ItemsSource="{Binding Sources}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{DynamicResource AgPanelBrush}"
                                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                  CornerRadius="9" Padding="11,9" Margin="0,3">
                            <Grid ColumnDefinitions="*,Auto">
                              <!-- row body: click opens the delete menu (built in code-behind) -->
                              <Button Grid.Column="0" Classes="sourcerow" Click="OnSourceRowClick"
                                      ToolTip.Tip="Нажмите, чтобы удалить">
                                <StackPanel VerticalAlignment="Center">
                                  <TextBlock Classes="srctitle" Text="{Binding Detail}" FontSize="12.5" FontWeight="SemiBold" />
                                  <TextBlock Text="{Binding Url}" FontSize="11" Classes="muted mono"
                                             TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                              </Button>
                              <!-- refresh: spins + shows download % while an update is in flight -->
                              <Button Grid.Column="1" Classes="icon" VerticalAlignment="Center" Margin="8,0,0,0"
                                      Command="{Binding UpdateCommand}" IsEnabled="{Binding !Updating}"
                                      ToolTip.Tip="Обновить базу">
                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                  <TextBlock Text="{Binding ProgressText}" IsVisible="{Binding ShowProgress}"
                                             FontSize="11.5" VerticalAlignment="Center" />
                                  <PathIcon Classes.spin="{Binding Updating}" Data="{DynamicResource AgRefreshGeometry}"
                                            Width="14" Height="14" />
                                </StackPanel>
                              </Button>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock IsVisible="{Binding !HasSources}"
                               Text="Пока нет баз. Добавьте geosite/geoip выше."
                               Classes="muted" FontSize="12" Margin="2,8" TextWrapping="Wrap" />
                  </StackPanel>
                </ScrollViewer>
              </Border>
            </DockPanel>

            <DockPanel IsVisible="{Binding HasRoutingEditor}" LastChildFill="True" Margin="24,22">

              <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="Правила маршрутизации" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="softbtn" IsVisible="{Binding !RoutingEditor.IsNew}"
                        Command="{Binding DeleteRoutingListEditCommand}" Content="Удалить правило" />
              </Grid>

              <StackPanel DockPanel.Dock="Top" Spacing="14">
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="ИМЯ ПРАВИЛА" />
                  <TextBox Classes="field" Text="{Binding RoutingEditor.Name, Mode=TwoWay}" Watermark="напр. openai-route" />
                </StackPanel>

                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="ДОБАВИТЬ ЗАПИСЬ (ГЕО-КАТЕГОРИЯ, ДОМЕН ИЛИ CIDR)" />
                  <Grid ColumnDefinitions="*,Auto">
                    <AutoCompleteBox Grid.Column="0" Margin="0,0,8,0"
                                     Watermark="напр. geosite:openai, geoip:de, example.com, 1.2.3.0/24"
                                     Text="{Binding RoutingEditor.RuleInput, Mode=TwoWay}"
                                     ItemsSource="{Binding RoutingEditor.GeoSuggestions}"
                                     FilterMode="ContainsOrdinal" MaxDropDownHeight="220" />
                    <Button Grid.Column="1" Classes="accent" Command="{Binding RoutingEditor.AddRuleCommand}">
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="+" />
                        <TextBlock Text="Добавить" />
                      </StackPanel>
                    </Button>
                  </Grid>
                </StackPanel>

                <TextBlock Text="{Binding RoutingEditor.StatusMessage}" Classes="muted"
                           FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap" />

                <TextBlock Classes="label" Text="ЗАПИСИ" />
              </StackPanel>

              <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                      Background="{DynamicResource AgInsetBrush}" CornerRadius="12" Margin="0,8,0,0">
                <ScrollViewer>
                  <ItemsControl ItemsSource="{Binding RoutingEditor.Rules}" Margin="10,10">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Background="{DynamicResource AgPanelBrush}"
                                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                CornerRadius="9" Padding="10,7" Margin="0,3">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding}" Classes="mono" FontSize="12.5"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1" Classes="icon" Content="✕"
                                    Command="{Binding $parent[ItemsControl].DataContext.RoutingEditor.RemoveRuleCommand}"
                                    CommandParameter="{Binding}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Border>

            </DockPanel>
          </Panel>

          <!-- SETTINGS -->
          <ScrollViewer IsVisible="{Binding IsSettings}">
            <StackPanel Margin="24,22" MaxWidth="640" HorizontalAlignment="Left">
              <TextBlock Text="Настройки" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,18" />

              <Border Classes="subcard" Margin="0,0,0,16">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="17,13">
                    <TextBlock Text="ОБЩИЕ" Classes="section" />
                  </Border>

                  <!-- Theme (existing, unchanged) -->
                  <Grid ColumnDefinitions="*,Auto" Margin="17,14">
                    <TextBlock Text="Тема оформления" FontSize="13.5" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="softbtn" Content="{Binding ThemeLabel}" Command="{Binding ToggleThemeCommand}" />
                  </Grid>

                  <!-- divider -->
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />

                  <!-- Language (relocated from header; placeholder, disabled) -->
                  <Grid ColumnDefinitions="*,Auto" Margin="17,14">
                    <TextBlock Text="Язык интерфейса" FontSize="13.5" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="2" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Classes="seg active" Content="RU" IsEnabled="False" />
                        <Button Classes="seg" Content="EN" IsEnabled="False" />
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="subcard" Margin="0,0,0,16">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="17,13">
                    <TextBlock Text="БЕЗОПАСНОСТЬ" Classes="section" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto" Margin="17,14">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                      <TextBlock Text="Kill-switch" FontSize="13.5" />
                      <TextBlock Text="Блокировать весь трафик вне туннеля. Применяется при переподключении."
                                 Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding KillSwitchEnabled, Mode=TwoWay}" />
                  </Grid>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />
                  <Grid ColumnDefinitions="*,Auto" Margin="17,14">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                      <TextBlock Text="Доступ к локальной сети" FontSize="13.5" />
                      <TextBlock Text="Разрешить локальную сеть при kill-switch (SSH, принтеры, NAS)."
                                 Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding AllowLan, Mode=TwoWay}" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="subcard" Margin="0,0,0,16">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="17,13">
                    <TextBlock Text="О ПРИЛОЖЕНИИ" Classes="section" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto" Margin="17,14">
                    <TextBlock Text="Версия" FontSize="13.5" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="AmneziaGeo 1.0.0" Classes="muted mono" FontSize="12.5" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

        </Grid>
      </Border>

    </Grid>

  </DockPanel>

    <!-- TOP-CENTER NOTICE BANNER (settings changed / better connection available) -->
    <Border IsVisible="{Binding NoticeVisible}"
            VerticalAlignment="Top" HorizontalAlignment="Center"
            Margin="0,58,0,0" MaxWidth="560"
            Background="{DynamicResource AgAccentBrush}"
            CornerRadius="10" Padding="16,10"
            BoxShadow="0 6 20 0 #33000000">
      <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
        <Ellipse Grid.Column="0" Width="9" Height="9" Fill="White" VerticalAlignment="Center" Margin="0,0,10,0" />
        <TextBlock Grid.Column="1" Text="{Binding NoticeText}" Foreground="White"
                   FontSize="12.5" FontWeight="SemiBold"
                   TextWrapping="Wrap" VerticalAlignment="Center" />
        <Button Grid.Column="2" Classes="radiopick" Command="{Binding DismissNoticeCommand}"
                Content="✕" Foreground="White" FontSize="13" Margin="10,0,0,0"
                VerticalAlignment="Center" ToolTip.Tip="Закрыть" />
      </Grid>
    </Border>

  </Grid>
</Window>
