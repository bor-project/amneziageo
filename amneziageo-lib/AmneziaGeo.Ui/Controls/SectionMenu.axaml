<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmneziaGeo.Ui.Controls"
             x:Class="AmneziaGeo.Ui.Controls.SectionMenu"
             x:Name="Root">
  <Border Background="{DynamicResource AgInsetBrush}"
          BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
          CornerRadius="9" Padding="3" MaxWidth="420" HorizontalAlignment="Left">
    <UniformGrid Columns="3">
      <Button Classes="seg" HorizontalAlignment="Stretch" Padding="8,6"
              Classes.active="{Binding #Root.Item1Active}"
              Command="{Binding #Root.Command}"
              CommandParameter="{Binding #Root.Item1Param}"
              IsEnabled="{Binding #Root.Item1Enabled}"
              Content="{Binding #Root.Item1Text}" />
      <Button Classes="seg" HorizontalAlignment="Stretch" Padding="8,6"
              Classes.active="{Binding #Root.Item2Active}"
              Command="{Binding #Root.Command}"
              CommandParameter="{Binding #Root.Item2Param}"
              IsEnabled="{Binding #Root.Item2Enabled}"
              Content="{Binding #Root.Item2Text}" />
      <Button Classes="seg" HorizontalAlignment="Stretch" Padding="8,6"
              Classes.active="{Binding #Root.Item3Active}"
              Command="{Binding #Root.Command}"
              CommandParameter="{Binding #Root.Item3Param}"
              IsEnabled="{Binding #Root.Item3Enabled}"
              Content="{Binding #Root.Item3Text}" />
    </UniformGrid>
  </Border>
</UserControl>
