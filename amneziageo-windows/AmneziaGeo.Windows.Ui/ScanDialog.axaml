<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AmneziaGeo.Windows.Ui.ScanDialog"
        Title="Сканировать QR с камеры"
        Width="480" Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <DockPanel Margin="16">

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button Content="Отмена" Click="OnCancel" IsCancel="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
               Foreground="{DynamicResource AgMutedBrush}" FontSize="12"
               TextWrapping="Wrap" Margin="0,10,0,0" />

    <Border Background="Black" CornerRadius="8" ClipToBounds="True">
      <Image Source="{Binding Preview}" Stretch="Uniform" />
    </Border>

  </DockPanel>
</Window>
