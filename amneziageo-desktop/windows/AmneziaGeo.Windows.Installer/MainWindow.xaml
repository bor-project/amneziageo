<Window x:Class="AmneziaGeo.Windows.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:AmneziaGeo.Windows.Installer"
        Title="AmneziaGeo" Height="440" Width="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource AppFontFamily}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="B2V" />
    <!-- #151: hides while keeping layout space, so the progress bar does not shift down. -->
    <l:BoolToVisibilityHiddenConverter x:Key="B2VH" />
  </Window.Resources>

  <Grid Margin="18">
    <Border Style="{StaticResource Card}" Padding="24,22">
      <DockPanel LastChildFill="True">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="{Binding Heading}" FontSize="23" FontWeight="SemiBold" />
          <TextBlock Text="{Binding VersionText}" Style="{StaticResource MutedTextBlock}" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Sub text / status line -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding SubText}"
                   Style="{StaticResource MutedTextBlock}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   Margin="0,16,0,0" />

        <!-- Geo-list download outcome (final screen, install/update). -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding GeoResult}"
                   Style="{StaticResource MutedTextBlock}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"
                   Visibility="{Binding HasGeoResult, Converter={StaticResource B2V}}" />

        <!-- Progress (apply phase) -->
        <StackPanel DockPanel.Dock="Bottom"
                    Visibility="{Binding ShowProgress, Converter={StaticResource B2V}}">
          <!-- RangeBase.Value binds TwoWay by default; Progress is read-only, so pin OneWay or the binding throws. -->
          <ProgressBar Value="{Binding Progress, Mode=OneWay}" Maximum="100" IsIndeterminate="{Binding IsIndeterminate}" />
          <TextBlock Text="{Binding Progress, StringFormat={}{0}%}"
                     Style="{StaticResource MutedTextBlock}"
                     HorizontalAlignment="Right" Margin="0,8,0,0"
                     Visibility="{Binding ShowPercent, Converter={StaticResource B2VH}}" />
        </StackPanel>

        <!-- Done. The launch-after choice now lives on the options step (#165); when it is on, a
             successful install/update auto-closes here and starts the app, so this screen is only
             reached when launch is off or the run failed - just a Close button. -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Visibility="{Binding ShowDone, Converter={StaticResource B2V}}">
          <Button Content="{l:Tr InstallerUi_Close}" Style="{StaticResource AccentButton}" Command="{Binding CloseCommand}" />
        </StackPanel>

        <!-- Ready, step 1 (#114): pick a maintenance action. Its options move to a dedicated step below. -->
        <StackPanel DockPanel.Dock="Bottom"
                    Visibility="{Binding ShowActionButtons, Converter={StaticResource B2V}}">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{l:Tr InstallerUi_Remove}" Style="{StaticResource DangerButton}"
                    Command="{Binding RemoveCommand}" Margin="0,0,10,0"
                    Visibility="{Binding ShowRemove, Converter={StaticResource B2V}}" />
            <Button Content="{l:Tr InstallerUi_Repair}"
                    Command="{Binding RepairCommand}" Margin="0,0,10,0"
                    Visibility="{Binding ShowRepair, Converter={StaticResource B2V}}" />
            <Button Content="{l:Tr InstallerUi_Update}" Style="{StaticResource AccentButton}"
                    Command="{Binding UpdateCommand}" Margin="0,0,10,0"
                    Visibility="{Binding ShowUpdate, Converter={StaticResource B2V}}" />
            <Button Content="{Binding InstallButtonText}" Style="{StaticResource AccentButton}"
                    Command="{Binding InstallCommand}"
                    Visibility="{Binding ShowInstall, Converter={StaticResource B2V}}" />
          </StackPanel>
        </StackPanel>

        <!-- Ready, step 2 (#114): configure the chosen action, then Continue / Back. Which options appear is
             per-action (install/update/repair: settings file + geo + reset; remove: only delete config). -->
        <StackPanel DockPanel.Dock="Bottom"
                    Visibility="{Binding ShowOptionsStep, Converter={StaticResource B2V}}">
          <TextBlock Text="{Binding OptionsHeading}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12" />
          <!-- #123: pick a configuration file (a portable bundle or a single config); it is applied through the
               same agent import path as the in-app import, not by swapping the SQLite database. -->
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12"
                      Visibility="{Binding ShowConfigFileOption, Converter={StaticResource B2V}}">
            <Button Content="{l:Tr InstallerUi_ConfigFile}" Command="{Binding PickConfigCommand}" Margin="0,0,10,0" />
            <TextBlock Text="{Binding ConfigFileLabel}" Style="{StaticResource MutedTextBlock}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
          </StackPanel>
          <!-- #123: when the picked file may collide with an existing configuration, resolve it inline here
               (never a separate dialog) - the same four policies as the in-app bundle import. -->
          <StackPanel Margin="0,0,0,12"
                      Visibility="{Binding ShowConflictPolicy, Converter={StaticResource B2V}}">
            <TextBlock Text="{l:Tr BundleImport_ConflictLabel}" Style="{StaticResource MutedTextBlock}" Margin="0,0,0,4" />
            <ComboBox SelectedIndex="{Binding ConflictPolicyIndex, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="220">
              <ComboBoxItem Content="{l:Tr BundleImport_ConflictAddNew}" />
              <ComboBoxItem Content="{l:Tr BundleImport_ConflictReplace}" />
              <ComboBoxItem Content="{l:Tr BundleImport_ConflictSkip}" />
              <ComboBoxItem Content="{l:Tr BundleImport_ConflictMerge}" />
            </ComboBox>
          </StackPanel>
          <CheckBox Content="{l:Tr InstallerUi_DownloadGeoDbUpdates}"
                    IsChecked="{Binding DownloadLists}"
                    Margin="0,0,0,12"
                    Visibility="{Binding ShowDownloadOption, Converter={StaticResource B2V}}" />
          <!-- #165: launch-after choice up front (install/update only). When on, a successful run
               closes the installer and starts the app instead of showing the Done screen. -->
          <CheckBox Content="{l:Tr InstallerUi_LaunchAfterInstall}"
                    IsChecked="{Binding LaunchOnClose}"
                    Margin="0,0,0,12"
                    Visibility="{Binding ShowLaunchOnInstall, Converter={StaticResource B2V}}" />
          <!-- #105/#114: wipe the runtime configuration (ProgramData\AmneziaGeo). The label is contextual -
               «Сбросить настройки» on install/update/repair, «Удалить конфигурацию и кэш» on removal. Off by
               default so a plain (re)install keeps the user's profiles and settings. -->
          <CheckBox Content="{Binding DeleteConfigLabel}"
                    IsChecked="{Binding DeleteConfig}"
                    Margin="0,0,0,12"
                    Visibility="{Binding ShowDeleteConfigOption, Converter={StaticResource B2V}}" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{l:Tr InstallerUi_Back}" Command="{Binding BackCommand}" Margin="0,0,10,0"
                    Visibility="{Binding ShowBack, Converter={StaticResource B2V}}" />
            <Button Content="{l:Tr InstallerUi_Continue}" Style="{StaticResource AccentButton}"
                    Command="{Binding ConfirmCommand}" />
          </StackPanel>
        </StackPanel>

        <!-- filler so DockPanel balances -->
        <Grid />
      </DockPanel>
    </Border>
  </Grid>
</Window>
