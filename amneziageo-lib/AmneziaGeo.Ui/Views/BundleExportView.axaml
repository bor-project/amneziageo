<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Ui.Localization"
             x:Class="AmneziaGeo.Ui.Views.BundleExportView"
             x:CompileBindings="True"
             x:DataType="vm:BundleExportViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgCopyGeometry">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
    <StreamGeometry x:Key="AgDownloadGeometry">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</StreamGeometry>
  </UserControl.Resources>
  <StackPanel Spacing="12">
    <TextBlock Text="{l:Tr BundleExport_Heading}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
    <TextBlock Text="{l:Tr BundleExport_PrivateKeyWarning}" Foreground="{DynamicResource AgWarnBrush}"
               FontSize="12" TextWrapping="Wrap" />

    <!-- PHASE 1: selection tree. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent" IsVisible="{Binding !IsExported}">
      <ScrollViewer MaxHeight="360" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="16">

          <StackPanel Spacing="6">
            <TextBlock Text="{l:Tr BundleExport_ProfilesSection}" Classes="label" />
            <ItemsControl ItemsSource="{Binding ProfileItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:BundleItem">
                  <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsEnabled="{Binding !IsLocked}" Margin="0,3">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontSize="13.5" />
                      <TextBlock Text="{Binding Detail}" Classes="muted" FontSize="11.5" />
                    </StackPanel>
                  </CheckBox>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{l:Tr BundleExport_ConfigsSection}" Classes="label" />
            <ItemsControl ItemsSource="{Binding ConfigItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:BundleItem">
                  <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsEnabled="{Binding !IsLocked}" Margin="0,3">
                    <StackPanel>
                      <TextBlock Text="{Binding Name}" FontSize="13.5" />
                      <TextBlock Text="{Binding Detail}" Classes="muted" FontSize="11.5" />
                    </StackPanel>
                  </CheckBox>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Text="{l:Tr BundleExport_RoutingSection}" Classes="label" />
            <TextBlock Text="{l:Tr BundleExport_RoutingRulesHint}" Classes="muted" FontSize="11" TextWrapping="Wrap" />
            <ItemsControl ItemsSource="{Binding RoutingItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:BundleItem">
                  <StackPanel Margin="0,3">
                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" IsEnabled="{Binding !IsLocked}">
                      <StackPanel>
                        <TextBlock Text="{Binding Name}" FontSize="13.5" />
                        <TextBlock Text="{Binding Detail}" Classes="muted" FontSize="11.5" />
                      </StackPanel>
                    </CheckBox>
                    <!-- Per-rule exclusion: uncheck a rule to drop it from this list in the bundle. -->
                    <ItemsControl ItemsSource="{Binding Rules}" IsVisible="{Binding HasRules}"
                                  IsEnabled="{Binding IsChecked}" Margin="26,2,0,0">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:BundleRuleItem">
                          <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Margin="0,1" MinHeight="0">
                            <TextBlock Text="{Binding Token}" FontSize="11.5"
                                       FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" />
                          </CheckBox>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

        </StackPanel>
      </ScrollViewer>
    </Border>

    <Button Classes="accent" Width="180" HorizontalAlignment="Left" IsVisible="{Binding !IsExported}"
            Content="{l:Tr BundleExport_ExportButton}" Command="{Binding ExportCommand}" IsEnabled="{Binding !IsBusy}" />

    <!-- PHASE 2: resulting bundle JSON. -->
    <Border BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
            CornerRadius="8" Background="{DynamicResource AgPanelBrush}" IsVisible="{Binding IsExported}">
      <TextBox Text="{Binding Payload}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
               VerticalContentAlignment="Top" Height="360"
               ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
               BorderThickness="0" Background="Transparent"
               FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="11" />
    </Border>
    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsExported}">
      <Button Classes="methodpick" Width="180" Click="OnCopy">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource AgCopyGeometry}" Width="14" Height="14" />
          <TextBlock Text="{l:Tr BundleExport_CopyButton}" />
        </StackPanel>
      </Button>
      <Button Classes="accent" Width="180" Click="OnSaveFile">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource AgDownloadGeometry}" Width="14" Height="14" />
          <TextBlock Text="{l:Tr BundleExport_SaveToFileButton}" />
        </StackPanel>
      </Button>
    </StackPanel>

    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource AgDownBrush}" FontSize="12"
               TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
