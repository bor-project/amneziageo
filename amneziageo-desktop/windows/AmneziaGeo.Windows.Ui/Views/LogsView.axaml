<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.LogsView"
             x:CompileBindings="True"
             x:DataType="vm:LogsViewModel">
  <StackPanel Spacing="14">
    <!-- Header. -->
    <TextBlock Classes="section" Text="{l:Tr Main_AgentLogSection}" />

    <!-- Capture settings card: verbosity level + route log. Applies live. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="14">
        <TextBlock Text="{l:Tr Main_LogCaptureTitle}" FontWeight="SemiBold" FontSize="15" />

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
            <TextBlock Text="{l:Tr Main_LogVerbosityTitle}" FontSize="13.5" />
            <TextBlock Text="{l:Tr Main_LogVerbosityHint}" Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
          </StackPanel>
          <ComboBox Grid.Column="1" Classes="field" VerticalAlignment="Center" MinWidth="150"
                    ItemsSource="{Binding LogLevels}" SelectedItem="{Binding LogLevel, Mode=TwoWay}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
            <TextBlock Text="{l:Tr Main_RouteLogTitle}" FontSize="13.5" />
            <TextBlock Text="{l:Tr Main_RouteLogHint}" Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
          </StackPanel>
          <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding RouteLogEnabled, Mode=TwoWay}" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- Viewer card: file picker + live-tail follow, search over the shown tail, and the log itself. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="10">
        <TextBlock Text="{l:Tr Main_LogViewerTitle}" FontWeight="SemiBold" FontSize="15" />

        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" VerticalAlignment="Center">
          <TextBlock Grid.Column="0" Text="{l:Tr Main_LogFileLabel}" Classes="muted" FontSize="11.5" VerticalAlignment="Center" />
          <ComboBox Grid.Column="1" Classes="field" HorizontalAlignment="Stretch"
                    ItemsSource="{Binding LogFiles}" SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:LogFileChoice">
                <TextBlock Text="{Binding Display}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <TextBlock Grid.Column="2" Text="{l:Tr Main_LogFollowLabel}" Classes="muted" FontSize="11.5" VerticalAlignment="Center" />
          <ToggleSwitch Grid.Column="3" IsChecked="{Binding LogFollow, Mode=TwoWay}" VerticalAlignment="Center" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" VerticalAlignment="Center">
          <TextBox Grid.Column="0" Classes="field" Text="{Binding SearchQuery, Mode=TwoWay}"
                   Watermark="{l:Tr Main_LogSearchWatermark}" />
          <TextBlock Grid.Column="1" Text="{Binding SearchSummary}" Classes="muted" FontSize="11.5"
                     VerticalAlignment="Center" />
        </Grid>

        <Button Classes="softbtn" HorizontalAlignment="Center"
                Content="{l:Tr Main_LogLoadOlderButton}" Command="{Binding LoadOlderLogCommand}"
                IsVisible="{Binding LogCanPageOlder}" />

        <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                Background="{DynamicResource AgInsetBrush}" CornerRadius="10" MaxHeight="520">
          <Panel>
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <SelectableTextBlock Text="{Binding LogText}" IsVisible="{Binding HasLogs}"
                                   FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace"
                                   FontSize="11.5" LineHeight="18"
                                   Foreground="{DynamicResource AgMutedBrush}"
                                   TextWrapping="Wrap" Margin="16,13" />
            </ScrollViewer>
            <TextBlock IsVisible="{Binding !HasLogs}" Classes="muted" FontSize="12"
                       Text="{l:Tr Main_LogEmptyHint}"
                       Margin="16,13" VerticalAlignment="Top" />
          </Panel>
        </Border>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
