<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmneziaGeo.Ui.Controls"
             xmlns:vm="clr-namespace:AmneziaGeo.Ui.ViewModels"
             xmlns:views="clr-namespace:AmneziaGeo.Ui.Views"
             xmlns:svc="clr-namespace:AmneziaGeo.Ui.Services"
             xmlns:l="clr-namespace:AmneziaGeo.Ui.Localization"
             x:Class="AmneziaGeo.Ui.Views.RoutingView"
             x:CompileBindings="True"
             x:DataType="vm:RoutingViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgCopyGeometry">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
    <StreamGeometry x:Key="AgPasteGeometry">M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7Z</StreamGeometry>
    <StreamGeometry x:Key="AgDownloadGeometry">M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z</StreamGeometry>
    <StreamGeometry x:Key="AgFileGeometry">M13,9H18.5L13,3.5V9M6,2H14L20,8V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V4C4,2.89 4.89,2 6,2M15,18V16H6V18H15M18,14V12H6V14H18Z</StreamGeometry>
    <StreamGeometry x:Key="AgQrGeometry">M3,11H5V13H3V11M11,5H13V9H11V5M9,11H13V15H11V13H9V11M15,11H17V13H19V11H21V13H19V15H21V19H19V21H17V19H13V21H11V17H15V15H17V13H15V11M19,19V15H17V19H19M15,3H21V9H15V3M17,5V7H19V5H17M3,3H9V9H3V3M5,5V7H7V5H5M3,15H9V21H3V15M5,17V19H7V17H5Z</StreamGeometry>
    <StreamGeometry x:Key="AgPencilGeometry">M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z</StreamGeometry>
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Section menu: Settings / Import / Export. Settings and Export disable while no list exists. -->
    <Border Grid.Row="0" Background="{DynamicResource AgInsetBrush}"
            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="9" Padding="3" MaxWidth="420" HorizontalAlignment="Left">
      <UniformGrid Columns="3">
        <Button Classes="seg" Classes.active="{Binding SegSettingsActive}"
                Command="{Binding SelectRoutingSectionCommand}" CommandParameter="settings"
                IsEnabled="{Binding CanSettingsSection}"
                Content="{l:Tr Main_SettingsTab}" HorizontalAlignment="Stretch" Padding="8,6" />
        <Button Classes="seg" Classes.active="{Binding SegImportActive}"
                Command="{Binding SelectRoutingSectionCommand}" CommandParameter="import"
                Content="{l:Tr Main_ImportTab}" HorizontalAlignment="Stretch" Padding="8,6" />
        <Button Classes="seg" Classes.active="{Binding SegExportActive}"
                Command="{Binding SelectRoutingSectionCommand}" CommandParameter="export"
                IsEnabled="{Binding CanExportSection}"
                Content="{l:Tr Main_ExportTab}" HorizontalAlignment="Stretch" Padding="8,6" />
      </UniformGrid>
    </Border>

    <!-- Routing-list catalogue combo: «- не выбрано -» then saved lists. Hidden while importing. -->
    <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="6" IsVisible="{Binding !IsSectionImport}">
      <TextBlock Classes="label" Text="{l:Tr Main_ChooseListLabel}" />
      <controls:AdaptiveComboBox Classes="field" HorizontalAlignment="Stretch"
                ItemsSource="{Binding RoutingCatalogueOptions}"
                SelectedItem="{Binding SelectedCatalogueRouting, Mode=TwoWay}">
        <controls:AdaptiveComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:RoutingListChoice">
            <!-- «- не выбрано -» for the none sentinel. -->
            <Panel>
              <TextBlock Text="{l:Tr Main_NotSelected}" IsVisible="{Binding IsNone}" />
              <TextBlock Text="{Binding Name}" IsVisible="{Binding !IsNone}" />
            </Panel>
          </DataTemplate>
        </controls:AdaptiveComboBox.ItemTemplate>
      </controls:AdaptiveComboBox>
      <TextBlock IsVisible="{Binding !HasRoutingLists}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                 Text="{l:Tr Main_NoRoutingListsHint}" />
    </StackPanel>

    <!-- Content: one section shown at a time. -->
    <Panel Grid.Row="2" Margin="0,14,0,0">

      <!-- Section loader until an opened list's rules + traffic settings finish (#193). -->
      <StackPanel IsVisible="{Binding ShowSettingsLoader}" HorizontalAlignment="Center" Spacing="12" Margin="0,24">
        <ProgressBar IsIndeterminate="True" Width="150" HorizontalAlignment="Center" />
        <TextBlock Text="{l:Tr Main_RoutingLoading}" Classes="muted" FontSize="13" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Settings section: the shared editor + delete card. -->
      <StackPanel IsVisible="{Binding ShowSettingsEditor}" Spacing="14">
        <views:RoutingEditorView />

        <!-- Delete card: description left, delete trigger right. When armed, the trigger is replaced in place by
             the Confirm/Cancel pair sharing its footprint - one per column, each stretched (#4). -->
        <Border Background="Transparent" IsVisible="{Binding ShowDeleteCard}"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16">
          <StackPanel Spacing="10">
            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
              <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0"
                          Grid.ColumnSpan="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=span2}">
                <TextBlock Text="{l:Tr Main_DeleteListTitle}" FontWeight="SemiBold" FontSize="13.5" />
                <TextBlock Text="{l:Tr Main_DeleteListPrompt}" FontSize="12" TextWrapping="Wrap" />
                <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap" Text="{l:Tr Main_DeleteListHint}" />
              </StackPanel>
              <Grid VerticalAlignment="Center"
                    Grid.Row="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=row}"
                    Grid.Column="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=col}"
                    Width="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=w180}"
                    ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.ColumnSpan="2" Classes="danger" HorizontalAlignment="Stretch"
                        Content="{l:Tr Main_DeleteListButton}"
                        IsVisible="{Binding !RoutingDeletePending}"
                        Command="{Binding RequestDeleteSectionRoutingListCommand}" />
                <Button Grid.Column="0" Classes="danger" HorizontalAlignment="Stretch"
                        Content="{l:Tr Main_ConfirmDeleteButton}"
                        IsVisible="{Binding RoutingDeletePending}"
                        Command="{Binding ConfirmDeleteSectionRoutingListCommand}" />
                <Button Grid.Column="1" Classes="softbtn" HorizontalAlignment="Stretch"
                        Content="{l:Tr Main_CancelButton}"
                        IsVisible="{Binding RoutingDeletePending}"
                        Command="{Binding CancelDeleteRoutingCommand}" />
              </Grid>
            </Grid>
            <TextBlock Text="{Binding RoutingDeleteStatus}" Classes="fieldwarn" FontSize="12" TextWrapping="Wrap"
                       IsVisible="{Binding RoutingDeleteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- Export section: QR / raw payload of the list, with copy / save. -->
      <Border IsVisible="{Binding IsSectionExport}"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <StackPanel Spacing="12" DataContext="{Binding RoutingEditor}" x:DataType="vm:RoutingListEditorViewModel">
          <StackPanel Spacing="2">
            <TextBlock Text="{l:Tr Main_ExportListTitle}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
            <TextBlock Text="{l:Tr Main_TransferSubtitle}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>

          <!-- Segmented [QR | Конфиг]. -->
          <Border Background="{DynamicResource AgInsetBrush}"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                  CornerRadius="9" Padding="3" MaxWidth="420" HorizontalAlignment="Center">
            <UniformGrid Columns="2">
              <Button Classes="seg" Classes.active="{Binding IsTransferQr}" Command="{Binding ShowTransferQrCommand}"
                      Content="{l:Tr Main_TransferQrTab}" HorizontalAlignment="Stretch" Padding="20,6" />
              <Button Classes="seg" Classes.active="{Binding IsTransferText}" Command="{Binding ShowTransferTextCommand}"
                      Content="{l:Tr Main_TransferTextTab}" HorizontalAlignment="Stretch" Padding="20,6" />
            </UniformGrid>
          </Border>

          <!-- QR tab: fixed 240x240 stage so the image (or notice) appearing never reflows the card. -->
          <Panel Height="240" IsVisible="{Binding IsTransferQr}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="8" Padding="10"
                    IsVisible="{Binding RoutingQrImage, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Image Source="{Binding RoutingQrImage}" Width="220" Height="220" />
            </Border>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource AgInsetBrush}"
                    BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Width="240" IsVisible="{Binding QrUnavailable}">
              <TextBlock Text="{l:Tr Main_QrUnavailableHint}" Classes="muted" FontSize="12"
                         TextAlignment="Center" TextWrapping="Wrap" />
            </Border>
          </Panel>

          <!-- Config tab: the raw transfer payload, read-only and selectable. -->
          <TextBox Classes="field" Text="{Binding TransferText}" IsReadOnly="True" AcceptsReturn="True"
                   TextWrapping="NoWrap" IsVisible="{Binding IsTransferText}"
                   VerticalContentAlignment="Top" Height="200"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12" />

          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     HorizontalAlignment="Center" TextAlignment="Center"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <!-- Export actions: copy (QR) / save (text). -->
          <WrapPanel HorizontalAlignment="Center">
            <Button Classes="methodpick" Margin="4" Padding="14,6" Click="OnRoutingExportCopy"
                    IsVisible="{Binding IsTransferQr}"
                    ToolTip.Tip="{l:Tr Main_RoutingCopyTooltip}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgCopyGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_CopyButton}" />
              </StackPanel>
            </Button>
            <Button Classes="accent" Margin="4" Padding="14,6" Click="OnRoutingExportSave"
                    IsVisible="{Binding IsTransferText}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgDownloadGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_SaveToFileButton}" />
              </StackPanel>
            </Button>
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- Import section - method picker: blank / file / paste / QR. -->
      <Border IsVisible="{Binding ShowImportPicker}"
              Background="{DynamicResource AgPanelBrush}"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1" CornerRadius="9" MinHeight="220">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4" Margin="16">
          <TextBlock Text="{l:Tr Main_AddListTitle}" FontSize="16" FontWeight="SemiBold"
                     HorizontalAlignment="Center" />
          <TextBlock Text="{l:Tr Main_AddConfigSubtitle}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12" />
          <WrapPanel HorizontalAlignment="Center">
            <Button Classes="methodpick" Margin="4" Command="{Binding BeginManualImportCommand}" Width="160">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgPencilGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_BlankListButton}" />
              </StackPanel>
            </Button>
            <Button Classes="methodpick" Margin="4" Click="OnRoutingImportFile" Width="160">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgFileGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_FileButton}" />
              </StackPanel>
            </Button>
            <Button Classes="methodpick" Margin="4" Click="OnRoutingImportPaste" Width="160">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgPasteGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_PasteButton}" />
              </StackPanel>
            </Button>
            <Button Classes="methodpick" Margin="4" Command="{Binding BeginCameraImportCommand}" Width="160">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgQrGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_CameraButton}" />
              </StackPanel>
            </Button>
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- Import section - draft editor (blank or prefilled from file / paste / QR). -->
      <StackPanel IsVisible="{Binding ShowImportEditor}" Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Classes="label" Text="{l:Tr Main_NewListLabel}" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="methodpick" Command="{Binding ChangeMethodCommand}" Width="160">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{l:Tr Main_ChangeMethodButton}" />
            </StackPanel>
          </Button>
        </Grid>
        <views:RoutingEditorView />
      </StackPanel>

      <!-- Import section - live QR scanner. -->
      <Panel IsVisible="{Binding ShowImportCamera}" MinHeight="220">
        <views:ScanView DataContext="{Binding SectionScan}" />
      </Panel>

    </Panel>
  </Grid>
</UserControl>
