<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
        x:Class="AmneziaGeo.Windows.Ui.QrDialog"
        Title="{l:Tr Qr_WindowTitle}"
        Width="460" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <DockPanel Margin="16">

    <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold" FontSize="16" />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,12,0,0">
      <Button Content="{l:Tr Qr_CopyButton}" Click="OnCopy" />
      <Button Content="{l:Tr Qr_SaveButton}" Click="OnSave" />
      <Button Content="{l:Tr Qr_CloseButton}" Click="OnClose" IsDefault="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
               Foreground="{DynamicResource AgMutedBrush}" FontSize="12"
               TextWrapping="Wrap" Margin="0,10,0,0" />

    <StackPanel Spacing="10" Margin="0,14,0,0">
      <Border HorizontalAlignment="Center" Background="White" CornerRadius="8" Padding="10"
              IsVisible="{Binding HasQr}">
        <Image Source="{Binding QrImage}" Width="240" Height="240" />
      </Border>
      <Border HorizontalAlignment="Center" Background="{DynamicResource AgInsetBrush}"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="8" Padding="16" Width="260" IsVisible="{Binding QrUnavailable}">
        <TextBlock Text="{l:Tr Qr_TooLargeHint}"
                   TextWrapping="Wrap" TextAlignment="Center"
                   Foreground="{DynamicResource AgMutedBrush}" FontSize="12" />
      </Border>
      <TextBox Text="{Binding Payload}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
               Height="150" FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="11" />
    </StackPanel>

  </DockPanel>
</Window>
