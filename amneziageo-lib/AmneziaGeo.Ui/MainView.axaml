<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AmneziaGeo.Ui.Controls"
        xmlns:svc="clr-namespace:AmneziaGeo.Ui.Services"
        xmlns:vm="clr-namespace:AmneziaGeo.Ui.ViewModels"
        xmlns:views="clr-namespace:AmneziaGeo.Ui.Views"
        xmlns:l="clr-namespace:AmneziaGeo.Ui.Localization"
        x:Class="AmneziaGeo.Ui.MainView"
        x:CompileBindings="True"
        x:DataType="vm:MainWindowViewModel"
        Design.DataContext="{x:Static vm:DesignData.MainWindow}"
        Design.Width="987" Design.Height="610"
        Background="{DynamicResource AgBgBrush}"
        FontFamily="IBM Plex Sans, Segoe UI, sans-serif"
        Foreground="{DynamicResource AgFgBrush}">

  <UserControl.Resources>
    <!-- Refresh glyph. -->
    <StreamGeometry x:Key="AgRefreshGeometry">M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z</StreamGeometry>
    <!-- Power glyph. -->
    <StreamGeometry x:Key="AgPowerGeometry">M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z</StreamGeometry>
    <!-- Gear glyph. -->
    <StreamGeometry x:Key="AgGearGeometry">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</StreamGeometry>
    <!-- Back glyph. -->
    <StreamGeometry x:Key="AgBackGeometry">M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z</StreamGeometry>
  </UserControl.Resources>

  <Grid>

    <!-- HOME screen: gear pinned left, centered title, big round connect control, status, profile picker. -->
    <Border Classes="card" Margin="12" Padding="0" IsVisible="{Binding IsHome}">
      <DockPanel LastChildFill="True">

        <!-- Top row: gear pinned left, title centered. -->
        <Border DockPanel.Dock="Top" Height="48" Padding="12,0">
          <Grid>
            <TextBlock Text="AmneziaGeo" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AgMutedBrush}" />
            <Button Classes="icon" Padding="6,4" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Command="{Binding NavSettingsCommand}" ToolTip.Tip="{l:Tr Main_SettingsTooltip}">
              <PathIcon Data="{DynamicResource AgGearGeometry}" Width="18" Height="18"
                        Foreground="{DynamicResource AgMutedBrush}" />
            </Button>
          </Grid>
        </Border>

        <!-- Power button + status/hint + profile combo, seated on the golden section (upper) rather than dead
             centre. A loader replaces it until the first agent snapshot, so the indeterminate power button
             never flashes on open. -->
        <ScrollViewer x:Name="HomeScroll" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
        <Panel MinHeight="{Binding #HomeScroll.Bounds.Height}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="18"
                    Orientation="{Binding IsHorizontalHome, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=homeOrientation}"
                    Margin="{Binding #HomeScroll.Bounds.Height, Converter={x:Static svc:GoldenTopConverter.Instance}, ConverterParameter=118}"
                    IsVisible="{Binding Home.IsReady}">
          <Button Classes="powerbig" HorizontalAlignment="Center"
                  Command="{Binding Home.ToggleConnectionCommand}"
                  IsEnabled="{Binding Home.CanToggleConnection}"
                  ToolTip.Tip="{Binding Home.ConnectHint}">
            <Grid Width="236" Height="236">
              <Ellipse Width="236" Height="236" Stroke="{DynamicResource AgBorderBrush}"
                       StrokeThickness="1" Opacity="0.7" />
              <Ellipse Width="196" Height="196" Stroke="{DynamicResource AgBorderBrush}"
                       StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Width="158" Height="158" Stroke="{DynamicResource AgBorder2Brush}"
                       StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <!-- Accent ring-wave overlays during connect / disconnect. -->
              <Ellipse Classes="ring r1" Classes.waveout="{Binding Home.IsConnectingOut}"
                       Classes.wavein="{Binding Home.IsConnectingIn}"
                       Width="158" Height="158" Stroke="{Binding Home.ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Classes="ring r2" Classes.waveout="{Binding Home.IsConnectingOut}"
                       Classes.wavein="{Binding Home.IsConnectingIn}"
                       Width="196" Height="196" Stroke="{Binding Home.ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Classes="ring r3" Classes.waveout="{Binding Home.IsConnectingOut}"
                       Classes.wavein="{Binding Home.IsConnectingIn}"
                       Width="236" Height="236" Stroke="{Binding Home.ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Border Width="132" Height="132" CornerRadius="66"
                      Background="{Binding Home.ConnectCircleBrush}"
                      BorderBrush="{Binding Home.ConnectCircleBorderBrush}" BorderThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      BoxShadow="0 8 24 0 #1F000000">
                <Panel>
                  <PathIcon Data="{DynamicResource AgPowerGeometry}" Width="54" Height="54"
                            Foreground="{Binding Home.ConnectCircleForeground}"
                            IsVisible="{Binding !Home.IsConnecting}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Ellipse Classes.pulse="{Binding Home.IsConnecting}" Width="44" Height="44"
                           IsVisible="{Binding Home.IsConnecting}" Fill="{Binding Home.ConnectCircleForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Panel>
              </Border>
            </Grid>
          </Button>

          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4" Margin="0,4,0,0">
            <TextBlock Text="{Binding Home.AgentStatusText}" FontSize="17" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{Binding Home.ConnectStatusBrush}" />
            <TextBlock Text="{Binding Home.ConnectHint}" FontSize="12.5"
                       HorizontalAlignment="Center" Foreground="{Binding Home.ConnectHintBrush}" />
            <!-- Retry counter while a stalled connect keeps trying (#197). -->
            <TextBlock Text="{Binding Home.RetryText}" FontSize="12" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{Binding Home.ConnectStatusBrush}"
                       IsVisible="{Binding Home.ShowRetry}" />
          </StackPanel>

          <!-- Profile picker: «- не выбрано -» then saved profiles. -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" Width="300" Margin="0,6,0,0">
            <controls:AdaptiveComboBox Classes="field" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Profile.ProfileOptions}"
                      SelectedItem="{Binding Home.ActiveProfileChoice, Mode=TwoWay}">
              <controls:AdaptiveComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ProfileChoice">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </controls:AdaptiveComboBox.ItemTemplate>
            </controls:AdaptiveComboBox>
            <!-- No profiles: hint to add one in settings. -->
            <TextBlock IsVisible="{Binding !HasProfiles}" Classes="muted" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       Text="{l:Tr Main_NoProfilesHint}" />
            <!-- Profiles exist but none usable: hint to pick one. -->
            <TextBlock IsVisible="{Binding Home.ShowSelectConfigHint}" Classes="muted" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       Text="{l:Tr Main_HomeSelectConfigHint}" />
          </StackPanel>
        </StackPanel>

          <!-- Loader until the first snapshot: seated just below the golden line, toward centre; the ready-state content keeps its seat. -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Spacing="16"
                      Margin="{Binding #HomeScroll.Bounds.Height, Converter={x:Static svc:GoldenTopConverter.Instance}, ConverterParameter=-10}"
                      IsVisible="{Binding !Home.IsReady}">
            <ProgressBar IsIndeterminate="True" Width="150" HorizontalAlignment="Center" />
            <TextBlock Text="{l:Tr Main_RoutingLoading}" Classes="muted" FontSize="13"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Panel>
        </ScrollViewer>

      </DockPanel>
    </Border>

    <!-- SETTINGS screen: back to home (left), title centered, connect control (right), over the section rail
         and content pane. -->
      <Border Classes="card" CornerRadius="0" Height="48" Margin="12,12,12,0" Padding="12,0"
              VerticalAlignment="Top" IsVisible="{Binding IsSettings}">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <!-- Back: compact section detail steps back to the rail, otherwise home. Every screen autosaves, so
               navigation is never locked; deletion is confirmed inline. -->
          <Button Grid.Column="0" Classes="backbtn" VerticalAlignment="Center"
                  Command="{Binding NavBackCommand}"
                  ToolTip.Tip="{l:Tr Main_BackToProfilesTooltip}">
            <PathIcon Data="{DynamicResource AgBackGeometry}" Width="18" Height="18"
                      Foreground="{DynamicResource AgMutedBrush}" />
          </Button>

          <!-- Title centered between the back arrow and the connect control: the app name, or the current section
               name when a compact section detail is open. -->
          <Panel Grid.Column="1" Margin="8,0">
            <TextBlock Text="AmneziaGeo" FontSize="15" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource AgMutedBrush}"
                       IsVisible="{Binding !IsSectionDetail}" />
            <Panel IsVisible="{Binding IsSectionDetail}">
              <TextBlock Text="{l:Tr Main_ProfileSection}" IsVisible="{Binding IsSettingsProfile}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
              <TextBlock Text="{l:Tr Main_ConfigSection}" IsVisible="{Binding IsSettingsConfig}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
              <TextBlock Text="{l:Tr Main_RoutingSection}" IsVisible="{Binding IsSettingsRouting}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
              <TextBlock Text="{l:Tr Main_SourcesSection}" IsVisible="{Binding IsSettingsSources}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
              <TextBlock Text="{l:Tr Main_AgentLogSection}" IsVisible="{Binding IsSettingsLogs}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
              <TextBlock Text="{l:Tr General_Section}" IsVisible="{Binding IsSettingsGeneral}"
                         FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" Foreground="{DynamicResource AgMutedBrush}" />
            </Panel>
          </Panel>

          <!-- Connect control (right): retry counter (#197) then the animated connect / disconnect pill; the
               inner circle + text carry the state colour (gray off, orange while switching, blue connected). -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="{Binding Home.RetryText}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{Binding Home.ConnectStatusBrush}" VerticalAlignment="Center"
                       IsVisible="{Binding Home.ShowRetry}" />
            <Button Classes="powerctl" VerticalAlignment="Center"
                    Width="130" HorizontalContentAlignment="Left"
                    Command="{Binding Home.ToggleConnectionCommand}"
                    IsEnabled="{Binding Home.CanToggleConnection}"
                    ToolTip.Tip="{Binding Home.ConnectHint}">
              <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                <Panel Width="28" Height="28">
                  <Ellipse Classes="connspin" Classes.spinning="{Binding Home.IsConnecting}"
                           Width="26" Height="26" Stroke="{Binding Home.ConnectCircleForeground}"
                           StrokeThickness="2" StrokeDashArray="12,29" StrokeLineCap="Round"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Border Width="22" Height="22" CornerRadius="11"
                          Background="{Binding Home.ConnectCircleBrush}"
                          BorderBrush="{Binding Home.ConnectCircleBorderBrush}" BorderThickness="1"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                    <PathIcon Data="{DynamicResource AgPowerGeometry}" Width="11" Height="11"
                              Foreground="{Binding Home.ConnectCircleForeground}"
                              IsVisible="{Binding !Home.IsConnecting}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </Panel>
                <TextBlock Text="{Binding Home.AgentStatusText}" FontSize="12" FontWeight="SemiBold"
                           Foreground="{Binding Home.ConnectStatusBrush}" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

    <Grid x:Name="SettingsBody" IsVisible="{Binding IsSettings}" Margin="12,0,12,12" RowDefinitions="48,*">
      <Grid.ColumnDefinitions>
        <!-- Section rail column, drag-resizable via the GridSplitter.
             MaxWidth capped so that even at the rail's widest the content pane keeps its MinWidth at the
             window's MinWidth: railMax(320) + splitter(5) + contentMin(440) + hMargins(24) = 789 <= Window.MinWidth(800).
             With the old 360 cap a wide rail + small window pushed the content below its min (hscroll is
             Disabled), so its widest fixed control (the 320px segmented toggle) spilled left/down out of the pane. -->
        <ColumnDefinition Width="260" MinWidth="210" MaxWidth="320" />
        <ColumnDefinition Width="Auto" />
        <!-- Content floored: the splitter can never starve it below its min, so the
             disabled-hscroll pane fits/wraps instead of clipping right-side controls. -->
        <ColumnDefinition Width="*" MinWidth="440" />
      </Grid.ColumnDefinitions>

      <!-- Section rail. -->
      <Border Grid.Column="0" Grid.Row="1" Classes="card" CornerRadius="0" Margin="0,12,0,0" Padding="0"
              IsVisible="{Binding ShowRail}">
        <ScrollViewer>
          <StackPanel Classes="railmenu" Classes.compact="{Binding IsCompact}" Margin="12,12">
              <Button Classes="rowselect" Classes.active="{Binding IsSettingsProfile}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="profile">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsProfile}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailProfileTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailProfileSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsConfig}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="config">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsConfig}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailConfigTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailConfigSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsRouting}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="routing">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsRouting}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailRoutingTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailRoutingSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsSources}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="sources">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsSources}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailSourcesTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailSourcesSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsLogs}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="logs">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsLogs}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailLogsTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailLogsSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsGeneral}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="general">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Classes="railradio" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsGeneral}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Classes="railtext" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailGeneralTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailGeneralSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
      </Border>

      <!-- Draggable divider between rail and content (wide mode only). -->
      <GridSplitter Grid.Column="1" Grid.Row="1" Width="5" IsVisible="{Binding ShowSplitter}"
                    ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="Transparent" Margin="0,12,0,0" />

      <!-- Content pane. -->
      <Border Grid.Column="2" Grid.Row="1" Classes="card" CornerRadius="0" Margin="0,12,0,0" Padding="0"
              IsVisible="{Binding ShowContent}">
        <DockPanel LastChildFill="True">
          <!-- Static footer for config: import-draft or open-config edits. Save / Cancel + unsaved indicator. -->
          <Border DockPanel.Dock="Bottom" IsVisible="{Binding Config.ShowSaveBar}"
                  Background="{DynamicResource AgPanelBrush}" BorderBrush="{DynamicResource AgBorderBrush}"
                  BorderThickness="0,1,0,0" Height="52" Padding="18,0">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource AgWarnBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{l:Tr Main_UnsavedChanges}" Classes="muted" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Classes="methodpick" Content="{l:Tr Main_CancelButton}"
                        Width="120"
                        Command="{Binding Config.CancelSectionCommand}" />
                <Button Classes="accent" Content="{l:Tr Main_SaveButton}"
                        Width="120" Padding="6"
                        Command="{Binding Config.SaveSectionCommand}"
                        IsVisible="{Binding Config.ShowSaveButton}"
                        IsEnabled="{Binding Config.CanSave}" />
              </StackPanel>
            </Grid>
          </Border>
          <!-- Static footer for routing: import-draft or open-list edits. Save / Cancel + unsaved indicator. -->
          <Border DockPanel.Dock="Bottom" IsVisible="{Binding Routing.ShowSaveBar}"
                  Background="{DynamicResource AgPanelBrush}" BorderBrush="{DynamicResource AgBorderBrush}"
                  BorderThickness="0,1,0,0" Height="52" Padding="18,0">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource AgWarnBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{l:Tr Main_UnsavedChanges}" Classes="muted" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Classes="methodpick" Content="{l:Tr Main_CancelButton}"
                        Width="120"
                        Command="{Binding Routing.CancelSectionCommand}" />
                <Button Classes="accent" Content="{l:Tr Main_SaveButton}"
                        Width="120" Padding="6"
                        Command="{Binding Routing.SaveSectionCommand}"
                        IsVisible="{Binding Routing.ShowSaveButton}"
                        IsEnabled="{Binding Routing.CanSave}" />
              </StackPanel>
            </Grid>
          </Border>
          <!-- Static footer for profile: open-profile edits. Save / Cancel + unsaved indicator. -->
          <Border DockPanel.Dock="Bottom" IsVisible="{Binding Profile.ShowSaveBar}"
                  Background="{DynamicResource AgPanelBrush}" BorderBrush="{DynamicResource AgBorderBrush}"
                  BorderThickness="0,1,0,0" Height="52" Padding="18,0">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource AgWarnBrush}" VerticalAlignment="Center" />
                <TextBlock Text="{l:Tr Main_UnsavedChanges}" Classes="muted" FontSize="12" VerticalAlignment="Center" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Classes="methodpick" Content="{l:Tr Main_CancelButton}"
                        Width="120"
                        Command="{Binding Profile.CancelSectionCommand}" />
                <Button Classes="accent" Content="{l:Tr Main_SaveButton}"
                        Width="120" Padding="6"
                        Command="{Binding Profile.SaveSectionCommand}"
                        IsVisible="{Binding Profile.ShowSaveButton}"
                        IsEnabled="{Binding Profile.CanSave}" />
              </StackPanel>
            </Grid>
          </Border>
        <!-- ALL insets live on the inner Grid's Margin, none on the ScrollViewer. A ScrollViewer Padding is
             applied asymmetrically between the measure and arrange passes, so the padded side is pushed past
             the presenter's clip: horizontally it shoved stretched fields off the edge; vertically the
             bottom 16px of a scrolled-to-max section (e.g. the config «Удалить» button) landed below the
             viewport's clip and was unreachable even at max scroll. A Grid Margin is applied identically in
             both passes, so the top+bottom inset survives and the last control always scrolls fully into view. -->
        <!-- Never scroll sideways: long values (source URLs) trim/wrap instead of overflowing the card. -->
        <ScrollViewer x:Name="ContentScroll" HorizontalScrollBarVisibility="Disabled">
          <Grid Margin="18,16">

            <!-- PROFILE SECTION -->
            <Panel IsVisible="{Binding IsSettingsProfile}">
              <views:ProfileView DataContext="{Binding Profile}" />
            </Panel>

            <!-- CONFIG SECTION: cap height to the viewport minus the Grid's 32px inset. -->
            <Panel IsVisible="{Binding IsSettingsConfig}">
              <views:ConfigView DataContext="{Binding Config}"
                                MinHeight="{Binding #ContentScroll.Viewport.Height, Converter={x:Static svc:SubtractConverter.Instance}, ConverterParameter=32}" />
            </Panel>

            <!-- ROUTING SECTION -->
            <Panel IsVisible="{Binding IsSettingsRouting}">
              <views:RoutingView DataContext="{Binding Routing}" />
            </Panel>

            <!-- SOURCES SECTION -->
            <Panel IsVisible="{Binding IsSettingsSources}">
              <views:SourcesView DataContext="{Binding Sources}" />
            </Panel>

            <!-- LOGS SECTION: fixed to the viewport (minus the Grid's 32px inset) so only the log body scrolls. -->
            <Panel IsVisible="{Binding IsSettingsLogs}">
              <views:LogsView DataContext="{Binding Logs}"
                              Height="{Binding #ContentScroll.Viewport.Height, Converter={x:Static svc:SubtractConverter.Instance}, ConverterParameter=32}" />
            </Panel>

            <!-- GENERAL SECTION -->
            <Panel IsVisible="{Binding IsSettingsGeneral}">
              <views:GeneralView DataContext="{Binding General}" />
            </Panel>

          </Grid>
        </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Floating notification toasts (reconnect notice, app update, geo update); shown over home and settings. -->
    <StackPanel ZIndex="50" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="12,24,12,0" MaxWidth="560" Spacing="6">

      <Border IsVisible="{Binding Home.NoticeVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding Home.NoticeText}" Foreground="White"
                     FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="radiopick" Command="{Binding Home.ReconnectCommand}"
                  Content="{Binding Home.NoticeActionText}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                  Margin="10,0,0,0" VerticalAlignment="Center" IsVisible="{Binding Home.ReconnectAvailable}" />
          <Button Grid.Column="3" Classes="radiopick" Command="{Binding Home.DismissNoticeCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="9,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_CloseTooltip}"
                  IsVisible="{Binding Home.CanDismissNotice}" />
        </Grid>
      </Border>

      <Border IsVisible="{Binding AppUpdateBannerVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding General.UpdateBannerText}"
                     Foreground="White" FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                      Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding General.UpdateDownloadPercent, StringFormat='{}{0}%'}" Foreground="White"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                       Width="36" TextAlignment="Right"
                       IsVisible="{Binding General.DownloadActive}" />
            <Button Classes="radiopick" Command="{Binding General.DownloadUpdateCommand}"
                    Content="{l:Tr Main_DownloadButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                    VerticalAlignment="Center" IsVisible="{Binding General.ShowDownloadButton}" />
            <Button Classes="radiopick" Command="{Binding General.CancelDownloadCommand}"
                    Content="{l:Tr Main_CancelButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                    VerticalAlignment="Center" IsVisible="{Binding General.DownloadActive}" />
            <Button Classes="radiopick" Command="{Binding General.ApplyUpdateCommand}"
                    Content="{l:Tr Main_InstallButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                    VerticalAlignment="Center" IsVisible="{Binding General.UpdateDownloaded}" />
          </StackPanel>
          <Button Grid.Column="3" Classes="radiopick" Command="{Binding General.DismissUpdateBannerCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="6,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_CloseTooltip}" />
        </Grid>
      </Border>

      <Border IsVisible="{Binding Sources.GeoUpdateBannerVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding Sources.GeoUpdateBannerText}"
                     Foreground="White" FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                      Margin="10,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding Sources.GeoUpdatePercent, StringFormat='{}{0}%'}" Foreground="White"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                       Width="36" TextAlignment="Right"
                       IsVisible="{Binding Sources.GeoDownloadActive}" />
            <Button Classes="radiopick" Command="{Binding Sources.UpdateGeoNowCommand}"
                    Content="{l:Tr Main_UpdateNowButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                    VerticalAlignment="Center" IsVisible="{Binding Sources.ShowGeoUpdateButton}" />
          </StackPanel>
          <Button Grid.Column="3" Classes="radiopick" Command="{Binding Sources.DismissGeoUpdateBannerCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="6,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_GeoDismissTooltip}" />
        </Grid>
      </Border>

    </StackPanel>

  </Grid>
</UserControl>
