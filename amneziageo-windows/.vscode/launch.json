{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (Launcher: backend + UI)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/tools/AmneziaGeo.Windows.Launcher/bin/Debug/net10.0/AmneziaGeo.Windows.Launcher.dll",
      "cwd": "${workspaceFolder}/tools/AmneziaGeo.Windows.Launcher/bin/Debug/net10.0",
      "console": "internalConsole",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Attach to process",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
