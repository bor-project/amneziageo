<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
        xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
        x:Class="AmneziaGeo.Windows.Ui.LauncherWindow"
        x:CompileBindings="True"
        x:DataType="vm:MainWindowViewModel"
        Title="AmneziaGeo"
        Width="440" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AgPanelBrush}"
        FontFamily="IBM Plex Sans, Segoe UI, sans-serif"
        Foreground="{DynamicResource AgFgBrush}">

  <Window.Resources>
    <!-- Power glyph. -->
    <StreamGeometry x:Key="LauncherPowerGeometry">M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z</StreamGeometry>
    <!-- Open-in-window glyph. -->
    <StreamGeometry x:Key="LauncherOpenGeometry">M19 19H5V5h7V3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2v-7h-2v7zM14 3v2h3.59l-9.83 9.83 1.41 1.41L19 6.41V10h2V3h-7z</StreamGeometry>
  </Window.Resources>

  <Window.Styles>
    <!-- Outlined accent action: panel fill, accent border + text. -->
    <Style Selector="Button.outline">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Panel Margin="24,18,24,20">

  <!-- Normal launcher: quick connect, open settings, update check/offer, tray hint. Hidden while a download
       takes over the window (#4). -->
  <StackPanel Spacing="0" IsVisible="{Binding !General.IsUpdateBusy}">
    <!-- Profiles arrive with the first agent snapshot; show a loader until then so the empty combo + disabled
         connect never read as "no profile". Height is reserved so the window does not jump on ready. -->
    <Panel MinHeight="130">
      <StackPanel Spacing="0" IsVisible="{Binding Home.IsReady}">
        <Grid Margin="0,0,0,7" ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Classes="muted" FontSize="13" VerticalAlignment="Center"
                     Text="{l:Tr Launcher_ActiveProfile}" />
          <TextBlock Grid.Column="1" Classes="muted" FontSize="13" VerticalAlignment="Center"
                     Text="{Binding Home.AgentStatusText}" />
        </Grid>

        <ComboBox Classes="field" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding Profile.ProfileOptions}"
                  SelectedItem="{Binding Home.ActiveProfileChoice, Mode=TwoWay}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ProfileChoice">
              <TextBlock Text="{Binding Name}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <Button Classes="accent" Classes.transitioning="{Binding Home.IsConnecting}"
                Margin="0,18,0,0" Height="48" HorizontalAlignment="Stretch"
                Click="OnConnect" IsEnabled="{Binding Home.CanToggleConnection}">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <Panel Width="18" Height="18" VerticalAlignment="Center">
              <PathIcon Data="{StaticResource LauncherPowerGeometry}" Width="17" Height="17"
                        IsVisible="{Binding !Home.IsConnecting}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
              <!-- Spinner arc while the tunnel is coming up or down. -->
              <Ellipse Classes="connspin" Classes.spinning="{Binding Home.IsConnecting}"
                       Width="17" Height="17" Stroke="White" StrokeThickness="2"
                       StrokeDashArray="12,29" StrokeLineCap="Round"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Panel>
            <TextBlock Text="{Binding Home.LauncherActionText}" FontSize="14" FontWeight="SemiBold"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Retry progress during a reconnect storm, mirroring the console (#197). -->
        <TextBlock Text="{Binding Home.RetryText}" IsVisible="{Binding Home.ShowRetry}"
                   Classes="muted" FontSize="12" FontWeight="SemiBold" Margin="0,8,0,0"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <StackPanel IsVisible="{Binding !Home.IsReady}" Spacing="12"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
        <ProgressBar IsIndeterminate="True" Width="150" HorizontalAlignment="Center" />
        <TextBlock Text="{l:Tr Launcher_Loading}" Classes="muted" FontSize="13" HorizontalAlignment="Center" />
      </StackPanel>
    </Panel>

    <Button Classes="outline" Margin="0,10,0,0" Height="48" HorizontalAlignment="Stretch"
            Click="OnOpenApp">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <PathIcon Data="{StaticResource LauncherOpenGeometry}" Width="16" Height="16" />
        <TextBlock Text="{l:Tr Launcher_OpenApp}" FontSize="14" FontWeight="SemiBold"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Button>

    <!-- App self-update: check and the download -> install flow, mirroring the console (#2), bound to General.*. -->
    <Border IsVisible="{Binding General.HasUpdateUrl}" Margin="0,12,0,0" Padding="12"
            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1" CornerRadius="10">
      <StackPanel Spacing="8">
        <TextBlock Text="{Binding General.UpdateVersionBadgeText}" FontSize="13" FontWeight="SemiBold"
                   TextWrapping="Wrap" IsVisible="{Binding General.UpdateAvailable}" />
        <TextBlock Text="{Binding General.UpdateStatus}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                   IsVisible="{Binding General.UpdateStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <Button Grid.Column="0" Classes="softbtn" HorizontalAlignment="Left"
                  Content="{l:Tr Main_CheckUpdatesButton}" Command="{Binding General.CheckUpdateCommand}"
                  IsVisible="{Binding General.ShowCheckUpdateButton}" />
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                      IsVisible="{Binding General.UpdateAvailable}">
            <Button Classes="accent" Content="{l:Tr Main_DownloadButton}" Command="{Binding General.DownloadUpdateCommand}"
                    IsVisible="{Binding General.ShowDownloadButton}" />
            <Button Classes="accent" Content="{l:Tr Main_InstallButton}" Command="{Binding General.ApplyUpdateCommand}"
                    IsVisible="{Binding General.UpdateDownloaded}" />
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <TextBlock Classes="muted" Margin="0,16,0,0" HorizontalAlignment="Center" FontSize="12.5"
               TextAlignment="Center" Text="{l:Tr Launcher_TrayHint}" />

    <Button Classes="backbtn" Margin="0,10,0,0" HorizontalAlignment="Center" Click="OnCancel">
      <TextBlock Text="{l:Tr Launcher_Cancel}" FontSize="13" FontWeight="SemiBold" />
    </Button>
  </StackPanel>

  <!-- Download takeover (#4): compact progress + cancel while downloading; retry/close after a failure. The
       window's SizeToContent shrinks it to this block so no empty space is left. -->
  <StackPanel Spacing="16" IsVisible="{Binding General.IsUpdateBusy}">
    <StackPanel Spacing="12" IsVisible="{Binding General.UpdateDownloading}">
      <TextBlock Text="{Binding General.UpdateStatus}" FontSize="14" FontWeight="SemiBold"
                 HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
        <ProgressBar Grid.Column="0" Minimum="0" Maximum="100"
                     Value="{Binding General.UpdateDownloadPercent}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="{Binding General.UpdateDownloadPercent, StringFormat='{}{0}%'}"
                   Classes="muted" FontSize="12" VerticalAlignment="Center" />
        <Button Grid.Column="2" Classes="softbtn" Content="{l:Tr Main_CancelButton}"
                Command="{Binding General.CancelDownloadCommand}" VerticalAlignment="Center" />
      </Grid>
    </StackPanel>

    <StackPanel Spacing="14" IsVisible="{Binding General.DownloadFailed}">
      <TextBlock Text="{Binding General.UpdateStatus}" FontSize="13.5" TextWrapping="Wrap"
                 HorizontalAlignment="Center" TextAlignment="Center" />
      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
        <Button Classes="accent" Content="{l:Tr Update_Retry}" Command="{Binding General.DownloadUpdateCommand}" />
        <Button Classes="softbtn" Content="{l:Tr Update_Close}" Command="{Binding General.DismissDownloadErrorCommand}" />
      </StackPanel>
    </StackPanel>
  </StackPanel>

  </Panel>
</Window>
