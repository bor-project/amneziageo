<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmneziaGeo.Ui.Controls"
             xmlns:vm="clr-namespace:AmneziaGeo.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Ui.Localization"
             x:Class="AmneziaGeo.Ui.Views.BundleImportView"
             x:CompileBindings="True"
             x:DataType="vm:BundleImportViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgUploadGeometry">M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z</StreamGeometry>
    <StreamGeometry x:Key="AgCheckGeometry">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</StreamGeometry>
  </UserControl.Resources>
  <StackPanel Spacing="12">
    <TextBlock Text="{l:Tr BundleImport_Heading}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
    <TextBlock Text="{l:Tr BundleImport_SecurityWarning}" Foreground="{DynamicResource AgWarnBrush}"
               FontSize="12" TextWrapping="Wrap" />

    <!-- Global name-conflict policy applied to every clashing config / routing list / profile. -->
    <StackPanel Spacing="4">
      <TextBlock Classes="label" Text="{l:Tr BundleImport_ConflictLabel}" />
      <controls:AdaptiveComboBox Classes="field" HorizontalAlignment="Stretch" SelectedIndex="{Binding ConflictPolicyIndex, Mode=TwoWay}">
        <ComboBoxItem Content="{l:Tr BundleImport_ConflictAddNew}" />
        <ComboBoxItem Content="{l:Tr BundleImport_ConflictReplace}" />
        <ComboBoxItem Content="{l:Tr BundleImport_ConflictSkip}" />
        <ComboBoxItem Content="{l:Tr BundleImport_ConflictMerge}" />
      </controls:AdaptiveComboBox>
    </StackPanel>

    <Border BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
            CornerRadius="8" Background="{DynamicResource AgPanelBrush}"
            controls:FileDropBehavior.Command="{Binding LoadDroppedFileCommand}">
      <TextBox Text="{Binding Payload, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True"
               TextWrapping="NoWrap" VerticalContentAlignment="Top" Height="280"
               ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
               BorderThickness="0" Background="Transparent"
               FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12"
               Watermark="{l:Tr BundleImport_PayloadWatermark}" />
    </Border>

    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Classes="methodpick" Width="180" Click="OnLoadFile">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource AgUploadGeometry}" Width="14" Height="14" />
          <TextBlock Text="{l:Tr BundleImport_LoadFileButton}" />
        </StackPanel>
      </Button>
      <Button Classes="accent" Width="180" Command="{Binding ImportCommand}" IsEnabled="{Binding !IsBusy}">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <PathIcon Data="{StaticResource AgCheckGeometry}" Width="14" Height="14" />
          <TextBlock Text="{l:Tr BundleImport_ImportButton}" />
        </StackPanel>
      </Button>
    </StackPanel>

    <!-- Carries both the success summary and error messages. -->
    <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
  </StackPanel>
</UserControl>
