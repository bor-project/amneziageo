<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:views="clr-namespace:AmneziaGeo.Windows.Ui.Views"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             xmlns:svc="clr-namespace:AmneziaGeo.Windows.Ui.Services"
             x:Class="AmneziaGeo.Windows.Ui.Views.GeneralView"
             x:CompileBindings="True"
             x:DataType="vm:GeneralViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgBackGeometry">M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z</StreamGeometry>
    <StreamGeometry x:Key="AgDownloadGeometry">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</StreamGeometry>
    <StreamGeometry x:Key="AgUploadGeometry">M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z</StreamGeometry>
  </UserControl.Resources>
  <Panel>

    <!-- MAIN general page. -->
    <StackPanel IsVisible="{Binding IsGeneralMain}" Spacing="14">
      <TextBlock Classes="section" Text="{l:Tr General_Section}" />

      <!-- Top row: appearance + about reflow from two columns to one when the pane gets narrow. -->
      <UniformGrid x:Name="TopCards"
                   Columns="{Binding #TopCards.Bounds.Width, Converter={x:Static svc:WidthBreakpointConverter.Instance}, ConverterParameter=680}">

        <!-- Appearance card: theme + language (live switch). -->
        <Border Margin="{Binding #TopCards.Columns, Converter={x:Static svc:GutterMarginConverter.Instance}, ConverterParameter=first}"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16" Background="Transparent">
          <StackPanel Spacing="12">
            <TextBlock Text="{l:Tr Main_AppearanceTitle}" FontWeight="SemiBold" FontSize="15" />

            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="12">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Tr General_Theme}" FontSize="13.5" VerticalAlignment="Center" />
              <ComboBox Grid.Row="0" Grid.Column="1" Classes="field" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        ItemsSource="{Binding Themes}"
                        SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}" />
              <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Tr General_Language}" FontSize="13.5" VerticalAlignment="Center" />
              <ComboBox Grid.Row="1" Grid.Column="1" Classes="field" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        ItemsSource="{Binding Languages}"
                        SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" />
            </Grid>
          </StackPanel>
        </Border>

        <!-- About card: versions + app self-update. -->
        <Border Margin="{Binding #TopCards.Columns, Converter={x:Static svc:GutterMarginConverter.Instance}, ConverterParameter=second}"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16" Background="Transparent">
          <StackPanel Spacing="12">
            <TextBlock Text="{l:Tr About_Section}" FontWeight="SemiBold" FontSize="15" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="{l:Tr About_Version}" FontSize="13.5" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding AppVersion}" Classes="muted mono" FontSize="12.5"
                         HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
              <TextBlock Grid.Column="0" Text="{l:Tr Main_AmneziaEngineVersion}" FontSize="13.5" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="{Binding AmneziaVersion}" Classes="muted mono" FontSize="12.5"
                         HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Right" TextWrapping="Wrap" />
            </Grid>

            <!-- Update sub-block: found -> downloading -> downloaded; installing is an explicit second click (#154). -->
            <StackPanel Spacing="9" IsVisible="{Binding HasUpdateUrl}">
              <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" Margin="0,2,0,0" />
              <TextBlock Text="{l:Tr Main_UpdateSection}" FontWeight="SemiBold" FontSize="13.5" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Text="{l:Tr General_AllowPrerelease}" FontSize="13" TextWrapping="Wrap" />
                  <TextBlock Text="{l:Tr General_AllowPrereleaseHint}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
                <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AllowPrerelease, Mode=TwoWay}" />
              </Grid>
              <TextBlock Text="{Binding UpdateVersionBadgeText}" FontSize="13" FontWeight="SemiBold"
                         IsVisible="{Binding UpdateAvailable}" />
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="{Binding UpdateStatus}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                             IsVisible="{Binding UpdateStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  <TextBlock Text="{Binding UpdateDescription}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                             IsVisible="{Binding UpdateAvailable}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <Button Classes="softbtn" Content="{l:Tr Main_CheckUpdatesButton}" Command="{Binding CheckUpdateCommand}"
                          IsVisible="{Binding ShowCheckUpdateButton}" />
                  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsVisible="{Binding UpdateAvailable}">
                    <TextBlock Text="{Binding UpdateDownloadPercent, StringFormat='{}{0}%'}" Classes="muted"
                               FontSize="12" VerticalAlignment="Center" IsVisible="{Binding UpdateDownloading}" />
                    <Button Classes="accent" Content="{l:Tr Main_DownloadButton}" Command="{Binding DownloadUpdateCommand}"
                            IsVisible="{Binding ShowDownloadButton}" />
                    <Button Classes="softbtn" Content="{l:Tr Main_CancelButton}" Command="{Binding CancelDownloadCommand}"
                            IsVisible="{Binding UpdateDownloading}" />
                    <Button Classes="accent" Content="{l:Tr Main_InstallButton}" Command="{Binding ApplyUpdateCommand}"
                            IsVisible="{Binding UpdateDownloaded}" />
                  </StackPanel>
                </StackPanel>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>
      </UniformGrid>

      <!-- Connection resilience card: survive reboot + periodic auto-reconnect (#196, #199). -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <StackPanel Spacing="12">
          <TextBlock Text="{l:Tr General_ConnectionSection}" FontWeight="SemiBold" FontSize="15" />

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{l:Tr General_ShowNotifications}" FontSize="13.5" />
              <TextBlock Text="{l:Tr General_ShowNotificationsHint}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding ShowNotifications, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{l:Tr General_SurviveReboot}" FontSize="13.5" />
              <TextBlock Text="{l:Tr General_SurviveRebootHint}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding SurviveReboot, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{l:Tr General_PeriodicReconnect}" FontSize="13.5" />
              <TextBlock Text="{l:Tr General_PeriodicReconnectHint}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding PeriodicReconnect, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsEnabled="{Binding PeriodicReconnectIntervalEnabled}">
            <TextBlock Grid.Column="0" Text="{l:Tr General_ReconnectInterval}" FontSize="13.5" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <ComboBox Classes="field" Width="92" VerticalAlignment="Center"
                        ItemsSource="{Binding ReconnectIntervals}"
                        SelectedItem="{Binding ReconnectIntervalSeconds, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="x:Int32">
                    <TextBlock Text="{Binding}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="{l:Tr General_Seconds}" Classes="muted" FontSize="12.5" VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Import / export card (full width): hint left, actions right. Opens the bundle sub-views inline. -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
            <TextBlock Text="{l:Tr Main_ImportExportSection}" FontWeight="SemiBold" FontSize="15" />
            <TextBlock Classes="muted" FontSize="12.5" TextWrapping="Wrap" Text="{l:Tr Main_BundleHint}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Classes="softbtn" Padding="16,7" Command="{Binding OpenBundleExportCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Data="{StaticResource AgDownloadGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_ExportButton}" />
              </StackPanel>
            </Button>
            <Button Classes="softbtn" Padding="16,7" Command="{Binding OpenBundleImportCommand}">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <PathIcon Data="{StaticResource AgUploadGeometry}" Width="15" Height="15" />
                <TextBlock Text="{l:Tr Main_ImportButton}" />
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>

    <!-- BUNDLE EXPORT sub-view. -->
    <StackPanel IsVisible="{Binding IsBundleExport}" Spacing="14">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="icon" Padding="6,4" Command="{Binding CloseBundleCommand}">
          <PathIcon Data="{StaticResource AgBackGeometry}" Width="18" Height="18" Foreground="{DynamicResource AgMutedBrush}" />
        </Button>
        <TextBlock Classes="section" Text="{l:Tr BundleExport_WindowTitle}" VerticalAlignment="Center" />
      </StackPanel>
      <views:BundleExportView DataContext="{Binding BundleExport}" />
    </StackPanel>

    <!-- BUNDLE IMPORT sub-view. -->
    <StackPanel IsVisible="{Binding IsBundleImport}" Spacing="14">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="icon" Padding="6,4" Command="{Binding CloseBundleCommand}">
          <PathIcon Data="{StaticResource AgBackGeometry}" Width="18" Height="18" Foreground="{DynamicResource AgMutedBrush}" />
        </Button>
        <TextBlock Classes="section" Text="{l:Tr BundleImport_WindowTitle}" VerticalAlignment="Center" />
      </StackPanel>
      <views:BundleImportView DataContext="{Binding BundleImport}" />
    </StackPanel>

  </Panel>
</UserControl>
