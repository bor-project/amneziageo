<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:AmneziaGeo.Ui.Controls"
             xmlns:vm="clr-namespace:AmneziaGeo.Ui.ViewModels"
             xmlns:svc="clr-namespace:AmneziaGeo.Ui.Services"
             xmlns:l="clr-namespace:AmneziaGeo.Ui.Localization"
             x:Class="AmneziaGeo.Ui.Views.SourcesView"
             x:CompileBindings="True"
             x:DataType="vm:SourcesViewModel">
  <StackPanel Spacing="14">
    <!-- Header: section title + count pill. -->
    <Grid ColumnDefinitions="Auto,Auto,*">
      <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_SourcesSection}" VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
              Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Sources.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
      </Border>
    </Grid>

    <!-- Update-check card: manual check + periodic auto-check. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="12">
        <TextBlock Text="{l:Tr Main_AutoCheckTitle}" FontWeight="SemiBold" FontSize="15" />
        <!-- Compact drops the interval + toggle under the hint, and the check button spans the width. -->
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
          <TextBlock Grid.Column="0" Text="{l:Tr Main_AutoCheckHint}" Classes="muted" FontSize="12"
                     TextWrapping="Wrap" MaxWidth="430" HorizontalAlignment="Left" VerticalAlignment="Center"
                     Grid.ColumnSpan="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=span2}" />
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                      Grid.Row="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=row}"
                      Grid.Column="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=col}"
                      HorizontalAlignment="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=alignRL}">
            <controls:AdaptiveComboBox Classes="field" Width="92" VerticalAlignment="Center"
                      IsEnabled="{Binding GeoAutoCheck}"
                      ItemsSource="{Binding GeoCheckIntervals}"
                      SelectedItem="{Binding GeoCheckIntervalHours, Mode=TwoWay}">
              <controls:AdaptiveComboBox.ItemTemplate>
                <DataTemplate x:DataType="x:Int32">
                  <TextBlock Text="{Binding Converter={x:Static l:HoursConverter.Instance}}" />
                </DataTemplate>
              </controls:AdaptiveComboBox.ItemTemplate>
            </controls:AdaptiveComboBox>
            <ToggleSwitch VerticalAlignment="Center" IsChecked="{Binding GeoAutoCheck, Mode=TwoWay}" />
          </StackPanel>
        </Grid>
        <Button Classes="methodpick" Padding="18,6"
                Width="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=w170}"
                HorizontalAlignment="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=stretchL}"
                Command="{Binding CheckSourcesCommand}" Content="{l:Tr Main_CheckUpdatesButton}" />
      </StackPanel>
    </Border>

    <!-- Add-database card. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="10">
        <TextBlock Text="{l:Tr Main_AddDatabaseLabel}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />

        <!-- Wide: kind picker, URL, and add button inline. -->
        <Grid ColumnDefinitions="Auto,*,Auto" IsVisible="{Binding !IsCompact}">
          <controls:AdaptiveComboBox Grid.Column="0" Classes="field" Width="100" Margin="0,0,8,0"
                    ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                    IsEnabled="{Binding !SourceKindLocked}"
                    ToolTip.Tip="{l:Tr Main_SourceKindTooltip}" />
          <TextBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                   Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
          <Button Grid.Column="2" Classes="accent" Width="130" Command="{Binding AddSourceCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="+" />
              <TextBlock Text="{l:Tr Main_AddButton}" />
            </StackPanel>
          </Button>
        </Grid>

        <!-- Compact: kind picker and add button split the row evenly; URL drops to its own full-width row. -->
        <StackPanel Spacing="8" IsVisible="{Binding IsCompact}">
          <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
            <controls:AdaptiveComboBox Grid.Column="0" Classes="field" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                      IsEnabled="{Binding !SourceKindLocked}"
                      ToolTip.Tip="{l:Tr Main_SourceKindTooltip}" />
            <Button Grid.Column="1" Classes="accent" HorizontalAlignment="Stretch" Command="{Binding AddSourceCommand}">
              <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="+" />
                <TextBlock Text="{l:Tr Main_AddButton}" />
              </StackPanel>
            </Button>
          </Grid>
          <TextBox Classes="field" Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
        </StackPanel>

        <TextBlock Classes="muted" FontSize="12" TextWrapping="Wrap" Text="{l:Tr Main_GeoKindsHint}" />
      </StackPanel>
    </Border>

    <!-- Sources list card. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="{l:Tr Main_SourcesLabel}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="methodpick" Width="130" Padding="18,6"
                  Command="{Binding UpdateSourcesCommand}" Content="{l:Tr Main_UpdateAllButton}" />
        </Grid>
        <ItemsControl ItemsSource="{Binding Sources}" IsVisible="{Binding HasSources}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SourceItemViewModel">
                <Border Background="{DynamicResource AgPanelBrush}"
                        BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                        CornerRadius="9" Padding="11,9" Margin="0,3"
                        ContextRequested="OnSourceRowContext"
                        DoubleTapped="OnSourceRowDoubleTapped"
                        ToolTip.Tip="{l:Tr Main_SourceRowTooltip}">
                  <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsEditing}">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Classes="srctitle" Text="{Binding Detail}" FontSize="12.5" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Url}" FontSize="11" Classes="muted mono"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{l:Tr Main_UpdateAvailableBadge}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AgAccentBrush}" Margin="0,3,0,0"
                                   IsVisible="{Binding ShowUpdateBadge}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                  VerticalAlignment="Center" Margin="8,0,0,0">
                        <Button Classes="icon" VerticalAlignment="Center"
                                Command="{Binding UpdateCommand}" IsEnabled="{Binding !Updating}"
                                ToolTip.Tip="{l:Tr Main_UpdateDatabaseTooltip}">
                          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProgressText}" IsVisible="{Binding ShowProgress}"
                                       FontSize="11.5" VerticalAlignment="Center" />
                            <PathIcon Classes.spin="{Binding Updating}" Data="{DynamicResource AgRefreshGeometry}"
                                      Width="14" Height="14" />
                          </StackPanel>
                        </Button>
                        <Button Classes="icon" VerticalAlignment="Center"
                                Click="OnSourceKebab" ToolTip.Tip="{l:Tr Main_ActionsTooltip}">
                          <TextBlock Text="⋮" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                        </Button>
                      </StackPanel>
                    </Grid>
                    <!-- Compact puts the kind picker and URL on separate rows, and splits Save / Cancel evenly. -->
                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="6">
                      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" RowSpacing="6">
                        <controls:AdaptiveComboBox Grid.Column="0" Classes="field" Width="100" Margin="0,0,8,0"
                                  ItemsSource="{Binding Kinds}" SelectedItem="{Binding EditKind, Mode=TwoWay}" />
                        <TextBox Classes="field"
                                 Grid.Row="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=row}"
                                 Grid.Column="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=col}"
                                 Grid.ColumnSpan="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=span2}"
                                 Text="{Binding EditUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
                      </Grid>
                      <Grid ColumnDefinitions="*,*" ColumnSpacing="6"
                            HorizontalAlignment="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=stretchR}">
                        <Button Grid.Column="0" Classes="accent" HorizontalAlignment="Stretch"
                                Width="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=w100}"
                                Content="{l:Tr Main_SaveButton}" Command="{Binding SaveEditCommand}" />
                        <Button Grid.Column="1" Classes="methodpick" HorizontalAlignment="Stretch"
                                Width="{Binding $parent[ItemsControl].((vm:SourcesViewModel)DataContext).IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=w100}"
                                Content="{l:Tr Main_CancelButton}" Command="{Binding CancelEditCommand}" />
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        <TextBlock IsVisible="{Binding !HasSources}"
                   Text="{l:Tr Main_NoSourcesHint}"
                   Classes="muted" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
