<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:AmneziaGeo.Windows.Ui.Services"
        xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
        xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
        x:Class="AmneziaGeo.Windows.Ui.MainWindow"
        x:CompileBindings="True"
        x:DataType="vm:MainWindowViewModel"
        Title="AmneziaGeo"
        Width="987" Height="610"
        MinWidth="800" MinHeight="560"
        Background="{DynamicResource AgBgBrush}"
        FontFamily="IBM Plex Sans, Segoe UI, sans-serif"
        Foreground="{DynamicResource AgFgBrush}">

  <Window.Resources>
    <!-- Refresh glyph. -->
    <StreamGeometry x:Key="AgRefreshGeometry">M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z</StreamGeometry>
    <!-- Power glyph. -->
    <StreamGeometry x:Key="AgPowerGeometry">M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z</StreamGeometry>
    <!-- Gear glyph. -->
    <StreamGeometry x:Key="AgGearGeometry">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</StreamGeometry>
    <!-- Back glyph. -->
    <StreamGeometry x:Key="AgBackGeometry">M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20z</StreamGeometry>
  </Window.Resources>

  <Grid>

    <!-- HOME screen. -->
    <Border Classes="card" Margin="12" Padding="0" IsVisible="{Binding IsHome}">
      <DockPanel LastChildFill="True">

        <!-- Top row: gear pinned left, title centered. -->
        <Border DockPanel.Dock="Top" Height="48" Padding="12,0">
          <Grid>
            <TextBlock Text="AmneziaGeo" FontSize="15" FontWeight="SemiBold"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Foreground="{DynamicResource AgMutedBrush}" />
            <Button Classes="icon" Padding="6,4" VerticalAlignment="Center" HorizontalAlignment="Left"
                    Command="{Binding NavSettingsCommand}" ToolTip.Tip="{l:Tr Main_SettingsTooltip}">
              <PathIcon Data="{DynamicResource AgGearGeometry}" Width="18" Height="18"
                        Foreground="{DynamicResource AgMutedBrush}" />
            </Button>
          </Grid>
        </Border>

        <!-- Centered column: power button + status/hint + profile combo. -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
          <Button Classes="powerbig" HorizontalAlignment="Center"
                  Command="{Binding ToggleConnectionCommand}"
                  IsEnabled="{Binding CanToggleConnection}"
                  ToolTip.Tip="{Binding ConnectHint}">
            <Grid Width="236" Height="236">
              <Ellipse Width="236" Height="236" Stroke="{DynamicResource AgBorderBrush}"
                       StrokeThickness="1" Opacity="0.7" />
              <Ellipse Width="196" Height="196" Stroke="{DynamicResource AgBorderBrush}"
                       StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Width="158" Height="158" Stroke="{DynamicResource AgBorder2Brush}"
                       StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
              <!-- Accent ring-wave overlays during connect / disconnect. -->
              <Ellipse Classes="ring r1" Classes.waveout="{Binding IsConnectingOut}"
                       Classes.wavein="{Binding IsConnectingIn}"
                       Width="158" Height="158" Stroke="{Binding ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Classes="ring r2" Classes.waveout="{Binding IsConnectingOut}"
                       Classes.wavein="{Binding IsConnectingIn}"
                       Width="196" Height="196" Stroke="{Binding ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Ellipse Classes="ring r3" Classes.waveout="{Binding IsConnectingOut}"
                       Classes.wavein="{Binding IsConnectingIn}"
                       Width="236" Height="236" Stroke="{Binding ConnectCircleForeground}" StrokeThickness="2"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
              <Border Width="132" Height="132" CornerRadius="66"
                      Background="{Binding ConnectCircleBrush}"
                      BorderBrush="{Binding ConnectCircleBorderBrush}" BorderThickness="2"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      BoxShadow="0 8 24 0 #1F000000">
                <Panel>
                  <PathIcon Data="{DynamicResource AgPowerGeometry}" Width="54" Height="54"
                            Foreground="{Binding ConnectCircleForeground}"
                            IsVisible="{Binding !IsConnecting}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Ellipse Classes.pulse="{Binding IsConnecting}" Width="44" Height="44"
                           IsVisible="{Binding IsConnecting}" Fill="{Binding ConnectCircleForeground}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Panel>
              </Border>
            </Grid>
          </Button>

          <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,4,0,0">
            <TextBlock Text="{Binding AgentStatusText}" FontSize="17" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Foreground="{Binding ConnectStatusBrush}" />
            <TextBlock Text="{Binding ConnectHint}" FontSize="12.5"
                       HorizontalAlignment="Center" Foreground="{Binding ConnectHintBrush}" />
          </StackPanel>

          <!-- Profile picker: «- не выбрано -» then saved profiles. -->
          <StackPanel HorizontalAlignment="Center" Spacing="6" Width="300" Margin="0,6,0,0">
            <ComboBox Classes="field" HorizontalAlignment="Stretch"
                      ItemsSource="{Binding ProfileOptions}"
                      SelectedItem="{Binding ActiveProfileChoice, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ProfileChoice">
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <!-- No profiles: hint to add one in settings. -->
            <TextBlock IsVisible="{Binding !HasBalancers}" Classes="muted" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       Text="{l:Tr Main_NoProfilesHint}" />
            <!-- Profiles exist but none usable: hint to pick one. -->
            <TextBlock IsVisible="{Binding ShowSelectConfigHint}" Classes="muted" FontSize="12"
                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300"
                       Text="{l:Tr Main_HomeSelectConfigHint}" />
          </StackPanel>
        </StackPanel>

      </DockPanel>
    </Border>

    <!-- SETTINGS screen. -->

      <!-- Settings top header: back to home (left), title centered, connect control (right). -->
      <Border Classes="card" CornerRadius="0" Height="48" Margin="12,12,12,0" Padding="12,0"
              VerticalAlignment="Top" IsVisible="{Binding IsSettings}">
        <Grid>
          <!-- Title centered. -->
          <TextBlock Text="AmneziaGeo" FontSize="15" FontWeight="SemiBold"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="{DynamicResource AgMutedBrush}" />

          <!-- Back to Home. -->
          <Button Classes="backbtn" HorizontalAlignment="Left" VerticalAlignment="Center"
                  Command="{Binding NavHomeCommand}" ToolTip.Tip="{l:Tr Main_BackToProfilesTooltip}">
            <PathIcon Data="{DynamicResource AgBackGeometry}" Width="18" Height="18"
                      Foreground="{DynamicResource AgMutedBrush}" />
          </Button>

          <!-- Animated connect / disconnect control. -->
          <Button Classes="powerctl" HorizontalAlignment="Right" VerticalAlignment="Center"
                  MinWidth="150" HorizontalContentAlignment="Left"
                  Command="{Binding ToggleConnectionCommand}"
                  IsEnabled="{Binding CanToggleConnection}"
                  ToolTip.Tip="{Binding ConnectHint}">
            <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
              <Panel Width="28" Height="28">
                <Ellipse Classes="connspin" Classes.spinning="{Binding IsConnecting}"
                         Width="26" Height="26" Stroke="{Binding ConnectCircleForeground}"
                         StrokeThickness="2" StrokeDashArray="12,29" StrokeLineCap="Round"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Border Width="22" Height="22" CornerRadius="11"
                        Background="{Binding ConnectCircleBrush}"
                        BorderBrush="{Binding ConnectCircleBorderBrush}" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                  <PathIcon Data="{DynamicResource AgPowerGeometry}" Width="11" Height="11"
                            Foreground="{Binding ConnectCircleForeground}"
                            IsVisible="{Binding !IsConnecting}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
              </Panel>
              <!-- Short status only. -->
              <TextBlock Text="{Binding AgentStatusText}" FontSize="12" FontWeight="SemiBold"
                         Foreground="{Binding ConnectStatusBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>

    <Grid IsVisible="{Binding IsSettings}" Margin="12,0,12,12" RowDefinitions="48,*">
      <Grid.ColumnDefinitions>
        <!-- Section rail column, drag-resizable via the GridSplitter. -->
        <ColumnDefinition Width="260" MinWidth="210" MaxWidth="460" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Section rail. -->
      <Border Grid.Column="0" Grid.Row="1" Classes="card" CornerRadius="0" Margin="0,12,0,0" Padding="0">
        <ScrollViewer>
          <StackPanel Margin="12,12">
              <Button Classes="rowselect" Classes.active="{Binding IsSettingsProfile}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="profile">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsProfile}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailProfileTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailProfileSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsConfig}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="config">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsConfig}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailConfigTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailConfigSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsRouting}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="routing">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsRouting}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailRoutingTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailRoutingSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsSources}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="sources">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsSources}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailSourcesTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailSourcesSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsLogs}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="logs">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsLogs}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailLogsTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailLogsSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsGeneral}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="general">
                <Grid ColumnDefinitions="Auto,*" Margin="12,7">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsGeneral}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{l:Tr Main_RailGeneralTitle}" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="{l:Tr Main_RailGeneralSubtitle}" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>
            </StackPanel>
          </ScrollViewer>
      </Border>

      <!-- Draggable divider between rail and content. -->
      <GridSplitter Grid.Column="1" Grid.Row="1" Width="5"
                    ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="Transparent" Margin="0,12,0,0" />

      <!-- Content pane. -->
      <Border Grid.Column="2" Grid.Row="1" Classes="card" CornerRadius="0" Margin="0,12,0,0" Padding="0">
        <!-- Inset on the ScrollViewer so a section can bind its height to the viewport. -->
        <ScrollViewer x:Name="ContentScroll" Padding="18,16">
          <Grid>

            <!-- PROFILE SECTION -->
            <StackPanel IsVisible="{Binding IsSettingsProfile}" Spacing="14">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_ProfileSection}" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                        Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Profiles.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
                </Border>
                <!-- «+ Профиль» disabled when the catalogue is empty. -->
                <Button Grid.Column="3" Classes="softbtn" Command="{Binding CreateProfileCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="+" />
                    <TextBlock Text="{l:Tr Main_ProfileAddButton}" />
                  </StackPanel>
                </Button>
              </Grid>

              <!-- No configurations yet: explain what to do first. -->
              <TextBlock IsVisible="{Binding !HasConfigs}" Classes="muted" FontSize="12.5"
                         TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center"
                         Margin="0,24,0,8" MaxWidth="360"
                         Text="{l:Tr Main_ProfileNeedsConfigHint}" />

              <StackPanel Spacing="6" IsVisible="{Binding HasConfigs}">
                <TextBlock Classes="label" Text="{l:Tr Main_ChooseProfileToSetup}" />
                <ComboBox Classes="field" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding ProfileOptions}"
                          SelectedItem="{Binding OpenProfileChoice, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProfileChoice">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock IsVisible="{Binding ShowNoProfilesYetHint}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                           Text="{l:Tr Main_NoProfilesYetHint}" />
              </StackPanel>

              <!-- Open profile's editor: rename + config picker + routing picker + delete. -->
              <StackPanel IsVisible="{Binding IsProfileDetail}" Spacing="16">

                <!-- Rename: auto-saves debounced; no «Сохранить». -->
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="{l:Tr Main_NameLabel}" />
                  <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                             Text="{l:Tr Main_ProfileRenameHint}" />
                  <TextBox Classes="field" Classes.invalid="{Binding ProfileNameMissing}"
                           Text="{Binding ProfileRename, Mode=TwoWay}" />
                  <TextBlock Classes="fieldwarn" IsVisible="{Binding ProfileNameMissing}"
                             Text="{l:Tr Main_RequiredEmptyWarning}" />
                  <TextBlock Text="{Binding ProfileRenameStatus}" Classes="muted" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- Config + routing pickers for the open profile. -->
                <StackPanel DataContext="{Binding OpenProfile}" x:DataType="vm:BalancerItemViewModel" Spacing="16">

                  <!-- Config picker: «- не выбрано -» then saved configs. -->
                  <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="{l:Tr Main_ConfigLabel}" />
                    <ComboBox Classes="field" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding ConfigOptions}"
                              SelectedItem="{Binding SelectedConfig, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConfigChoice">
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock IsVisible="{Binding !HasConfig}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                               Text="{l:Tr Main_ProfileNoConfigHint}" />
                  </StackPanel>

                  <!-- Routing picker: None means «Полный туннель». -->
                  <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="{l:Tr Main_RoutingLabel}" />
                    <ComboBox Classes="field" HorizontalAlignment="Stretch"
                              ItemsSource="{Binding RoutingListOptions}"
                              SelectedItem="{Binding SelectedRoutingList, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RoutingListChoice">
                          <!-- Relabel the "none" sentinel as «Полный туннель». -->
                          <Panel>
                            <TextBlock Text="{l:Tr Main_FullTunnel}" IsVisible="{Binding IsNone}" />
                            <TextBlock Text="{Binding Name}" IsVisible="{Binding !IsNone}" />
                          </Panel>
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding CanToggleRouting}">
                      <ToggleSwitch Grid.Column="0" IsChecked="{Binding UseRouting, Mode=TwoWay}"
                                    OnContent="" OffContent="" MinWidth="0" />
                      <TextBlock Grid.Column="1" Margin="11,0,0,0"
                                 Text="{l:Tr Main_UseSelectedList}" FontSize="12.5" FontWeight="Medium"
                                 VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                               Text="{l:Tr Main_RoutingPickerHint}" />
                  </StackPanel>
                </StackPanel>

                <!-- Delete. -->
                <StackPanel Spacing="6">
                  <TextBlock Classes="label" Text="{l:Tr Main_DeletionLabel}" />
                  <Button Classes="danger" HorizontalAlignment="Left"
                          Command="{Binding DeleteOpenProfileCommand}" Content="{l:Tr Main_DeleteProfileButton}" />
                  <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                             Text="{l:Tr Main_DeleteProfileHint}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <!-- CONFIG SECTION: Grid so the import form fills the pane height. -->
            <Grid IsVisible="{Binding IsSettingsConfig}" RowDefinitions="Auto,Auto,Auto,*"
                  MinHeight="{Binding #ContentScroll.Viewport.Height}">
              <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_ConfigSection}" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                        Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Configs.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
                </Border>
                <Button Grid.Column="3" Classes="softbtn" Command="{Binding BeginSectionConfigCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="+" />
                    <TextBlock Text="{l:Tr Main_NewConfigButton}" />
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Config catalogue combo: «- не выбрано -» then saved configs. -->
              <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="6">
                <TextBlock Classes="label" Text="{l:Tr Main_ChooseConfigLabel}" />
                <ComboBox Classes="field" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding ConfigCatalogueOptions}"
                          SelectedItem="{Binding SelectedCatalogueConfig, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ConfigChoice">
                      <TextBlock Text="{Binding Name}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock IsVisible="{Binding !HasConfigs}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                           Text="{l:Tr Main_NoConfigsHint}" />
              </StackPanel>

              <!-- Standalone import form (Row 3). Auto-saves when text parses and name is set. -->
              <Border Grid.Row="3" Margin="0,14,0,0" VerticalAlignment="Stretch"
                      IsVisible="{Binding IsCreatingSectionConfig}"
                      Background="{DynamicResource AgInsetBrush}"
                      BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                      CornerRadius="9" Padding="10">
                <DockPanel LastChildFill="True">
                  <StackPanel DockPanel.Dock="Top" Spacing="6">
                    <TextBlock Classes="label" Text="{l:Tr Main_NewConfigLabel}" />
                    <TextBox Classes="field" Classes.invalid="{Binding SectionConfigNameMissing}"
                             Text="{Binding SectionConfigName, Mode=TwoWay}"
                             Watermark="{l:Tr Main_ConfigNameWatermark}" />
                    <TextBlock Classes="fieldwarn" IsVisible="{Binding SectionConfigNameMissing}"
                               Text="{l:Tr Main_RequiredEmptyWarning}" />
                  </StackPanel>
                  <!-- Buttons sized to content, centred. -->
                  <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,10,0,0">
                    <TextBlock Text="{Binding SectionConfigStatus}" Classes="muted" FontSize="11.5"
                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                      <Button Classes="softbtn" Content="{l:Tr Main_FileButton}" Click="OnSectionConfigBrowse" />
                      <Button Classes="softbtn" Content="{l:Tr Main_CameraButton}" Click="OnSectionConfigCamera" />
                      <Button Classes="softbtn" Content="{l:Tr Main_ConfigEditButton}" Click="OnSectionConfigEdit"
                              ToolTip.Tip="{l:Tr Main_ConfigEditButtonTooltip}" />
                    </StackPanel>
                  </StackPanel>
                  <TextBox Classes="field" Margin="0,10,0,0" IsReadOnly="True"
                           Text="{Binding SectionConfigText}" AcceptsReturn="True" TextWrapping="Wrap"
                           VerticalAlignment="Stretch" MinHeight="180"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           Watermark="{l:Tr Main_ConfigTextWatermark}" />
                </DockPanel>
              </Border>

              <!-- Open config (Row 2): name editor + .conf export/editor + proxy + delete. -->
              <StackPanel Grid.Row="2" Margin="0,14,0,0" IsVisible="{Binding IsConfigManage}" Spacing="14">
                <!-- Config name: per-keystroke so the required-field border reacts at once; auto-saves debounced. -->
                <StackPanel Spacing="2">
                  <TextBlock Classes="label" Text="{l:Tr Main_ConfigNameLabel}" />
                  <TextBox Classes="field" Classes.invalid="{Binding ConfigNameMissing}"
                           Text="{Binding ConfigRename, Mode=TwoWay}" VerticalAlignment="Center" />
                  <TextBlock Classes="fieldwarn" IsVisible="{Binding ConfigNameMissing}"
                             Text="{l:Tr Main_RequiredEmptyWarning}" />
                  <TextBlock Text="{Binding ConfigRenameStatus}" Classes="muted" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>

                <!-- .conf text + export. -->
                <StackPanel Spacing="10" DataContext="{Binding ConfigExport}" x:DataType="vm:ExportDialogViewModel">
                  <Border Background="{DynamicResource AgInsetBrush}"
                          BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                          CornerRadius="9" Padding="3" HorizontalAlignment="Center"
                          IsEnabled="{Binding !IsEditing}">
                    <UniformGrid Columns="2" Width="320">
                      <Button Classes="seg" Classes.active="{Binding IsConf}" Command="{Binding ShowConfCommand}"
                              Content="{l:Tr Main_ConfFileTab}" HorizontalAlignment="Stretch" />
                      <Button Classes="seg" Classes.active="{Binding IsLink}" Command="{Binding ShowLinkCommand}"
                              Content="{l:Tr Main_VpnLinkTab}" HorizontalAlignment="Stretch" />
                    </UniformGrid>
                  </Border>
                  <TextBlock IsVisible="{Binding IsEditing}" Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                             Text="{l:Tr Main_ConfEditHint}" />
                  <Border HorizontalAlignment="Center" Background="White" CornerRadius="8" Padding="10"
                          IsVisible="{Binding ShowQr}">
                    <Image Source="{Binding QrImage}" Width="220" Height="220" />
                  </Border>
                  <Border HorizontalAlignment="Center" Background="{DynamicResource AgInsetBrush}"
                          BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                          CornerRadius="8" Padding="16" Width="240" IsVisible="{Binding QrUnavailable}">
                    <TextBlock Text="{l:Tr Main_QrUnavailableHint}"
                               Classes="muted" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" />
                  </Border>
                  <Border BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
                          CornerRadius="8" Background="{DynamicResource AgPanelBrush}"
                          IsVisible="{Binding IsEditing}">
                    <TextBox Text="{Binding Payload, Mode=TwoWay}" IsReadOnly="{Binding !IsEditing}"
                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                             VerticalContentAlignment="Top" Height="240"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent"
                             FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12" />
                  </Border>
                  <WrapPanel HorizontalAlignment="Center">
                    <Button Classes="softbtn" Content="{l:Tr Main_EditButton}" Command="{Binding BeginEditCommand}" Margin="4"
                            IsVisible="{Binding !IsEditing}" IsEnabled="{Binding IsReady}" />
                    <Button Classes="accent" Content="{l:Tr Main_SaveButton}" Command="{Binding SaveEditCommand}" Margin="4"
                            IsVisible="{Binding IsEditing}" />
                    <Button Classes="softbtn" Content="{l:Tr Main_CancelButton}" Command="{Binding CancelEditCommand}" Margin="4"
                            IsVisible="{Binding IsEditing}" />
                    <Button Classes="softbtn" Content="{l:Tr Main_CopyButton}" Click="OnConfigExportCopy" Margin="4"
                            IsVisible="{Binding !IsEditing}" IsEnabled="{Binding IsReady}" />
                    <Button Classes="softbtn" Content="{l:Tr Main_SaveToFileButton}" Click="OnConfigExportSave" Margin="4"
                            IsVisible="{Binding !IsEditing}" IsEnabled="{Binding IsReady}" />
                  </WrapPanel>
                  <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                             HorizontalAlignment="Center" TextAlignment="Center" />
                </StackPanel>

                <!-- Proxy (WebSocket). -->
                <StackPanel Spacing="10" DataContext="{Binding ConfigTransport}" x:DataType="vm:ConfigTransportViewModel">
                  <TextBlock Classes="label" Text="{l:Tr Main_ProxyWebSocketLabel}" />
                  <CheckBox Content="{l:Tr Main_UseWebSocketCheckbox}"
                            IsChecked="{Binding UseWebSocket}" />
                  <!-- MTU applies to any transport, not just WSS. Kept outside the WebSocket block. -->
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{l:Tr Main_TunnelMtuLabel}" VerticalAlignment="Center" />
                    <TextBox Width="90" Text="{Binding Mtu}" VerticalAlignment="Center" />
                    <TextBlock Classes="muted" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"
                               Text="{l:Tr Main_MtuHint}" />
                  </StackPanel>
                  <StackPanel IsVisible="{Binding UseWebSocket}" Spacing="8" Margin="22,0,0,0">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{l:Tr Main_ServerHostLabel}" />
                      <TextBox Text="{Binding WebSocketHost}"
                               Watermark="{l:Tr Main_ServerHostWatermark}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{l:Tr Main_ServerPortLabel}" VerticalAlignment="Center" />
                      <TextBox Width="90" Text="{Binding WebSocketPort}" />
                    </StackPanel>
                    <StackPanel Spacing="2">
                      <TextBlock Text="{l:Tr Main_AuthLabel}" />
                      <ComboBox SelectedIndex="{Binding AuthMode, Mode=TwoWay}" HorizontalAlignment="Left" MinWidth="220">
                        <ComboBoxItem Content="{l:Tr Main_AuthNone}" />
                        <ComboBoxItem Content="{l:Tr Main_AuthBasic}" />
                        <ComboBoxItem Content="{l:Tr Main_AuthToken}" />
                      </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="2" IsVisible="{Binding IsBasicAuth}">
                      <TextBlock Text="{l:Tr Main_LoginLabel}" />
                      <TextBox Text="{Binding WebSocketUser}" Watermark="{l:Tr Main_LoginWatermark}" />
                      <TextBlock Text="{l:Tr Main_PasswordLabel}" Margin="0,4,0,0" />
                      <TextBox Text="{Binding WebSocketPassword}" PasswordChar="●" Watermark="{l:Tr Main_PasswordWatermark}" />
                    </StackPanel>
                    <StackPanel Spacing="2" IsVisible="{Binding IsTokenAuth}">
                      <TextBlock Text="{l:Tr Main_AccessTokenLabel}" />
                      <TextBox Text="{Binding WebSocketToken}" Watermark="{l:Tr Main_AccessTokenWatermark}" />
                    </StackPanel>
                    <Border Background="{DynamicResource AgInsetBrush}" CornerRadius="6" Padding="8">
                      <SelectableTextBlock Text="{Binding ServerHint}" FontSize="11" Opacity="0.75" TextWrapping="Wrap"
                                           FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" />
                    </Border>
                  </StackPanel>
                  <!-- Auto-saves on change. -->
                  <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12"
                             TextWrapping="Wrap" />
                  <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="{l:Tr Main_ImportExportLabel}" />
                    <WrapPanel>
                      <Button Classes="softbtn" Content="{l:Tr Main_CopyButton}" Margin="0,0,6,6"
                              Click="OnWsExportCopy" ToolTip.Tip="{l:Tr Main_WsCopyTooltip}" />
                      <Button Classes="softbtn" Content="{l:Tr Main_SaveToFileButton}" Margin="0,0,6,6" Click="OnWsExportSave" />
                      <Button Classes="softbtn" Content="{l:Tr Main_PasteButton}" Margin="0,0,6,6"
                              Click="OnWsImportPaste" ToolTip.Tip="{l:Tr Main_WsPasteTooltip}" />
                      <Button Classes="softbtn" Content="{l:Tr Main_LoadFileButton}" Margin="0,0,6,6" Click="OnWsImportFile" />
                    </WrapPanel>
                  </StackPanel>
                </StackPanel>

                <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />

                <StackPanel Spacing="10">
                  <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                             Text="{l:Tr Main_DeleteConfigHint}" />
                  <Button Classes="danger" Content="{l:Tr Main_DeleteConfigButton}" HorizontalAlignment="Left"
                          Command="{Binding DeleteOpenConfigCommand}" />
                  <TextBlock Text="{Binding ConfigDeleteStatus}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
              </StackPanel>
            </Grid>

            <!-- ROUTING SECTION -->
            <StackPanel IsVisible="{Binding IsSettingsRouting}" Spacing="14">
              <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_RoutingSection}" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                        Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding RoutingLists.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
                </Border>
                <Button Grid.Column="3" Classes="softbtn" Command="{Binding CreateRoutingListCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="+" />
                    <TextBlock Text="{l:Tr Main_NewListButton}" />
                  </StackPanel>
                </Button>
              </Grid>

              <StackPanel Spacing="6">
                <TextBlock Classes="label" Text="{l:Tr Main_ChooseListLabel}" />
                <ComboBox Classes="field" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding RoutingCatalogueOptions}"
                          SelectedItem="{Binding SelectedCatalogueRouting, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoutingListChoice">
                      <!-- «- не выбрано -» for the none sentinel. -->
                      <Panel>
                        <TextBlock Text="{l:Tr Main_NotSelected}" IsVisible="{Binding IsNone}" />
                        <TextBlock Text="{Binding Name}" IsVisible="{Binding !IsNone}" />
                      </Panel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock IsVisible="{Binding !HasRoutingLists}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                           Text="{l:Tr Main_NoRoutingListsHint}" />
              </StackPanel>

              <!-- Rule editor for the selected/new list. -->
              <StackPanel IsVisible="{Binding HasRoutingEditor}" Spacing="12">
                <Border Background="Transparent"
                        BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                        CornerRadius="9" Padding="12">
                  <StackPanel Spacing="12" DataContext="{Binding RoutingEditor}" x:DataType="vm:RoutingListEditorViewModel">
                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="{l:Tr Main_ListNameLabel}" />
                      <TextBox Classes="field" Classes.invalid="{Binding IsNameMissing}"
                               Text="{Binding Name, Mode=TwoWay}" Watermark="{l:Tr Main_ListNameWatermark}" />
                      <TextBlock Classes="fieldwarn" IsVisible="{Binding IsNameMissing}"
                                 Text="{l:Tr Main_RequiredEmptyWarning}" />
                    </StackPanel>

                    <!-- Per-app tunneling. -->
                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="{l:Tr Main_PerAppRoutingLabel}" />
                      <Grid ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0" Classes="softbtn" Margin="0,0,8,0" Content="{l:Tr Main_SourceDropdown}">
                          <Button.Flyout>
                            <MenuFlyout>
                              <MenuItem Header="{l:Tr Main_AppSourceRunning}" Click="OnAppSourceRunning" />
                              <MenuItem Header="{l:Tr Main_AppSourceInstalled}" Click="OnAppSourceInstalled" />
                              <MenuItem Header="{l:Tr Main_AppSourceFolder}" Click="OnAppSourceFolder" />
                              <MenuItem Header="{l:Tr Main_AppSourceFile}" Click="OnAppSourceFile" />
                            </MenuFlyout>
                          </Button.Flyout>
                        </Button>
                        <AutoCompleteBox Grid.Column="1" Margin="0,0,8,0"
                                         Watermark="{Binding AppWatermark}"
                                         Text="{Binding AppInput, Mode=TwoWay}"
                                         SelectedItem="{Binding AppSelected, Mode=TwoWay}"
                                         ItemsSource="{Binding AppSuggestions}"
                                         FilterMode="ContainsOrdinal" MaxDropDownHeight="220"
                                         IsEnabled="{Binding IsAppPickerActive}" />
                        <Button Grid.Column="2" Classes="accent" Command="{Binding AddAppCommand}"
                                IsEnabled="{Binding IsAppPickerActive}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="+" />
                            <TextBlock Text="{l:Tr Main_AddButton}" />
                          </StackPanel>
                        </Button>
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="{l:Tr Main_AddEntryLabel}" />
                      <Grid ColumnDefinitions="*,Auto">
                        <AutoCompleteBox Grid.Column="0" Margin="0,0,8,0"
                                         Watermark="{l:Tr Main_AddEntryWatermark}"
                                         Text="{Binding RuleInput, Mode=TwoWay}"
                                         ItemsSource="{Binding GeoSuggestions}"
                                         FilterMode="ContainsOrdinal" MaxDropDownHeight="220" />
                        <Button Grid.Column="1" Classes="accent" Command="{Binding AddRuleCommand}">
                          <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="+" />
                            <TextBlock Text="{l:Tr Main_AddButton}" />
                          </StackPanel>
                        </Button>
                      </Grid>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap" />

                    <StackPanel Spacing="6" IsVisible="{Binding Rules.Count}">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Classes="label" Text="{l:Tr Main_EntriesLabel}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Classes="icon" Content="{l:Tr Main_ClearButton}" FontSize="11"
                                Command="{Binding ClearRulesCommand}"
                                ToolTip.Tip="{l:Tr Main_ClearRulesTooltip}" />
                      </Grid>
                      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                              Background="{DynamicResource AgPanelBrush}" CornerRadius="10">
                        <ItemsControl ItemsSource="{Binding Rules}" Margin="8,8">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                              <Border Background="{DynamicResource AgInsetBrush}"
                                      BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                      CornerRadius="8" Padding="10,7" Margin="0,3">
                                <Grid ColumnDefinitions="*,Auto">
                                  <TextBlock Grid.Column="0" Text="{Binding}" Classes="mono" FontSize="12.5"
                                             VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                  <Button Grid.Column="1" Classes="icon" Content="✕"
                                          Command="{Binding $parent[ItemsControl].((vm:RoutingListEditorViewModel)DataContext).RemoveRuleCommand}"
                                          CommandParameter="{Binding}" />
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Border>
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="{l:Tr Main_ImportExportLabel}" />
                      <WrapPanel>
                        <Button Classes="softbtn" Content="{l:Tr Main_CopyButton}" Margin="0,0,6,6"
                                Click="OnRoutingExportCopy" ToolTip.Tip="{l:Tr Main_RoutingCopyTooltip}" />
                        <Button Classes="softbtn" Content="{l:Tr Main_SaveToFileButton}" Margin="0,0,6,6"
                                Click="OnRoutingExportSave" />
                        <Button Classes="softbtn" Content="{l:Tr Main_ShowQrButton}" Margin="0,0,6,6"
                                Click="OnRoutingShowQr" ToolTip.Tip="{l:Tr Main_ShowQrTooltip}" />
                        <Button Classes="softbtn" Content="{l:Tr Main_PasteButton}" Margin="0,0,6,6"
                                Click="OnRoutingImportPaste" ToolTip.Tip="{l:Tr Main_RoutingPasteTooltip}" />
                        <Button Classes="softbtn" Content="{l:Tr Main_LoadFileButton}" Margin="0,0,6,6"
                                Click="OnRoutingImportFile" />
                      </WrapPanel>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Per-routing traffic settings: local DNS + exclusions + all-UDP. -->
                <Border Background="Transparent"
                        BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                        CornerRadius="9" Padding="12" IsVisible="{Binding RoutingSettings, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <StackPanel Spacing="12" DataContext="{Binding RoutingSettings}" x:DataType="vm:RoutingSettingsViewModel">
                    <TextBlock Classes="label" Text="{l:Tr Main_ListTrafficLabel}" />

                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="DNS" />
                      <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                                 Text="{l:Tr Main_DnsHint}" />
                      <TextBox Classes="field" Text="{Binding LocalDns, Mode=TwoWay}"
                               Watermark="{l:Tr Main_DnsWatermark}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                      <TextBlock Classes="label" Text="{l:Tr Main_ExclusionsLabel}" />
                      <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                                 Text="{l:Tr Main_ExclusionsHint}" />
                      <Button Classes="softbtn" HorizontalAlignment="Left" Content="{l:Tr Main_AddLocalSubnetsButton}"
                              Command="{Binding AddLocalSubnetsCommand}" IsEnabled="{Binding !IsBusy}" />
                      <TextBox Classes="field" AcceptsReturn="True" TextWrapping="NoWrap" Height="110"
                               VerticalContentAlignment="Top"
                               ScrollViewer.VerticalScrollBarVisibility="Auto"
                               FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12"
                               Text="{Binding Exclusions, Mode=TwoWay}"
                               Watermark="corp.local&#x0a;nas&#x0a;10.50.0.0/16&#x0a;192.168.10.5" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                        <TextBlock Text="{l:Tr Main_AllUdpTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_AllUdpHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                      </StackPanel>
                      <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AllUdp, Mode=TwoWay}" />
                    </Grid>

                    <!-- Auto-saves on change. -->
                    <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Border>

                <Button Classes="danger" HorizontalAlignment="Left"
                        IsVisible="{Binding !RoutingEditor.IsNew}"
                        Command="{Binding DeleteSectionRoutingListCommand}" Content="{l:Tr Main_DeleteListButton}" />
              </StackPanel>
            </StackPanel>

            <!-- SOURCES SECTION -->
            <StackPanel IsVisible="{Binding IsSettingsSources}">
              <Border Classes="subcard" Margin="0">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="{l:Tr Main_SourcesSection}" Classes="section" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Classes="softbtn" Command="{Binding CheckSourcesCommand}" Content="{l:Tr Main_CheckUpdatesButton}" />
                        <Button Classes="softbtn" Command="{Binding UpdateSourcesCommand}" Content="{l:Tr Main_UpdateAllButton}" />
                      </StackPanel>
                    </Grid>
                  </Border>

                  <StackPanel Margin="15,12" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                        <TextBlock Text="{l:Tr Main_AutoCheckTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_AutoCheckHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <ComboBox Classes="field" Width="92" VerticalAlignment="Center"
                                  IsEnabled="{Binding GeoAutoCheck}"
                                  ItemsSource="{Binding GeoCheckIntervals}"
                                  SelectedItem="{Binding GeoCheckIntervalHours, Mode=TwoWay}">
                          <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="x:Int32">
                              <TextBlock Text="{Binding Converter={x:Static l:HoursConverter.Instance}}" />
                            </DataTemplate>
                          </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ToggleSwitch VerticalAlignment="Center" IsChecked="{Binding GeoAutoCheck, Mode=TwoWay}" />
                      </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                        <TextBlock Text="{l:Tr Main_CacheValidityTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_CacheValidityHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                      </StackPanel>
                      <ComboBox Grid.Column="1" Classes="field" Width="92" VerticalAlignment="Center"
                                ItemsSource="{Binding GeoCacheValidities}"
                                SelectedItem="{Binding GeoCacheValidityHours, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                          <DataTemplate x:DataType="x:Int32">
                            <TextBlock Text="{Binding Converter={x:Static l:HoursConverter.Instance}}" />
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                    </Grid>
                    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />

                    <TextBlock Classes="label" Text="{l:Tr Main_AddDatabaseLabel}" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <ComboBox Grid.Column="0" Classes="field" Width="118" Margin="0,0,8,0"
                                ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                                IsEnabled="{Binding !SourceKindLocked}"
                                ToolTip.Tip="{l:Tr Main_SourceKindTooltip}" />
                      <TextBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                               Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
                      <Button Grid.Column="2" Classes="accent" Command="{Binding AddSourceCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="+" />
                          <TextBlock Text="{l:Tr Main_AddButton}" />
                        </StackPanel>
                      </Button>
                    </Grid>
                    <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                               Text="{l:Tr Main_GeoKindsHint}" />

                    <TextBlock Classes="label" Text="{l:Tr Main_SourcesLabel}" Margin="0,6,0,0" />
                    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            Background="{DynamicResource AgInsetBrush}" CornerRadius="12">
                      <StackPanel Margin="10,10">
                        <ItemsControl ItemsSource="{Binding Sources}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SourceItemViewModel">
                              <Border Background="{DynamicResource AgPanelBrush}"
                                      BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                      CornerRadius="9" Padding="11,9" Margin="0,3"
                                      ContextRequested="OnSourceRowContext"
                                      ToolTip.Tip="{l:Tr Main_SourceRowTooltip}">
                                <Grid ColumnDefinitions="*,Auto">
                                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Classes="srctitle" Text="{Binding Detail}" FontSize="12.5" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Url}" FontSize="11" Classes="muted mono"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{l:Tr Main_UpdateAvailableBadge}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AgAccentBrush}" Margin="0,3,0,0"
                                               IsVisible="{Binding ShowUpdateBadge}" />
                                  </StackPanel>
                                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                              VerticalAlignment="Center" Margin="8,0,0,0">
                                    <Button Classes="icon" VerticalAlignment="Center"
                                            Command="{Binding UpdateCommand}" IsEnabled="{Binding !Updating}"
                                            ToolTip.Tip="{l:Tr Main_UpdateDatabaseTooltip}">
                                      <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ProgressText}" IsVisible="{Binding ShowProgress}"
                                                   FontSize="11.5" VerticalAlignment="Center" />
                                        <PathIcon Classes.spin="{Binding Updating}" Data="{DynamicResource AgRefreshGeometry}"
                                                  Width="14" Height="14" />
                                      </StackPanel>
                                    </Button>
                                    <Button Classes="icon" VerticalAlignment="Center"
                                            Click="OnSourceKebab" ToolTip.Tip="{l:Tr Main_ActionsTooltip}">
                                      <TextBlock Text="⋮" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                    </Button>
                                  </StackPanel>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock IsVisible="{Binding !HasSources}"
                                   Text="{l:Tr Main_NoSourcesHint}"
                                   Classes="muted" FontSize="12" Margin="2,8" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- LOGS SECTION -->
            <StackPanel IsVisible="{Binding IsSettingsLogs}">
              <Border Classes="subcard" Margin="0">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,9">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Grid.Column="0" Text="{l:Tr Main_AgentLogSection}" Classes="section" VerticalAlignment="Center" />
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{l:Tr Main_LevelLabel}" Classes="muted" FontSize="11.5" VerticalAlignment="Center" />
                        <ComboBox SelectedIndex="{Binding LogSeverity, Mode=TwoWay}" MinWidth="150">
                          <ComboBoxItem Content="{l:Tr Main_LogSeverityAll}" />
                          <ComboBoxItem Content="{l:Tr Main_LogSeverityInfo}" />
                          <ComboBoxItem Content="{l:Tr Main_LogSeverityWarn}" />
                          <ComboBoxItem Content="{l:Tr Main_LogSeverityError}" />
                        </ComboBox>
                      </StackPanel>
                    </Grid>
                  </Border>
                  <!-- Capture verbosity: minimum level WRITTEN to the log; applies live. -->
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{l:Tr Main_LogVerbosityTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_LogVerbosityHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left" />
                      </StackPanel>
                      <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="150"
                                ItemsSource="{Binding LogLevels}"
                                SelectedItem="{Binding LogLevelLabel, Mode=TwoWay}" />
                    </Grid>
                  </Border>
                  <!-- Routing log: toggleable log of route changes and DNS resolutions. -->
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{l:Tr Main_RouteLogTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_RouteLogHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left" />
                      </StackPanel>
                      <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding RouteLogEnabled, Mode=TwoWay}" />
                    </Grid>
                  </Border>
                  <!-- Support export: redacted diagnostics zip. -->
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="{l:Tr Main_SupportLogsTitle}" FontSize="13.5" />
                        <TextBlock Text="{l:Tr Main_SupportLogsHint}"
                                   Classes="muted" FontSize="11.5" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left" />
                      </StackPanel>
                      <Button Grid.Column="1" Classes="softbtn" VerticalAlignment="Center"
                              Content="{l:Tr Main_CollectLogsButton}" Click="OnCollectLogs" />
                    </Grid>
                  </Border>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                          Background="{DynamicResource AgInsetBrush}" Margin="15,12,15,15"
                          CornerRadius="12" MaxHeight="520">
                    <Panel>
                      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <SelectableTextBlock Text="{Binding LogText}" IsVisible="{Binding HasLogs}"
                                             FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace"
                                             FontSize="11.5" LineHeight="18"
                                             Foreground="{DynamicResource AgMutedBrush}"
                                             TextWrapping="Wrap" Margin="16,13" />
                      </ScrollViewer>
                      <TextBlock IsVisible="{Binding !HasLogs}" Classes="muted" FontSize="12"
                                 Text="{l:Tr Main_LogEmptyHint}"
                                 Margin="18,15" VerticalAlignment="Top" />
                    </Panel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- GENERAL SECTION (+ About) -->
            <StackPanel IsVisible="{Binding IsSettingsGeneral}" Spacing="14">
              <Border Classes="subcard" Margin="0">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="{l:Tr General_Section}" Classes="section" />
                  </Border>

                  <!-- Theme -->
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="{l:Tr General_Theme}" FontSize="13.5" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="softbtn" Content="{Binding ThemeLabel}" Command="{Binding ToggleThemeCommand}" />
                  </Grid>

                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />

                  <!-- Language: live switch. -->
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="{l:Tr General_Language}" FontSize="13.5" VerticalAlignment="Center" />
                    <ComboBox Grid.Column="1" MinWidth="150" VerticalAlignment="Center"
                              ItemsSource="{Binding Languages}"
                              SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}" />
                  </Grid>
                </StackPanel>
              </Border>

              <!-- About folded into General. -->
              <Border Classes="subcard" Margin="0">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="{l:Tr About_Section}" Classes="section" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="{l:Tr About_Version}" FontSize="13.5" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding AppVersion}" Classes="muted mono" FontSize="12.5" VerticalAlignment="Center" />
                  </Grid>

                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="{l:Tr Main_AmneziaEngineVersion}" FontSize="13.5" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding AmneziaVersion}" Classes="muted mono" FontSize="12.5" VerticalAlignment="Center" />
                  </Grid>

                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" Padding="15,12"
                          IsVisible="{Binding HasUpdateUrl}">
                    <StackPanel Spacing="9">
                      <TextBlock Text="{l:Tr Main_UpdateSection}" Classes="section" />
                      <Button Classes="softbtn" HorizontalAlignment="Left" Content="{l:Tr Main_CheckUpdatesButton}"
                              Command="{Binding CheckUpdateCommand}" />
                      <TextBlock Text="{Binding UpdateStatus}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
                      <StackPanel Spacing="6" IsVisible="{Binding UpdateAvailable}">
                        <TextBlock Text="{Binding UpdateVersionBadgeText}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding UpdateDescription}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                          <Button Classes="accent" Content="{l:Tr Main_DownloadAndInstallButton}" Command="{Binding InstallUpdateCommand}"
                                  IsEnabled="{Binding !UpdateDownloading}" />
                          <TextBlock Text="{Binding UpdateDownloadPercent, StringFormat='{}{0}%'}" Classes="muted"
                                     FontSize="12" VerticalAlignment="Center" IsVisible="{Binding UpdateDownloading}" />
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <!-- Selective export/import: portable JSON bundle of profiles, configs, routing lists. -->
              <Border Classes="subcard" Margin="0">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="{l:Tr Main_ImportExportSection}" Classes="section" />
                  </Border>
                  <StackPanel Margin="15,11" Spacing="10">
                    <TextBlock Classes="muted" FontSize="12.5" TextWrapping="Wrap"
                               Text="{l:Tr Main_BundleHint}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Button Classes="softbtn" Content="{l:Tr Main_ExportButton}" Click="OnOpenBundleExport" />
                      <Button Classes="softbtn" Content="{l:Tr Main_ImportButton}" Click="OnOpenBundleImport" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>

          </Grid>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- Floating notification toasts (reconnect notice, app update, geo update). -->
    <StackPanel ZIndex="50" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="12,24,12,0" MaxWidth="560" Spacing="6">

      <Border IsVisible="{Binding NoticeVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding NoticeText}" Foreground="White"
                     FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="radiopick" Command="{Binding DismissNoticeCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="9,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_CloseTooltip}" />
        </Grid>
      </Border>

      <Border IsVisible="{Binding UpdateBannerVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding UpdateBannerText}"
                     Foreground="White" FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="radiopick" Command="{Binding InstallUpdateCommand}"
                  Content="{l:Tr Main_UpdateButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                  Margin="10,0,0,0" VerticalAlignment="Center" />
          <Button Grid.Column="3" Classes="radiopick" Command="{Binding DismissUpdateBannerCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="6,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_CloseTooltip}" />
        </Grid>
      </Border>

      <Border IsVisible="{Binding GeoUpdateBannerVisible}"
              Background="{DynamicResource AgAccentBrush}"
              CornerRadius="8" Padding="12,7" BoxShadow="0 6 18 0 #2A000000">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Top" Margin="0,5,9,0" />
          <TextBlock Grid.Column="1" Text="{Binding GeoUpdateBannerText}"
                     Foreground="White" FontSize="12" FontWeight="SemiBold"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="radiopick" Command="{Binding UpdateGeoNowCommand}"
                  Content="{l:Tr Main_UpdateNowButton}" Foreground="White" FontSize="12" FontWeight="SemiBold"
                  Margin="10,0,0,0" VerticalAlignment="Center" />
          <Button Grid.Column="3" Classes="radiopick" Command="{Binding DismissGeoUpdateBannerCommand}"
                  Content="✕" Foreground="White" FontSize="12" Margin="6,0,0,0"
                  VerticalAlignment="Top" ToolTip.Tip="{l:Tr Main_GeoDismissTooltip}" />
        </Grid>
      </Border>

    </StackPanel>

  </Grid>
</Window>
