<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.SourcesView"
             x:CompileBindings="True"
             x:DataType="vm:SourcesViewModel">
  <StackPanel Spacing="14">
    <!-- Header: section title + count pill + bulk actions. -->
    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
      <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_SourcesSection}" VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
              Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Sources.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
      </Border>
      <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
        <Button Classes="methodpick" Width="170" Padding="18,6"
                Command="{Binding CheckSourcesCommand}" Content="{l:Tr Main_CheckUpdatesButton}" />
        <Button Classes="methodpick" Width="170" Padding="18,6"
                Command="{Binding UpdateSourcesCommand}" Content="{l:Tr Main_UpdateAllButton}" />
      </StackPanel>
    </Grid>

    <!-- Auto-update card. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
          <TextBlock Text="{l:Tr Main_AutoCheckTitle}" FontWeight="SemiBold" FontSize="15" />
          <TextBlock Text="{l:Tr Main_AutoCheckHint}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <ComboBox Classes="field" Width="92" VerticalAlignment="Center"
                    IsEnabled="{Binding GeoAutoCheck}"
                    ItemsSource="{Binding GeoCheckIntervals}"
                    SelectedItem="{Binding GeoCheckIntervalHours, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="x:Int32">
                <TextBlock Text="{Binding Converter={x:Static l:HoursConverter.Instance}}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <ToggleSwitch VerticalAlignment="Center" IsChecked="{Binding GeoAutoCheck, Mode=TwoWay}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Add-database card. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="10">
        <TextBlock Text="{l:Tr Main_AddDatabaseLabel}" FontWeight="SemiBold" FontSize="15" />
        <Grid ColumnDefinitions="Auto,*,Auto">
          <ComboBox Grid.Column="0" Classes="field" Width="100" Margin="0,0,8,0"
                    ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                    IsEnabled="{Binding !SourceKindLocked}"
                    ToolTip.Tip="{l:Tr Main_SourceKindTooltip}" />
          <TextBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                   Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
          <Button Grid.Column="2" Classes="accent" Width="130" Command="{Binding AddSourceCommand}">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="+" />
              <TextBlock Text="{l:Tr Main_AddButton}" />
            </StackPanel>
          </Button>
        </Grid>
        <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap" Text="{l:Tr Main_GeoKindsHint}" />
      </StackPanel>
    </Border>

    <!-- Sources list card. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="16" Background="Transparent">
      <StackPanel Spacing="10">
        <TextBlock Text="{l:Tr Main_SourcesLabel}" FontWeight="SemiBold" FontSize="15" />
        <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                Background="{DynamicResource AgInsetBrush}" CornerRadius="10"
                IsVisible="{Binding HasSources}">
          <ItemsControl ItemsSource="{Binding Sources}" Margin="10,10">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SourceItemViewModel">
                <Border Background="{DynamicResource AgPanelBrush}"
                        BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                        CornerRadius="9" Padding="11,9" Margin="0,3"
                        ContextRequested="OnSourceRowContext"
                        DoubleTapped="OnSourceRowDoubleTapped"
                        ToolTip.Tip="{l:Tr Main_SourceRowTooltip}">
                  <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding !IsEditing}">
                      <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Classes="srctitle" Text="{Binding Detail}" FontSize="12.5" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Url}" FontSize="11" Classes="muted mono"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{l:Tr Main_UpdateAvailableBadge}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AgAccentBrush}" Margin="0,3,0,0"
                                   IsVisible="{Binding ShowUpdateBadge}" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2"
                                  VerticalAlignment="Center" Margin="8,0,0,0">
                        <Button Classes="icon" VerticalAlignment="Center"
                                Command="{Binding UpdateCommand}" IsEnabled="{Binding !Updating}"
                                ToolTip.Tip="{l:Tr Main_UpdateDatabaseTooltip}">
                          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ProgressText}" IsVisible="{Binding ShowProgress}"
                                       FontSize="11.5" VerticalAlignment="Center" />
                            <PathIcon Classes.spin="{Binding Updating}" Data="{DynamicResource AgRefreshGeometry}"
                                      Width="14" Height="14" />
                          </StackPanel>
                        </Button>
                        <Button Classes="icon" VerticalAlignment="Center"
                                Click="OnSourceKebab" ToolTip.Tip="{l:Tr Main_ActionsTooltip}">
                          <TextBlock Text="⋮" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                        </Button>
                      </StackPanel>
                    </Grid>
                    <StackPanel IsVisible="{Binding IsEditing}" Spacing="6">
                      <Grid ColumnDefinitions="Auto,*">
                        <ComboBox Grid.Column="0" Classes="field" Width="100" Margin="0,0,8,0"
                                  ItemsSource="{Binding Kinds}" SelectedItem="{Binding EditKind, Mode=TwoWay}" />
                        <TextBox Grid.Column="1" Classes="field"
                                 Text="{Binding EditUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
                      </Grid>
                      <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                        <Button Classes="accent" Width="100" Content="{l:Tr Main_SaveButton}" Command="{Binding SaveEditCommand}" />
                        <Button Classes="methodpick" Width="100" Content="{l:Tr Main_CancelButton}" Command="{Binding CancelEditCommand}" />
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Border>
        <TextBlock IsVisible="{Binding !HasSources}"
                   Text="{l:Tr Main_NoSourcesHint}"
                   Classes="muted" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
