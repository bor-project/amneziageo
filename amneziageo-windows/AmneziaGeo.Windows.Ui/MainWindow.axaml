<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:AmneziaGeo.Windows.Ui.Services"
        x:Class="AmneziaGeo.Windows.Ui.MainWindow"
        Title="AmneziaGeo"
        Width="1180" Height="760"
        MinWidth="900" MinHeight="560"
        Background="{DynamicResource AgBgBrush}"
        FontFamily="IBM Plex Sans, Segoe UI, sans-serif"
        Foreground="{DynamicResource AgFgBrush}">

  <Window.Resources>
    <!-- "sync" glyph (two circular arrows): the per-source refresh / update icon. -->
    <StreamGeometry x:Key="AgRefreshGeometry">M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z</StreamGeometry>
    <!-- "power" glyph (broken ring + top bar): the large connection control's centre icon. -->
    <StreamGeometry x:Key="AgPowerGeometry">M13 3h-2v10h2V3zm4.83 2.17l-1.42 1.42C17.99 7.86 19 9.81 19 12c0 3.87-3.13 7-7 7s-7-3.13-7-7c0-2.19 1.01-4.14 2.58-5.42L6.17 5.17C4.23 6.82 3 9.26 3 12c0 4.97 4.03 9 9 9s9-4.03 9-9c0-2.74-1.23-5.18-3.17-6.83z</StreamGeometry>
    <!-- "gear" glyph: the Settings button icon in the left header. -->
    <StreamGeometry x:Key="AgGearGeometry">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</StreamGeometry>
  </Window.Resources>


  <Grid>
  <DockPanel LastChildFill="True">

    <!-- BODY : single uniform gutter colour (no separate-coloured container around the right card). -->
    <Grid ColumnDefinitions="Auto,*" Background="{DynamicResource AgSidebarBrush}">

      <!-- LEFT SIDEBAR (always visible; its content swaps per tab — profiles / routing / settings).
           Narrower now that it holds only lists (the editors moved to the right pane); 340 keeps the
           3-segment nav ("Маршрутизация" at 11px) from clipping. -->
      <DockPanel Grid.Column="0" Width="340"
                 Background="{DynamicResource AgSidebarBrush}" LastChildFill="True">

        <!-- one left card mirroring the right one: the nav is its header bar (white + bottom divider),
             and the per-tab content fills below -->
        <Border Classes="card" Margin="12,12,0,12" Padding="0">
        <DockPanel LastChildFill="True">

          <Border DockPanel.Dock="Top" Height="52" Padding="14,0"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1">
            <Panel>
              <!-- profiles mode: brand + a gear that opens Settings (the old segmented nav is gone) -->
              <Grid IsVisible="{Binding !IsSettings}" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <TextBlock Grid.Column="0" Text="AmneziaGeo" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="icon" Padding="6,4"
                        Command="{Binding NavSettingsCommand}" ToolTip.Tip="Настройки">
                  <PathIcon Data="{DynamicResource AgGearGeometry}" Width="18" Height="18"
                            Foreground="{DynamicResource AgMutedBrush}" />
                </Button>
              </Grid>
              <!-- settings mode: a back control returns to the profiles view -->
              <Button IsVisible="{Binding IsSettings}" Classes="backbtn" HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Command="{Binding NavHomeCommand}" ToolTip.Tip="К профилям">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
                  <TextBlock Text="Настройки" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
              </Button>
            </Panel>
          </Border>

        <Grid>

        <!-- Profiles (Home tab): master-detail — the profiles list, or the open profile's aspect rail -->
        <Panel IsVisible="{Binding IsHome}">

            <!-- profiles list (nothing open): click a row to open it; the filled circle marks the active one -->
            <DockPanel IsVisible="{Binding IsProfileList}" LastChildFill="True">
              <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,Auto,*,Auto" Margin="14,11,14,8">
                <TextBlock Grid.Column="0" Classes="section" Text="ПРОФИЛИ" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                        Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding Balancers.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
                </Border>
                <Button Grid.Column="3" Classes="softbtn" Command="{Binding CreateProfileCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="+" />
                    <TextBlock Text="Профиль" />
                  </StackPanel>
                </Button>
              </Grid>

              <ScrollViewer>
                <StackPanel Margin="12,2,12,12">
                  <ItemsControl ItemsSource="{Binding Balancers}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <!-- the whole row opens the profile; the filled dot shows the active one -->
                        <Button Classes="rowselect" Classes.active="{Binding IsActive}" Margin="0,3"
                                Command="{Binding $parent[ItemsControl].DataContext.OpenProfileDetailCommand}"
                                CommandParameter="{Binding}">
                          <Grid ColumnDefinitions="Auto,*,Auto" Margin="10,6,12,6">
                            <!-- the dot activates the profile (one click); the rest of the row opens it.
                                 A nested button: Avalonia marks its press handled, so the row's
                                 OpenProfileDetail does not also fire. -->
                            <Button Grid.Column="0" Classes="radiopick" VerticalAlignment="Center"
                                    Command="{Binding SelectCommand}"
                                    ToolTip.Tip="Сделать активным профилем">
                              <Grid Width="18" Height="18">
                                <Ellipse Width="16" Height="16" StrokeThickness="2"
                                         Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Ellipse Width="16" Height="16" StrokeThickness="2"
                                         Stroke="{DynamicResource AgAccentBrush}" Fill="Transparent"
                                         IsVisible="{Binding IsActive}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                                         IsVisible="{Binding IsActive}"
                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                              </Grid>
                            </Button>
                            <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                              <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5" />
                              <TextBlock Text="{Binding Detail}" FontSize="11.5" Classes="muted"
                                         TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="▶" Classes="muted" FontSize="11"
                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                          </Grid>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <TextBlock IsVisible="{Binding !HasBalancers}"
                             Text="Нет профилей. Нажмите «+ Профиль»."
                             Classes="muted" FontSize="12" Margin="6,12" TextWrapping="Wrap" />
                </StackPanel>
              </ScrollViewer>
            </DockPanel>

            <!-- open profile: its aspect rail (Конфигурация / Маршрутизация / Балансировщик / Название) -->
            <DockPanel IsVisible="{Binding IsProfileDetail}" LastChildFill="True">
              <!-- the open profile's name (the back-to-list navigation now lives in the right pane header) -->
              <StackPanel DockPanel.Dock="Top" Margin="14,11,14,8">
                <TextBlock Classes="section" Text="ПРОФИЛЬ" />
                <TextBlock Text="{Binding OpenProfileName}" FontWeight="SemiBold" FontSize="14"
                           Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
              </StackPanel>

              <StackPanel Margin="12,2,12,12">
                <Button Classes="rowselect" Classes.active="{Binding IsAspectConfig}" Margin="0,3"
                        Command="{Binding SelectProfileAspectCommand}" CommandParameter="config">
                  <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                    <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                      <Ellipse Width="16" Height="16" StrokeThickness="2"
                               Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                               IsVisible="{Binding IsAspectConfig}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="Конфигурация" FontWeight="SemiBold" FontSize="13.5" />
                      <TextBlock Text="Серверы профиля" FontSize="11.5" Classes="muted"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>
                </Button>
                <Button Classes="rowselect" Classes.active="{Binding IsAspectRouting}" Margin="0,3"
                        Command="{Binding SelectProfileAspectCommand}" CommandParameter="routing">
                  <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                    <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                      <Ellipse Width="16" Height="16" StrokeThickness="2"
                               Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                               IsVisible="{Binding IsAspectRouting}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="Маршрутизация" FontWeight="SemiBold" FontSize="13.5" />
                      <TextBlock Text="Какой трафик в туннель" FontSize="11.5" Classes="muted"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>
                </Button>
                <Button Classes="rowselect" Classes.active="{Binding IsAspectBalancer}" Margin="0,3"
                        Command="{Binding SelectProfileAspectCommand}" CommandParameter="balancer">
                  <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                    <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                      <Ellipse Width="16" Height="16" StrokeThickness="2"
                               Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                               IsVisible="{Binding IsAspectBalancer}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="Балансировщик" FontWeight="SemiBold" FontSize="13.5" />
                      <TextBlock Text="Переключение серверов" FontSize="11.5" Classes="muted"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>
                </Button>
                <Button Classes="rowselect" Classes.active="{Binding IsAspectName}" Margin="0,3"
                        Command="{Binding SelectProfileAspectCommand}" CommandParameter="name">
                  <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                    <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                      <Ellipse Width="16" Height="16" StrokeThickness="2"
                               Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                               IsVisible="{Binding IsAspectName}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                      <TextBlock Text="Название" FontWeight="SemiBold" FontSize="13.5" />
                      <TextBlock Text="Имя профиля" FontSize="11.5" Classes="muted"
                                 TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                  </Grid>
                </Button>
              </StackPanel>
            </DockPanel>

        </Panel>

        <!-- The former top-level Routing panel is gone: its rule-lists moved into each profile's
             Маршрутизация aspect, and its geo-data sources moved into Settings. -->


        <!-- Settings sections (Settings tab): a radio list mirroring the routing rail -->
        <DockPanel IsVisible="{Binding IsSettings}" LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Classes="section" Text="НАСТРОЙКИ" Margin="14,11,14,8" />
            <StackPanel Margin="12,2,12,12">
              <Button Classes="rowselect" Classes.active="{Binding IsSettingsGeneral}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="general">
                <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsGeneral}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Общие" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="Тема и язык интерфейса" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsSecurity}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="security">
                <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsSecurity}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Безопасность" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="Kill-switch и локальная сеть" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsSources}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="sources">
                <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsSources}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Источники данных" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="Базы geosite и geoip" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsLogs}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="logs">
                <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsLogs}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Логи" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="Журнал работы агента" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>

              <Button Classes="rowselect" Classes.active="{Binding IsSettingsAbout}" Margin="0,3"
                      Command="{Binding SelectSettingsCommand}" CommandParameter="about">
                <Grid ColumnDefinitions="Auto,*" Margin="12,10">
                  <Grid Grid.Column="0" Width="18" Height="18" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" StrokeThickness="2"
                             Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AgAccentBrush}"
                             IsVisible="{Binding IsSettingsAbout}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Grid>
                  <StackPanel Grid.Column="1" Margin="11,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="О приложении" FontWeight="SemiBold" FontSize="13.5" />
                    <TextBlock Text="Версия приложения" FontSize="11.5" Classes="muted"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </Grid>
              </Button>
            </StackPanel>
        </DockPanel>

        </Grid>
        </DockPanel>
        </Border>
      </DockPanel>

      <!-- RIGHT CONTENT (12px gutter on its left → consistent in both docked and full-width modes) -->
      <Border Grid.Column="1" Classes="card" Margin="12,12,12,12" Padding="0">
        <DockPanel LastChildFill="True">

          <!-- persistent header (shown on every tab): the round power control toggles the ACTIVE profile;
               the reconnect / better-connection notice sits beside it. Per-profile connect lives in each
               profile's detail. -->
          <Border DockPanel.Dock="Top" Height="52" Padding="12,0"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
              <!-- back to the previous menu (the profiles list); shown only inside a profile's detail. -->
              <Button Grid.Column="0" Classes="backbtn" HorizontalAlignment="Left" VerticalAlignment="Center"
                      IsVisible="{Binding IsProfileDetail}"
                      Command="{Binding BackToProfilesCommand}" ToolTip.Tip="К списку профилей">
                <StackPanel Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                  <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
                  <TextBlock Text="Назад" FontSize="12.5" FontWeight="Medium" VerticalAlignment="Center" />
                </StackPanel>
              </Button>

              <!-- connection control: moved to the right edge of the header. Hidden on the Home
                   profiles-list, where the large power button in the right pane takes over (this would
                   only duplicate it). -->
              <Button Grid.Column="2" Classes="powerctl" HorizontalAlignment="Right" VerticalAlignment="Center"
                      IsVisible="{Binding ShowHeaderPower}"
                      Command="{Binding ToggleConnectionCommand}"
                      IsEnabled="{Binding CanToggleConnection}">
                <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                  <Border Width="28" Height="28" CornerRadius="14"
                          Background="{Binding ConnectCircleBrush}"
                          BorderBrush="{Binding ConnectCircleBorderBrush}" BorderThickness="1">
                    <Panel>
                      <TextBlock Text="{Binding ConnectGlyph}" Foreground="{Binding ConnectCircleForeground}"
                                 FontSize="11" IsVisible="{Binding !IsConnecting}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Classes.pulse="{Binding IsConnecting}" Width="11" Height="11"
                               IsVisible="{Binding IsConnecting}" Fill="{Binding ConnectCircleForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Panel>
                  </Border>
                  <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding AgentStatusText}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AgFgBrush}" />
                    <TextBlock Text="{Binding ConnectHint}" FontSize="10"
                               Foreground="{Binding ConnectHintBrush}" />
                  </StackPanel>
                </StackPanel>
              </Button>

              <Border Grid.Column="1" IsVisible="{Binding NoticeVisible}"
                      VerticalAlignment="Center" HorizontalAlignment="Right" MaxWidth="680"
                      Margin="12,0,0,0"
                      Background="{DynamicResource AgAccentBrush}"
                      CornerRadius="8" Padding="12,5">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                  <Ellipse Grid.Column="0" Width="8" Height="8" Fill="White" VerticalAlignment="Center" Margin="0,0,9,0" />
                  <TextBlock Grid.Column="1" Text="{Binding NoticeText}" Foreground="White"
                             FontSize="12" FontWeight="SemiBold"
                             TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                  <Button Grid.Column="2" Classes="radiopick" Command="{Binding DismissNoticeCommand}"
                          Content="✕" Foreground="White" FontSize="12" Margin="9,0,0,0"
                          VerticalAlignment="Center" ToolTip.Tip="Закрыть" />
                </Grid>
              </Border>
            </Grid>
          </Border>

          <Grid>

          <!-- HOME : profile master-detail right pane — pick-a-profile hint, or the open profile's aspect.
               Each aspect's editor binds to OpenProfile (DataContext switched on the inner panel); the
               outer panel keeps the window VM so IsAspect* drives which one shows. -->
          <Panel IsVisible="{Binding IsHome}">

            <!-- profiles list: a large round power button fills the right pane (the header control is
                 hidden here so it is not duplicated). Click toggles the active profile; the rings + circle
                 colour reflect connection state. Pick a profile on the left to edit its settings. -->
            <StackPanel IsVisible="{Binding IsProfileList}"
                        HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="18">
              <Button Classes="powerbig" HorizontalAlignment="Center"
                      Command="{Binding ToggleConnectionCommand}"
                      IsEnabled="{Binding CanToggleConnection}"
                      ToolTip.Tip="{Binding ConnectHint}">
                <Grid Width="236" Height="236">
                  <Ellipse Width="236" Height="236" Stroke="{DynamicResource AgBorderBrush}"
                           StrokeThickness="1" Opacity="0.7" />
                  <Ellipse Width="196" Height="196" Stroke="{DynamicResource AgBorderBrush}"
                           StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Ellipse Width="158" Height="158" Stroke="{DynamicResource AgBorder2Brush}"
                           StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  <Border Width="132" Height="132" CornerRadius="66"
                          Background="{Binding ConnectCircleBrush}"
                          BorderBrush="{Binding ConnectCircleBorderBrush}" BorderThickness="2"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          BoxShadow="0 8 24 0 #1F000000">
                    <Panel>
                      <PathIcon Data="{DynamicResource AgPowerGeometry}" Width="54" Height="54"
                                Foreground="{Binding ConnectCircleForeground}"
                                IsVisible="{Binding !IsConnecting}"
                                HorizontalAlignment="Center" VerticalAlignment="Center" />
                      <Ellipse Classes.pulse="{Binding IsConnecting}" Width="44" Height="44"
                               IsVisible="{Binding IsConnecting}" Fill="{Binding ConnectCircleForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Panel>
                  </Border>
                </Grid>
              </Button>

              <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,4,0,0">
                <TextBlock Text="{Binding AgentStatusText}" FontSize="17" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Foreground="{Binding ConnectStatusBrush}" />
                <TextBlock Text="{Binding ConnectHint}" FontSize="12.5"
                           HorizontalAlignment="Center" Foreground="{Binding ConnectHintBrush}" />
              </StackPanel>

              <TextBlock Text="Выберите профиль слева, чтобы изменить его настройки."
                         Classes="muted" FontSize="12" Margin="0,10,0,0" MaxWidth="320"
                         HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer IsVisible="{Binding IsProfileDetail}">
              <StackPanel Margin="18,16">

                <!-- Конфигурация : the profile's member configs -->
                <StackPanel IsVisible="{Binding IsAspectConfig}">
                  <StackPanel DataContext="{Binding OpenProfile}" Spacing="8">
                    <Grid ColumnDefinitions="Auto,Auto">
                      <TextBlock Grid.Column="0" Classes="label" Text="КОНФИГУРАЦИИ" VerticalAlignment="Center" />
                      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
                              Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Members.Count}" FontSize="10.5" Classes="muted" FontWeight="SemiBold" />
                      </Border>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                      <ComboBox Grid.Column="0" Classes="field"
                                ItemsSource="{Binding AvailableConfigs}"
                                SelectedItem="{Binding AddMemberSelection, Mode=TwoWay}"
                                PlaceholderText="Выбрать..." Margin="0,0,8,0" />
                      <Button Grid.Column="1" Classes="accent"
                              Command="{Binding AddMemberCommand}"
                              IsEnabled="{Binding CanAddMember}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="+" />
                          <TextBlock Text="Добавить" />
                        </StackPanel>
                      </Button>
                    </Grid>

                    <!-- inline "new config" form: shown when the combo's "+ Новая конфигурация" is picked -->
                    <Border IsVisible="{Binding IsCreatingConfig}"
                            Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="9" Padding="10" Margin="0,2,0,0">
                      <StackPanel Spacing="6">
                        <TextBlock Classes="label" Text="НОВАЯ КОНФИГУРАЦИЯ" />
                        <TextBox Classes="field" Text="{Binding NewConfigName, Mode=TwoWay}"
                                 Watermark="Имя (необязательно)" />
                        <TextBox Classes="field" Text="{Binding NewConfigText, Mode=TwoWay}"
                                 AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                 Watermark="vpn://...   или   текст .conf" />
                        <UniformGrid Columns="4">
                          <Button Classes="softbtn" Content="Файл" Click="OnNewConfigBrowse" Margin="0,0,6,0" />
                          <Button Classes="softbtn" Content="QR" Click="OnNewConfigQrImage" Margin="0,0,6,0" />
                          <Button Classes="softbtn" Content="Камера" Click="OnNewConfigCamera" Margin="0,0,6,0" />
                          <Button Classes="softbtn" Content="Буфер" Click="OnNewConfigClipboard" />
                        </UniformGrid>
                        <TextBlock Text="{Binding NewConfigStatus}" Classes="muted" FontSize="11.5"
                                   TextWrapping="Wrap" />
                        <UniformGrid Columns="2">
                          <Button Classes="softbtn" Content="Отмена" Margin="0,0,4,0"
                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                  Command="{Binding CancelNewConfigCommand}" />
                          <Button Classes="accent" Content="Сохранить" Margin="4,0,0,0"
                                  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                  Command="{Binding SaveNewConfigCommand}" />
                        </UniformGrid>
                      </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding Members}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="{DynamicResource AgPanelBrush}"
                                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                  CornerRadius="9" Padding="9,8" Margin="0,3"
                                  ContextRequested="OnMemberRowContext"
                                  ToolTip.Tip="Радио — сделать конфигурацией по умолчанию; правый клик — экспорт / удалить">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                              <!-- the radio picks the default config (moves it to the front); the filled
                                   dot marks the current default. -->
                              <Button Grid.Column="0" Classes="radiopick" VerticalAlignment="Center"
                                      Command="{Binding $parent[ItemsControl].DataContext.SetDefaultMemberCommand}"
                                      CommandParameter="{Binding}"
                                      ToolTip.Tip="Использовать по умолчанию">
                                <Grid Width="16" Height="16">
                                  <Ellipse Width="14" Height="14" StrokeThickness="2"
                                           Stroke="{DynamicResource AgBorder2Brush}" Fill="Transparent"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                  <Ellipse Width="14" Height="14" StrokeThickness="2"
                                           Stroke="{DynamicResource AgAccentBrush}" Fill="Transparent"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse.IsVisible>
                                      <MultiBinding Converter="{x:Static svc:EqualityConverter.Instance}">
                                        <Binding />
                                        <Binding Path="$parent[ItemsControl].DataContext.DefaultMember" />
                                      </MultiBinding>
                                    </Ellipse.IsVisible>
                                  </Ellipse>
                                  <Ellipse Width="7" Height="7" Fill="{DynamicResource AgAccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse.IsVisible>
                                      <MultiBinding Converter="{x:Static svc:EqualityConverter.Instance}">
                                        <Binding />
                                        <Binding Path="$parent[ItemsControl].DataContext.DefaultMember" />
                                      </MultiBinding>
                                    </Ellipse.IsVisible>
                                  </Ellipse>
                                </Grid>
                              </Button>
                              <TextBlock Grid.Column="1" Margin="9,0,0,0" Text="{Binding}"
                                         FontSize="12.5" FontWeight="Medium"
                                         VerticalAlignment="Center"
                                         TextTrimming="CharacterEllipsis" />
                              <StackPanel Grid.Column="2" Orientation="Vertical" Spacing="0">
                                <Button Classes="icon" Content="▲"
                                        Command="{Binding $parent[ItemsControl].DataContext.MoveUpCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="8" Padding="3,0" />
                                <Button Classes="icon" Content="▼"
                                        Command="{Binding $parent[ItemsControl].DataContext.MoveDownCommand}"
                                        CommandParameter="{Binding}"
                                        FontSize="8" Padding="3,0" />
                              </StackPanel>
                              <Button Grid.Column="3" Classes="icon" Content="✕" Margin="4,0,0,0"
                                      Command="{Binding $parent[ItemsControl].DataContext.RemoveMemberCommand}"
                                      CommandParameter="{Binding}" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </StackPanel>

                <!-- Маршрутизация : the "use routing" flag + the list picker, and (relocated from the old
                     Routing tab) the selected list's rule editor inline. Picking "+ Новый список" reveals
                     a fresh editor; the catalogue stays shared across profiles. -->
                <StackPanel IsVisible="{Binding IsAspectRouting}" Spacing="14">
                  <StackPanel DataContext="{Binding OpenProfile}" Spacing="6">
                    <TextBlock Classes="label" Text="МАРШРУТИЗАЦИЯ" />
                    <Grid ColumnDefinitions="Auto,*" IsEnabled="{Binding CanToggleRouting}">
                      <ToggleSwitch Grid.Column="0" IsChecked="{Binding UseRouting, Mode=TwoWay}"
                                    OnContent="" OffContent=""
                                    MinWidth="0" />
                      <TextBlock Grid.Column="1" Margin="11,0,0,0"
                                 Text="Использовать маршрутизацию" FontSize="12.5" FontWeight="Medium"
                                 VerticalAlignment="Center" />
                    </Grid>
                    <ComboBox Classes="field" ItemsSource="{Binding RoutingListOptions}"
                              SelectedItem="{Binding SelectedRoutingList, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>

                  <!-- shared-catalogue notice (only for a real, persisted list) -->
                  <TextBlock IsVisible="{Binding HasRoutingEditor}" Classes="muted" FontSize="11.5"
                             Text="{Binding RoutingUsageHint}" TextWrapping="Wrap" />

                  <!-- inline rule editor for the selected list (bound to the window VM's RoutingEditor) -->
                  <StackPanel IsVisible="{Binding HasRoutingEditor}" Spacing="12">
                    <Border Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="9" Padding="12">
                      <StackPanel Spacing="12" DataContext="{Binding RoutingEditor}">
                        <StackPanel Spacing="6">
                          <TextBlock Classes="label" Text="ИМЯ СПИСКА" />
                          <TextBox Classes="field" Text="{Binding Name, Mode=TwoWay}" Watermark="напр. openai-route" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                          <TextBlock Classes="label" Text="ДОБАВИТЬ ЗАПИСЬ (ГЕО-КАТЕГОРИЯ, ДОМЕН ИЛИ CIDR)" />
                          <Grid ColumnDefinitions="*,Auto">
                            <AutoCompleteBox Grid.Column="0" Margin="0,0,8,0"
                                             Watermark="напр. geosite:openai, geoip:de, example.com, 1.2.3.0/24"
                                             Text="{Binding RuleInput, Mode=TwoWay}"
                                             ItemsSource="{Binding GeoSuggestions}"
                                             FilterMode="ContainsOrdinal" MaxDropDownHeight="220" />
                            <Button Grid.Column="1" Classes="accent" Command="{Binding AddRuleCommand}">
                              <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="+" />
                                <TextBlock Text="Добавить" />
                              </StackPanel>
                            </Button>
                          </Grid>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap" />

                        <StackPanel Spacing="6">
                          <TextBlock Classes="label" Text="ЗАПИСИ" />
                          <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                  Background="{DynamicResource AgPanelBrush}" CornerRadius="10">
                            <ItemsControl ItemsSource="{Binding Rules}" Margin="8,8">
                              <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                  <Border Background="{DynamicResource AgInsetBrush}"
                                          BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                          CornerRadius="8" Padding="10,7" Margin="0,3">
                                    <Grid ColumnDefinitions="*,Auto">
                                      <TextBlock Grid.Column="0" Text="{Binding}" Classes="mono" FontSize="12.5"
                                                 VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                      <Button Grid.Column="1" Classes="icon" Content="✕"
                                              Command="{Binding $parent[ItemsControl].DataContext.RemoveRuleCommand}"
                                              CommandParameter="{Binding}" />
                                    </Grid>
                                  </Border>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <Button Classes="danger" HorizontalAlignment="Left"
                            IsVisible="{Binding !RoutingEditor.IsNew}"
                            Command="{Binding DeleteRoutingListEditCommand}" Content="Удалить список" />
                  </StackPanel>
                </StackPanel>

                <!-- Балансировщик : mode + recheck interval (disabled with one config; interval only while balancing) -->
                <StackPanel IsVisible="{Binding IsAspectBalancer}">
                  <StackPanel DataContext="{Binding OpenProfile}" Spacing="9">
                    <TextBlock Classes="label" Text="БАЛАНСИРОВЩИК" />
                    <Border Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="9" Padding="3" IsEnabled="{Binding CanUseBalancer}">
                      <UniformGrid Columns="3">
                        <Button Classes="seg"
                                Classes.active="{Binding IsOffMode}"
                                Command="{Binding SetOffModeCommand}"
                                Content="Не использовать" HorizontalAlignment="Stretch" />
                        <Button Classes="seg"
                                Classes.active="{Binding IsPriorityMode}"
                                Command="{Binding SetPriorityModeCommand}"
                                Content="По приоритету" HorizontalAlignment="Stretch" />
                        <Button Classes="seg"
                                Classes.active="{Binding IsLatencyMode}"
                                Command="{Binding SetLatencyModeCommand}"
                                Content="По доступности" HorizontalAlignment="Stretch" />
                      </UniformGrid>
                    </Border>
                    <TextBlock IsVisible="{Binding !CanUseBalancer}" Classes="muted" FontSize="11.5"
                               TextWrapping="Wrap"
                               Text="Балансировщик доступен при двух и более конфигурациях." />
                    <Grid ColumnDefinitions="*,Auto,4,Auto,4,Auto" IsVisible="{Binding ShowInterval}">
                      <TextBlock Grid.Column="0" Classes="muted" FontSize="11.5"
                                 Text="Интервал проверки" VerticalAlignment="Center" />
                      <Button Grid.Column="1" Classes="chip"
                              Classes.active="{Binding IsInterval10}"
                              Command="{Binding SetInterval10Command}" Content="10с" />
                      <Button Grid.Column="3" Classes="chip"
                              Classes.active="{Binding IsInterval30}"
                              Command="{Binding SetInterval30Command}" Content="30с" />
                      <Button Grid.Column="5" Classes="chip"
                              Classes.active="{Binding IsInterval60}"
                              Command="{Binding SetInterval60Command}" Content="60с" />
                    </Grid>
                  </StackPanel>
                </StackPanel>

                <!-- Название : the profile name (read-only) + delete-profile. The delete button stays in
                     the window VM's context (the name box sets its own OpenProfile context) so it can
                     bind DeleteOpenProfileCommand. -->
                <StackPanel IsVisible="{Binding IsAspectName}" Spacing="16">
                  <StackPanel DataContext="{Binding OpenProfile}" Spacing="6">
                    <TextBlock Classes="label" Text="НАЗВАНИЕ" />
                    <TextBox Classes="field" Text="{Binding Name}" IsReadOnly="True" />
                  </StackPanel>
                  <StackPanel Spacing="6">
                    <TextBlock Classes="label" Text="УДАЛЕНИЕ" />
                    <Button Classes="danger" HorizontalAlignment="Left"
                            Command="{Binding DeleteOpenProfileCommand}"
                            Content="Удалить профиль" />
                    <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                               Text="Профиль удалится вместе со своими настройками. Запущенный профиль нужно сначала отключить." />
                  </StackPanel>
                </StackPanel>

              </StackPanel>
            </ScrollViewer>
          </Panel>

          <!-- The former top-level ROUTING right panel is gone: the rule editor now lives inline in each
               profile's Маршрутизация aspect, and the geo-data sources moved to a Settings card below. -->


          <!-- SETTINGS : the section chosen in the left rail (cards span the full pane width) -->
          <ScrollViewer IsVisible="{Binding IsSettings}">
            <StackPanel Margin="18,16">

              <Border Classes="subcard" Margin="0" IsVisible="{Binding IsSettingsGeneral}">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="ОБЩИЕ" Classes="section" />
                  </Border>

                  <!-- Theme (existing, unchanged) -->
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="Тема оформления" FontSize="13.5" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="softbtn" Content="{Binding ThemeLabel}" Command="{Binding ToggleThemeCommand}" />
                  </Grid>

                  <!-- divider -->
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />

                  <!-- Language (relocated from header; placeholder, disabled) -->
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="Язык интерфейса" FontSize="13.5" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="2" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button Classes="seg active" Content="RU" IsEnabled="False" />
                        <Button Classes="seg" Content="EN" IsEnabled="False" />
                      </StackPanel>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="subcard" Margin="0" IsVisible="{Binding IsSettingsSecurity}">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="БЕЗОПАСНОСТЬ" Classes="section" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                      <TextBlock Text="Kill-switch" FontSize="13.5" />
                      <TextBlock Text="Блокировать весь трафик вне туннеля. Применяется при переподключении."
                                 Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding KillSwitchEnabled, Mode=TwoWay}" />
                  </Grid>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,1,0,0" />
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
                      <TextBlock Text="Доступ к локальной сети" FontSize="13.5" />
                      <TextBlock Text="Разрешить локальную сеть при kill-switch (SSH, принтеры, NAS)."
                                 Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1" VerticalAlignment="Center"
                                  IsChecked="{Binding AllowLan, Mode=TwoWay}" />
                  </Grid>
                </StackPanel>
              </Border>

              <Border Classes="subcard" Margin="0" IsVisible="{Binding IsSettingsLogs}">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="ЖУРНАЛ АГЕНТА" Classes="section" />
                  </Border>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                          Background="{DynamicResource AgInsetBrush}" Margin="15,12,15,15"
                          CornerRadius="12" MaxHeight="520">
                    <Panel>
                      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <SelectableTextBlock Text="{Binding LogText}" IsVisible="{Binding HasLogs}"
                                             FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace"
                                             FontSize="11.5" LineHeight="18"
                                             Foreground="{DynamicResource AgMutedBrush}"
                                             TextWrapping="Wrap" Margin="16,13" />
                      </ScrollViewer>
                      <TextBlock IsVisible="{Binding !HasLogs}" Classes="muted" FontSize="12"
                                 Text="Журнал появится, когда агент начнёт работу."
                                 Margin="18,15" VerticalAlignment="Top" />
                    </Panel>
                  </Border>
                </StackPanel>
              </Border>

              <!-- Источники данных : the geo-data bases (relocated from the old Routing → Источники tab) -->
              <Border Classes="subcard" Margin="0" IsVisible="{Binding IsSettingsSources}">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <Grid ColumnDefinitions="*,Auto">
                      <TextBlock Text="ИСТОЧНИКИ ДАННЫХ" Classes="section" VerticalAlignment="Center" />
                      <Button Grid.Column="1" Classes="softbtn" Command="{Binding UpdateSourcesCommand}" Content="Обновить все" />
                    </Grid>
                  </Border>

                  <StackPanel Margin="15,12" Spacing="8">
                    <TextBlock Classes="label" Text="ДОБАВИТЬ БАЗУ" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <ComboBox Grid.Column="0" Classes="field" Width="118" Margin="0,0,8,0"
                                ItemsSource="{Binding SourceKinds}" SelectedItem="{Binding NewSourceKind, Mode=TwoWay}"
                                IsEnabled="{Binding !SourceKindLocked}"
                                ToolTip.Tip="Тип определён по имени файла в URL" />
                      <TextBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                               Text="{Binding NewSourceUrl, Mode=TwoWay}" Watermark="https://.../geosite.dat" />
                      <Button Grid.Column="2" Classes="accent" Command="{Binding AddSourceCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                          <TextBlock Text="+" />
                          <TextBlock Text="Добавить" />
                        </StackPanel>
                      </Button>
                    </Grid>
                    <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                               Text="geosite — категории доменов, geoip — страны. Файл скачивается сразу. Значок ⟳ обновляет базу, «Обновить все» — все сразу; правый клик по базе — удалить." />

                    <TextBlock Classes="label" Text="ИСТОЧНИКИ" Margin="0,6,0,0" />
                    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            Background="{DynamicResource AgInsetBrush}" CornerRadius="12">
                      <StackPanel Margin="10,10">
                        <ItemsControl ItemsSource="{Binding Sources}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="{DynamicResource AgPanelBrush}"
                                      BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                                      CornerRadius="9" Padding="11,9" Margin="0,3"
                                      ContextRequested="OnSourceRowContext"
                                      ToolTip.Tip="Правый клик — удалить базу">
                                <Grid ColumnDefinitions="*,Auto">
                                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Classes="srctitle" Text="{Binding Detail}" FontSize="12.5" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Url}" FontSize="11" Classes="muted mono"
                                               TextTrimming="CharacterEllipsis" />
                                  </StackPanel>
                                  <Button Grid.Column="1" Classes="icon" VerticalAlignment="Center" Margin="8,0,0,0"
                                          Command="{Binding UpdateCommand}" IsEnabled="{Binding !Updating}"
                                          ToolTip.Tip="Обновить базу">
                                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                      <TextBlock Text="{Binding ProgressText}" IsVisible="{Binding ShowProgress}"
                                                 FontSize="11.5" VerticalAlignment="Center" />
                                      <PathIcon Classes.spin="{Binding Updating}" Data="{DynamicResource AgRefreshGeometry}"
                                                Width="14" Height="14" />
                                    </StackPanel>
                                  </Button>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock IsVisible="{Binding !HasSources}"
                                   Text="Пока нет баз. Добавьте geosite/geoip выше."
                                   Classes="muted" FontSize="12" Margin="2,8" TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="subcard" Margin="0" IsVisible="{Binding IsSettingsAbout}">
                <StackPanel>
                  <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="15,11">
                    <TextBlock Text="О ПРИЛОЖЕНИИ" Classes="section" />
                  </Border>
                  <Grid ColumnDefinitions="*,Auto" Margin="15,11">
                    <TextBlock Text="Версия" FontSize="13.5" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="AmneziaGeo 1.0.0" Classes="muted mono" FontSize="12.5" VerticalAlignment="Center" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>

        </Grid>
        </DockPanel>
      </Border>

    </Grid>

  </DockPanel>

  </Grid>
</Window>
