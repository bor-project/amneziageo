<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:views="clr-namespace:AmneziaGeo.Windows.Ui.Views"
             xmlns:svc="clr-namespace:AmneziaGeo.Windows.Ui.Services"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.ConfigView"
             x:CompileBindings="True"
             x:DataType="vm:ConfigViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgFileGeometry">M13,9H18.5L13,3.5V9M6,2H14L20,8V20A2,2 0 0,1 18,22H6C4.89,22 4,21.1 4,20V4C4,2.89 4.89,2 6,2M15,18V16H6V18H15M18,14V12H6V14H18Z</StreamGeometry>
    <StreamGeometry x:Key="AgQrGeometry">M3,11H5V13H3V11M11,5H13V9H11V5M9,11H13V15H11V13H9V11M15,11H17V13H19V11H21V13H19V15H21V19H19V21H17V19H13V21H11V17H15V15H17V13H15V11M19,19V15H17V19H19M15,3H21V9H15V3M17,5V7H19V5H17M3,3H9V9H3V3M5,5V7H7V5H5M3,15H9V21H3V15M5,17V19H7V17H5Z</StreamGeometry>
    <StreamGeometry x:Key="AgPencilGeometry">M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z</StreamGeometry>
    <StreamGeometry x:Key="AgSwapGeometry">M6.99,11L3,15L6.99,19V16H14V14H6.99V11M21,9L17.01,5V8H10V10H17.01V13L21,9Z</StreamGeometry>
    <StreamGeometry x:Key="AgCopyGeometry">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
    <StreamGeometry x:Key="AgDownloadGeometry">M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z</StreamGeometry>
    <StreamGeometry x:Key="AgLockGeometry">M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z</StreamGeometry>
  </UserControl.Resources>
  <!-- Row 3 stars to fill the pane with the config-text box. -->
  <Grid RowDefinitions="Auto,Auto,Auto,*">
    <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*,Auto">
      <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_ConfigSection}" VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
              Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding Configs.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
      </Border>
      <Button Grid.Column="3" Classes="accent" Width="130" Command="{Binding BeginSectionConfigCommand}"
              IsEnabled="{Binding !IsCreatingSectionConfig}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="+" />
          <TextBlock Text="{l:Tr Main_NewConfigButton}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Config catalogue combo: «- не выбрано -» then saved configs. -->
    <StackPanel Grid.Row="1" Margin="0,14,0,0" Spacing="6">
      <TextBlock Classes="label" Text="{l:Tr Main_ChooseConfigLabel}" />
      <ComboBox Classes="field" HorizontalAlignment="Stretch"
                IsEnabled="{Binding !IsCreatingSectionConfig}"
                ItemsSource="{Binding ConfigCatalogueOptions}"
                SelectedItem="{Binding SelectedCatalogueConfig, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ConfigChoice">
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock IsVisible="{Binding !HasConfigs}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                 Text="{l:Tr Main_NoConfigsHint}" />
    </StackPanel>

    <!-- Standalone import form (Row 3). Imported with the header Save once text parses + name is set (#143). -->
    <Border Grid.Row="3" Margin="0,14,0,0"
            IsVisible="{Binding IsCreatingSectionConfig}"
            Background="Transparent"
            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            CornerRadius="12" Padding="10">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
          <Grid ColumnDefinitions="Auto,*,Auto,Auto">
            <TextBlock Grid.Column="0" Classes="label" Text="{l:Tr Main_NewConfigLabel}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Classes="muted" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"
                       IsVisible="{Binding !IsImportPicker}" Text="{Binding SectionMethodLabel}" />
            <Button Grid.Column="3" Classes="methodpick" IsVisible="{Binding !IsImportPicker}"
                    Command="{Binding ChangeMethodCommand}" Width="160">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgSwapGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_ChangeMethodButton}" />
              </StackPanel>
            </Button>
          </Grid>
          <TextBox Classes="field" Classes.invalid="{Binding SectionConfigNameMissing}"
                   Text="{Binding SectionConfigName, Mode=TwoWay}"
                   Watermark="{l:Tr Main_ConfigNameWatermark}" />
          <TextBlock Classes="fieldwarn" IsVisible="{Binding SectionConfigNameMissing}"
                     Text="{l:Tr Main_RequiredEmptyWarning}" />
        </StackPanel>
        <!-- MTU + WebSocket proxy for the new config: same card as the edit form. -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0"
                BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                CornerRadius="12" Padding="16" Background="Transparent">
          <views:ConfigTransportView DataContext="{Binding SectionConfigTransport}" />
        </Border>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding SectionConfigStatus}" Classes="fieldwarn"
                   FontSize="11.5" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                   Margin="0,10,0,0"
                   IsVisible="{Binding SectionConfigStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- Source: method picker / manual entry / live scanner, swapped inline. -->
        <Panel MinHeight="220" Margin="0,12,0,0">

          <Border IsVisible="{Binding IsImportPicker}"
                  Background="{DynamicResource AgPanelBrush}"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1" CornerRadius="9">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4" Margin="16">
              <TextBlock Text="{l:Tr Main_AddConfigTitle}" FontSize="16" FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
              <TextBlock Text="{l:Tr Main_AddConfigSubtitle}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                         HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12" />
              <WrapPanel HorizontalAlignment="Center">
                <Button Classes="methodpick" Margin="4" Click="OnSectionConfigBrowse" Width="160">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource AgFileGeometry}" Width="15" Height="15" />
                    <TextBlock Text="{l:Tr Main_FileButton}" />
                  </StackPanel>
                </Button>
                <Button Classes="methodpick" Margin="4" Command="{Binding BeginCameraImportCommand}" Width="160">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource AgQrGeometry}" Width="15" Height="15" />
                    <TextBlock Text="{l:Tr Main_CameraButton}" />
                  </StackPanel>
                </Button>
                <Button Classes="methodpick" Margin="4" Command="{Binding BeginManualImportCommand}" Width="160">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource AgPencilGeometry}" Width="15" Height="15" />
                    <TextBlock Text="{l:Tr Main_ConfigEditButton}" />
                  </StackPanel>
                </Button>
              </WrapPanel>
            </StackPanel>
          </Border>

          <Border IsVisible="{Binding IsImportManual}"
                  BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
                  CornerRadius="8" Background="{DynamicResource AgPanelBrush}">
            <TextBox Text="{Binding SectionConfigText, Mode=TwoWay}"
                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                     VerticalContentAlignment="Top" MinHeight="200"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0" Background="Transparent"
                     FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12"
                     Watermark="[Interface]&#x0a;PrivateKey = ...&#x0a;Address = ...&#x0a;&#x0a;[Peer]&#x0a;PublicKey = ...&#x0a;Endpoint = host:port" />
          </Border>

          <Panel IsVisible="{Binding IsImportCamera}">
            <views:ScanView DataContext="{Binding SectionScan}" />
          </Panel>

        </Panel>
      </DockPanel>
    </Border>

    <!-- Open config (Row 2): name editor + QR / .conf text + proxy + delete. Fields autosave on blur. -->
    <StackPanel Grid.Row="2" Margin="0,14,0,0" IsVisible="{Binding IsConfigManage}" Spacing="14"
                LostFocus="OnConfigFieldBlur">
      <!-- Config name: per-keystroke so the required-field border reacts at once; committed with the header Save (#143). -->
      <StackPanel Spacing="2">
        <TextBlock Classes="label" Text="{l:Tr Main_ConfigNameLabel}" />
        <TextBox Classes="field" Classes.invalid="{Binding ConfigNameMissing}"
                 Text="{Binding ConfigRename, Mode=TwoWay}" VerticalAlignment="Center" />
        <TextBlock Classes="fieldwarn" IsVisible="{Binding ConfigNameMissing}"
                   Text="{l:Tr Main_RequiredEmptyWarning}" />
        <TextBlock Text="{Binding ConfigRenameStatus}" Classes="fieldwarn" FontSize="11" TextWrapping="Wrap"
                   IsVisible="{Binding ConfigRenameStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
      </StackPanel>

      <!-- Export card: QR of the .conf / of the vpn:// link, or the .conf text itself. The text is edited in
           place and committed by the header Save (#143), so the mode switch locks while it is dirty. -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <StackPanel Spacing="12" DataContext="{Binding ConfigExport}" x:DataType="vm:ExportDialogViewModel">
          <StackPanel Spacing="2">
            <TextBlock Text="{l:Tr Main_ExportConfigTitle}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
            <TextBlock Text="{l:Tr Main_ExportConfigSubtitle}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
          </StackPanel>
          <Border Background="{DynamicResource AgInsetBrush}"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                  CornerRadius="9" Padding="3" MaxWidth="720" HorizontalAlignment="Center"
                  IsEnabled="{Binding !IsDirty}">
            <UniformGrid Columns="3">
              <!-- Compact shortens the two QR tab labels so all three fit the narrow segment. -->
              <Button Classes="seg" Classes.active="{Binding IsQrConf}" Command="{Binding ShowQrConfCommand}"
                      HorizontalAlignment="Stretch" Padding="20,6">
                <Panel>
                  <TextBlock Text="{l:Tr Main_QrConfTab}" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding !$parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                  <TextBlock Text="{l:Tr Main_QrConfTabShort}" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding $parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                </Panel>
              </Button>
              <Button Classes="seg" Classes.active="{Binding IsQrLink}" Command="{Binding ShowQrLinkCommand}"
                      HorizontalAlignment="Stretch" Padding="20,6">
                <Panel>
                  <TextBlock Text="{l:Tr Main_QrLinkTab}" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding !$parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                  <TextBlock Text="{l:Tr Main_QrLinkTabShort}" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsVisible="{Binding $parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                </Panel>
              </Button>
              <Button Classes="seg" Classes.active="{Binding IsText}" Command="{Binding ShowTextCommand}"
                      Content="{l:Tr Main_ConfigTextTab}" HorizontalAlignment="Stretch" Padding="20,6" />
            </UniformGrid>
          </Border>
          <Border HorizontalAlignment="Center" Background="White" CornerRadius="8" Padding="10"
                  IsVisible="{Binding ShowQr}">
            <Image Source="{Binding QrImage}" Width="220" Height="220" />
          </Border>
          <Border HorizontalAlignment="Center" Background="{DynamicResource AgInsetBrush}"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                  CornerRadius="8" Padding="16" Width="240" IsVisible="{Binding QrUnavailable}">
            <TextBlock Text="{l:Tr Main_QrUnavailableHint}"
                       Classes="muted" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" />
          </Border>
          <!-- vpn:// link under its QR: read-only, borderless, selectable to copy. -->
          <TextBox Text="{Binding LinkText}" IsReadOnly="True" IsVisible="{Binding IsQrLink}"
                   TextWrapping="Wrap" BorderThickness="0" Background="Transparent" Padding="0"
                   FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="11.5" />
          <Border BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
                  CornerRadius="8" Background="{DynamicResource AgPanelBrush}"
                  IsVisible="{Binding IsText}" IsEnabled="{Binding IsReady}">
            <TextBox Text="{Binding ConfText, Mode=TwoWay}"
                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                     VerticalContentAlignment="Top" Height="240"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     BorderThickness="0" Background="Transparent"
                     FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12" />
          </Border>
          <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" IsVisible="{Binding !IsText}">
            <PathIcon Data="{StaticResource AgLockGeometry}" Width="13" Height="13"
                      Foreground="{DynamicResource AgMutedBrush}" VerticalAlignment="Center" />
            <TextBlock Text="{l:Tr Main_QrPrivateKeyWarning}" Classes="muted" FontSize="12"
                       TextWrapping="Wrap" VerticalAlignment="Center" />
          </StackPanel>
          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     HorizontalAlignment="Center" TextAlignment="Center" />
          <Grid ColumnDefinitions="*,*" ColumnSpacing="10" MaxWidth="520" HorizontalAlignment="Center">
            <Button Grid.Column="0" Classes="methodpick" HorizontalAlignment="Stretch" Padding="16,6"
                    Click="OnCopyExport" IsEnabled="{Binding IsReady}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgCopyGeometry}" Width="14" Height="14" />
                <!-- Compact drops the label to just "Copy" so it fits the narrow half-width button. -->
                <Panel>
                  <TextBlock Text="{l:Tr Main_CopyContentButton}"
                             IsVisible="{Binding !$parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                  <TextBlock Text="{l:Tr Main_CopyContentButtonShort}"
                             IsVisible="{Binding $parent[UserControl].((vm:ConfigViewModel)DataContext).IsCompact}" />
                </Panel>
              </StackPanel>
            </Button>
            <Button Grid.Column="1" Classes="accent" HorizontalAlignment="Stretch" Padding="16,6"
                    Click="OnDownloadQr" IsVisible="{Binding ShowQr}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgDownloadGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_DownloadQrButton}" />
              </StackPanel>
            </Button>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Proxy (WebSocket) card. -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <views:ConfigTransportView DataContext="{Binding ConfigTransport}" />
      </Border>

      <!-- Delete card: description left, delete trigger right. When armed, the trigger is replaced in place by
           the Confirm/Cancel pair sharing its footprint - one per column, each stretched (#4). -->
      <Border Background="Transparent"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16">
        <StackPanel Spacing="10">
          <!-- Compact stacks the trigger under the description; wide keeps them side by side. -->
          <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="10">
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0"
                        Grid.ColumnSpan="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=span2}">
              <TextBlock Text="{l:Tr Main_DeleteConfigTitle}" FontWeight="SemiBold" FontSize="13.5" TextWrapping="Wrap" />
              <TextBlock Text="{Binding DeleteConfigPrompt}" FontSize="12" TextWrapping="Wrap" />
              <TextBlock Classes="muted" FontSize="12" TextWrapping="Wrap" Text="{l:Tr Main_DeleteConfigHint}" />
            </StackPanel>
            <Grid VerticalAlignment="Center"
                  Grid.Row="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=row}"
                  Grid.Column="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=col}"
                  Width="{Binding IsCompact, Converter={x:Static svc:CompactConverter.Instance}, ConverterParameter=w180}"
                  ColumnDefinitions="*,*" ColumnSpacing="8">
              <Button Grid.ColumnSpan="2" Classes="danger" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_DeleteConfigButton}"
                      IsVisible="{Binding !ConfigDeletePending}"
                      Command="{Binding RequestDeleteOpenConfigCommand}" />
              <Button Grid.Column="0" Classes="danger" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_ConfirmDeleteButton}"
                      IsVisible="{Binding ConfigDeletePending}"
                      Command="{Binding ConfirmDeleteOpenConfigCommand}" />
              <Button Grid.Column="1" Classes="softbtn" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_CancelButton}"
                      IsVisible="{Binding ConfigDeletePending}"
                      Command="{Binding CancelDeleteConfigCommand}" />
            </Grid>
          </Grid>
          <TextBlock Text="{Binding ConfigDeleteStatus}" Classes="fieldwarn" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding ConfigDeleteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
