<?xml version="1.0" encoding="UTF-8"?>
<!--
  AmneziaGeo Burn bundle. Wraps the self-contained per-machine MSI and hosts the custom managed
  WPF bootstrapper application (AmneziaGeo.Windows.Installer). The bundle Version carries a 4th
  build field (1.0.1.<build>) so every build is strictly newer to Burn - that, together with the
  MSI's MajorUpgrade AllowDowngrades, is what lets "same version, different code" reinstall as an
  update and lets downgrades through. The BA additionally clears any related bundle on install.

  The bundle UpgradeCode is its OWN GUID, distinct from the MSI UpgradeCode.

  The bundle's Add/Remove Programs icon is the bundle exe's embedded icon (IconSourceFile, from the
  installer config). A preprocessor <?if?> cannot wrap a single attribute (it only works between
  elements/content) and a <Bundle> cannot be split, so the whole element is duplicated under <?if?>:
  the HasIcon branch carries IconSourceFile, the other omits it (no icon). Only one branch compiles.

  #54 (default config DB): HasDefaultDb tells the BA whether this bundle carries a prebuilt state.db.
  REPLACEDB is the replace-on-conflict choice - overridable from the command line (REPLACEDB=1 replace
  / 0 skip); empty (the default) means "ask in the GUI, skip when silent". The BA resolves it before
  planning and it flows into the MSI as the SEEDREPLACE property. These two <Variable>s and the
  <MsiProperty> are duplicated into both <?if?> branches along with the rest of the <Bundle>.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

<?if $(var.HasIcon) = "true" ?>
  <Bundle Name="AmneziaGeo"
          Manufacturer="AmneziaGeo"
          Version="$(var.Version)"
          UpgradeCode="A7E1C4F2-9B3D-4E6A-8C15-2F7D9A0B6E34"
          IconSourceFile="$(var.IconFile)"
          Compressed="yes">

    <Variable Name="HasDefaultDb" Value="$(var.HasDefaultDb)" />
    <Variable Name="REPLACEDB" Value="" />

    <!-- Custom out-of-proc BA: the .exe is named directly; every other file from its self-contained
         publish is supplied via the generated BaPayloads PayloadGroup. -->
    <BootstrapperApplication SourceFile="$(var.BaExe)">
      <PayloadGroupRef Id="BaPayloads" />
    </BootstrapperApplication>

    <Chain>
      <!-- Id MUST match InstallerBootstrapper.MsiPackageId so the BA can read this package's state. -->
      <MsiPackage Id="AmneziaGeoMsi"
                  SourceFile="$(var.MsiPath)"
                  Vital="yes"
                  Compressed="yes">
        <MsiProperty Name="SEEDREPLACE" Value="[REPLACEDB]" />
      </MsiPackage>
    </Chain>
  </Bundle>
<?else?>
  <Bundle Name="AmneziaGeo"
          Manufacturer="AmneziaGeo"
          Version="$(var.Version)"
          UpgradeCode="A7E1C4F2-9B3D-4E6A-8C15-2F7D9A0B6E34"
          Compressed="yes">

    <Variable Name="HasDefaultDb" Value="$(var.HasDefaultDb)" />
    <Variable Name="REPLACEDB" Value="" />

    <BootstrapperApplication SourceFile="$(var.BaExe)">
      <PayloadGroupRef Id="BaPayloads" />
    </BootstrapperApplication>

    <Chain>
      <MsiPackage Id="AmneziaGeoMsi"
                  SourceFile="$(var.MsiPath)"
                  Vital="yes"
                  Compressed="yes">
        <MsiProperty Name="SEEDREPLACE" Value="[REPLACEDB]" />
      </MsiPackage>
    </Chain>
  </Bundle>
<?endif?>

</Wix>
