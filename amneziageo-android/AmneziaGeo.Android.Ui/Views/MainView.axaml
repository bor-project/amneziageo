<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Android.Ui.ViewModels"
             x:Class="AmneziaGeo.Android.Ui.Views.MainView"
             x:DataType="vm:MainViewModel">
  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
    <TextBlock Text="AmneziaGeo" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" />
    <TextBlock Text="{Binding Status}" FontSize="18" HorizontalAlignment="Center" />
    <Button Content="{Binding ActionLabel}" Command="{Binding ToggleConnectionCommand}"
            HorizontalAlignment="Center" Padding="28,12" />
  </StackPanel>
</UserControl>