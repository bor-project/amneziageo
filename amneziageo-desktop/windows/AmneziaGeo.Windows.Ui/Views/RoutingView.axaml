<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.RoutingView"
             x:CompileBindings="True"
             x:DataType="vm:RoutingViewModel">
  <UserControl.Resources>
    <StreamGeometry x:Key="AgCopyGeometry">M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z</StreamGeometry>
    <StreamGeometry x:Key="AgPasteGeometry">M19,3H14.82C14.4,1.84 13.3,1 12,1C10.7,1 9.6,1.84 9.18,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M12,3A1,1 0 0,1 13,4A1,1 0 0,1 12,5A1,1 0 0,1 11,4A1,1 0 0,1 12,3M7,7H17V5H19V19H5V5H7V7Z</StreamGeometry>
    <StreamGeometry x:Key="AgUploadGeometry">M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z</StreamGeometry>
    <StreamGeometry x:Key="AgDownloadGeometry">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</StreamGeometry>
  </UserControl.Resources>
  <!-- Edits autosave: rules / toggles at once, text fields on blur (LostFocus). -->
  <StackPanel Spacing="14" LostFocus="OnRoutingFieldBlur">
    <!-- Header: section title + count pill + new-list button. -->
    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
      <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_RoutingSection}" VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
              Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding RoutingLists.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
      </Border>
      <Button Grid.Column="3" Classes="accent" Width="130" Command="{Binding CreateRoutingListCommand}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="+" />
          <TextBlock Text="{l:Tr Main_NewListButton}" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- Routing-list catalogue combo: «- не выбрано -» then saved lists. -->
    <StackPanel Spacing="6">
      <TextBlock Classes="label" Text="{l:Tr Main_ChooseListLabel}" />
      <ComboBox Classes="field" HorizontalAlignment="Stretch"
                ItemsSource="{Binding RoutingCatalogueOptions}"
                SelectedItem="{Binding SelectedCatalogueRouting, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:RoutingListChoice">
            <!-- «- не выбрано -» for the none sentinel. -->
            <Panel>
              <TextBlock Text="{l:Tr Main_NotSelected}" IsVisible="{Binding IsNone}" />
              <TextBlock Text="{Binding Name}" IsVisible="{Binding !IsNone}" />
            </Panel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock IsVisible="{Binding !HasRoutingLists}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                 Text="{l:Tr Main_NoRoutingListsHint}" />
    </StackPanel>

    <!-- Section loader until an opened list's rules + traffic settings finish, so the editor reveals fully
         populated with no reflow (#193); matches the main window's first-load loader. -->
    <StackPanel IsVisible="{Binding EditorLoading}" HorizontalAlignment="Center" Spacing="12" Margin="0,24">
      <ProgressBar IsIndeterminate="True" Width="150" HorizontalAlignment="Center" />
      <TextBlock Text="{l:Tr Main_RoutingLoading}" Classes="muted" FontSize="13" HorizontalAlignment="Center" />
    </StackPanel>

    <!-- Editor for the selected / new list. -->
    <StackPanel IsVisible="{Binding EditorReady}" Spacing="14">

      <!-- Rules card: name + per-app tunneling + geo/domain/cidr entries + import/export. -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <StackPanel Spacing="14" DataContext="{Binding RoutingEditor}" x:DataType="vm:RoutingListEditorViewModel">
          <!-- Title left; global-proxy flag right (binds up to the list's traffic settings). -->
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" Text="{l:Tr Main_RoutingListCardTitle}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                        ToolTip.Tip="{l:Tr Main_GlobalProxyHint}">
              <TextBlock Text="{l:Tr Main_GlobalProxyTitle}" FontSize="12.5" Classes="muted" VerticalAlignment="Center" />
              <ToggleSwitch VerticalAlignment="Center" MinWidth="0"
                            IsChecked="{Binding $parent[UserControl].((vm:RoutingViewModel)DataContext).RoutingSettings.UseGlobalProxy, Mode=TwoWay}" />
            </StackPanel>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsLoading}">
            <PathIcon Classes.spin="{Binding IsLoading}" Data="{DynamicResource AgRefreshGeometry}"
                      Width="14" Height="14" Foreground="{DynamicResource AgMutedBrush}" VerticalAlignment="Center" />
            <TextBlock Text="{l:Tr Main_RoutingLoading}" Classes="muted" FontSize="12.5" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Spacing="2">
            <TextBlock Classes="label" Text="{l:Tr Main_ListNameLabel}" />
            <TextBox Classes="field" Classes.invalid="{Binding IsNameMissing}"
                     Text="{Binding Name, Mode=TwoWay}" Watermark="{l:Tr Main_ListNameWatermark}" />
            <TextBlock Classes="fieldwarn" IsVisible="{Binding IsNameMissing}"
                       Text="{l:Tr Main_RequiredEmptyWarning}" />
          </StackPanel>

          <!-- Per-app tunneling. -->
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_PerAppRoutingLabel}" />
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Button Grid.Column="0" Classes="softbtn" Width="130" Margin="0,0,8,0" Content="{l:Tr Main_SourceDropdown}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuItem Header="{l:Tr Main_AppSourceRunning}" Click="OnAppSourceRunning" />
                    <MenuItem Header="{l:Tr Main_AppSourceInstalled}" Click="OnAppSourceInstalled" />
                    <MenuItem Header="{l:Tr Main_AppSourceFolder}" Click="OnAppSourceFolder" />
                    <MenuItem Header="{l:Tr Main_AppSourceFile}" Click="OnAppSourceFile" />
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
              <AutoCompleteBox Grid.Column="1" Classes="field" Margin="0,0,8,0"
                               Watermark="{Binding AppWatermark}"
                               Text="{Binding AppInput, Mode=TwoWay}"
                               SelectedItem="{Binding AppSelected, Mode=TwoWay}"
                               ItemsSource="{Binding AppSuggestions}"
                               FilterMode="ContainsOrdinal" MaxDropDownHeight="220"
                               IsEnabled="{Binding IsAppPickerActive}" />
              <Button Grid.Column="2" Classes="accent" Width="130" Command="{Binding AddAppCommand}"
                      IsEnabled="{Binding IsAppPickerActive}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="{l:Tr Main_AddButton}" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>

          <!-- Add a geo category / domain / cidr entry. -->
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_AddEntryLabel}" />
            <Grid ColumnDefinitions="*,Auto">
              <AutoCompleteBox Grid.Column="0" Classes="field" Margin="0,0,8,0"
                               Watermark="{l:Tr Main_AddEntryWatermark}"
                               Text="{Binding RuleInput, Mode=TwoWay}"
                               ItemsSource="{Binding GeoSuggestions}"
                               FilterMode="ContainsOrdinal" MaxDropDownHeight="220" />
              <Button Grid.Column="1" Classes="accent" Width="130" Command="{Binding AddRuleCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="{l:Tr Main_AddButton}" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>

          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
          <!-- Required-field validation, red; clears on any edit (#2/#3). -->
          <TextBlock Text="{Binding ValidationMessage}" Classes="fieldwarn" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <!-- Role segment [Прокси | Директ | Блок | Исключения]: which bucket the add rows target and the list below shows. -->
          <StackPanel Spacing="6">
            <Border Background="{DynamicResource AgInsetBrush}"
                    BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                    CornerRadius="9" Padding="3">
              <UniformGrid Columns="4">
                <Button Classes="seg" Classes.active="{Binding IsProxyRole}" Content="{l:Tr Main_RoleProxy}"
                        Command="{Binding SelectRoleCommand}" CommandParameter="proxy"
                        HorizontalAlignment="Stretch" Padding="12,6" />
                <Button Classes="seg" Classes.active="{Binding IsDirectRole}" Content="{l:Tr Main_RoleDirect}"
                        Command="{Binding SelectRoleCommand}" CommandParameter="direct"
                        HorizontalAlignment="Stretch" Padding="12,6" />
                <Button Classes="seg" Classes.active="{Binding IsBlockRole}" Content="{l:Tr Main_RoleBlock}"
                        Command="{Binding SelectRoleCommand}" CommandParameter="block"
                        HorizontalAlignment="Stretch" Padding="12,6" />
                <Button Classes="seg" Classes.active="{Binding IsExcludeRole}" Content="{l:Tr Main_RoleExclude}"
                        Command="{Binding SelectRoleCommand}" CommandParameter="exclude"
                        HorizontalAlignment="Stretch" Padding="12,6" />
              </UniformGrid>
            </Border>
            <!-- Role hint left; a blue link (Exclude only) fills the Exclude bucket with the machine's local subnets. -->
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding RoleHint}" Classes="muted" FontSize="11.5"
                         TextWrapping="Wrap" VerticalAlignment="Top" />
              <Button Grid.Column="1" IsVisible="{Binding IsExcludeRole}" Margin="12,0,0,0"
                      Command="{Binding AddLocalSubnetsCommand}" IsEnabled="{Binding !IsBusy}"
                      Background="Transparent" BorderThickness="0" Padding="0"
                      Cursor="Hand" VerticalAlignment="Top" HorizontalAlignment="Right">
                <TextBlock Text="{l:Tr Main_AddLocalSubnetsButton}" FontSize="11.5" TextWrapping="Wrap"
                           Foreground="{DynamicResource AgAccentBrush}" />
              </Button>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6" IsVisible="{Binding Rules.Count}">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
              <TextBlock Grid.Column="0" Classes="label" Text="{l:Tr Main_EntriesLabel}" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="icon" Content="⇅" FontSize="13" Margin="6,0,0,0"
                      VerticalAlignment="Center"
                      Command="{Binding SortRulesCommand}"
                      ToolTip.Tip="{l:Tr Main_SortRulesTooltip}" />
              <Button Grid.Column="3" Command="{Binding ClearRulesCommand}"
                      Background="Transparent" BorderThickness="0" Padding="0"
                      Cursor="Hand" VerticalAlignment="Center" HorizontalAlignment="Right"
                      ToolTip.Tip="{l:Tr Main_ClearRulesTooltip}">
                <TextBlock Text="{l:Tr Main_ClearButton}" FontSize="11.5"
                           Foreground="{DynamicResource AgAccentBrush}" />
              </Button>
            </Grid>
            <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                    Background="{DynamicResource AgPanelBrush}" CornerRadius="10">
              <ItemsControl ItemsSource="{Binding Rules}" Margin="8,8">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Border Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="10,7" Margin="0,3">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding}" Classes="mono" FontSize="12.5"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Classes="icon" Content="✕"
                                Command="{Binding $parent[ItemsControl].((vm:RoutingListEditorViewModel)DataContext).RemoveRuleCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Per-routing traffic card: exclusions + all-UDP + IPv6. -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent"
              IsVisible="{Binding RoutingSettings, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Spacing="14" DataContext="{Binding RoutingSettings}" x:DataType="vm:RoutingSettingsViewModel">
          <TextBlock Text="{l:Tr Main_RoutingOptionsLabel}" FontWeight="SemiBold" FontSize="15" />

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
              <TextBlock Text="{l:Tr Main_AllUdpTitle}" FontSize="13.5" />
              <TextBlock Text="{l:Tr Main_AllUdpHint}"
                         Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AllUdp, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
              <TextBlock Text="{l:Tr Main_UseIpv6Title}" FontSize="13.5" />
              <TextBlock Text="{l:Tr Main_UseIpv6Hint}"
                         Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding UseIpv6, Mode=TwoWay}" />
          </Grid>

          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </Border>

      <!-- Transfer card: QR / raw payload of the list, with copy / paste / load / save (replaces the modal). -->
      <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" Background="Transparent">
        <StackPanel Spacing="12" DataContext="{Binding RoutingEditor}" x:DataType="vm:RoutingListEditorViewModel">
          <StackPanel Spacing="2">
            <TextBlock Text="{l:Tr Main_ImportExportSection}" FontWeight="SemiBold" FontSize="15" />
            <TextBlock Text="{l:Tr Main_TransferSubtitle}" Classes="muted" FontSize="12" />
          </StackPanel>

          <!-- Segmented [QR | Конфиг]. -->
          <Border Background="{DynamicResource AgInsetBrush}"
                  BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                  CornerRadius="9" Padding="3" MaxWidth="420" HorizontalAlignment="Center">
            <UniformGrid Columns="2">
              <Button Classes="seg" Classes.active="{Binding IsTransferQr}" Command="{Binding ShowTransferQrCommand}"
                      Content="{l:Tr Main_TransferQrTab}" HorizontalAlignment="Stretch" Padding="20,6" />
              <Button Classes="seg" Classes.active="{Binding IsTransferText}" Command="{Binding ShowTransferTextCommand}"
                      Content="{l:Tr Main_TransferTextTab}" HorizontalAlignment="Stretch" Padding="20,6" />
            </UniformGrid>
          </Border>

          <!-- QR tab: fixed 240x240 stage so the image (or notice) appearing never reflows the card or jumps
               the scroll; blank while the QR is still being built. -->
          <Panel Height="240" IsVisible="{Binding IsTransferQr}">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="8" Padding="10"
                    IsVisible="{Binding RoutingQrImage, Converter={x:Static ObjectConverters.IsNotNull}}">
              <Image Source="{Binding RoutingQrImage}" Width="220" Height="220" />
            </Border>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{DynamicResource AgInsetBrush}"
                    BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16" Width="240" IsVisible="{Binding QrUnavailable}">
              <TextBlock Text="{l:Tr Main_QrUnavailableHint}" Classes="muted" FontSize="12"
                         TextAlignment="Center" TextWrapping="Wrap" />
            </Border>
          </Panel>

          <!-- Config tab: the raw transfer payload, read-only and selectable. -->
          <TextBox Classes="field" Text="{Binding TransferText}" IsReadOnly="True" AcceptsReturn="True"
                   TextWrapping="NoWrap" IsVisible="{Binding IsTransferText}"
                   VerticalContentAlignment="Top" Height="200"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12" />

          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                     HorizontalAlignment="Center" TextAlignment="Center"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <!-- Shared actions: copy / paste / load / save. -->
          <WrapPanel HorizontalAlignment="Center">
            <Button Classes="methodpick" Margin="4" Padding="14,6" Click="OnRoutingExportCopy"
                    IsVisible="{Binding IsTransferQr}"
                    ToolTip.Tip="{l:Tr Main_RoutingCopyTooltip}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgCopyGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_CopyButton}" />
              </StackPanel>
            </Button>
            <Button Classes="methodpick" Margin="4" Padding="14,6" Click="OnRoutingImportPaste"
                    IsVisible="{Binding IsTransferQr}"
                    ToolTip.Tip="{l:Tr Main_RoutingPasteTooltip}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgPasteGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_PasteButton}" />
              </StackPanel>
            </Button>
            <Button Classes="methodpick" Margin="4" Padding="14,6" Click="OnRoutingImportFile"
                    IsVisible="{Binding IsTransferText}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgUploadGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_LoadFileButton}" />
              </StackPanel>
            </Button>
            <Button Classes="accent" Margin="4" Padding="14,6" Click="OnRoutingExportSave"
                    IsVisible="{Binding IsTransferText}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource AgDownloadGeometry}" Width="14" Height="14" />
                <TextBlock Text="{l:Tr Main_SaveToFileButton}" />
              </StackPanel>
            </Button>
          </WrapPanel>
        </StackPanel>
      </Border>

      <!-- Delete card: description left, delete trigger right. When armed, the trigger is replaced in place by
           the Confirm/Cancel pair sharing its footprint - one per column, each stretched (#4). Hidden for an
           unsaved new-list draft. -->
      <Border Background="Transparent"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="12" Padding="16" IsVisible="{Binding !RoutingEditor.IsNew}">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center" Margin="0,0,16,0">
              <TextBlock Text="{l:Tr Main_DeleteListTitle}" FontWeight="SemiBold" FontSize="13.5" />
              <TextBlock Text="{l:Tr Main_DeleteListPrompt}" FontSize="12" TextWrapping="Wrap" />
              <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap" Text="{l:Tr Main_DeleteListHint}" />
            </StackPanel>
            <Grid Grid.Column="1" Width="180" VerticalAlignment="Center"
                  ColumnDefinitions="*,*" ColumnSpacing="8">
              <Button Grid.ColumnSpan="2" Classes="danger" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_DeleteListButton}"
                      IsVisible="{Binding !RoutingDeletePending}"
                      Command="{Binding RequestDeleteSectionRoutingListCommand}" />
              <Button Grid.Column="0" Classes="danger" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_ConfirmDeleteButton}"
                      IsVisible="{Binding RoutingDeletePending}"
                      Command="{Binding ConfirmDeleteSectionRoutingListCommand}" />
              <Button Grid.Column="1" Classes="softbtn" HorizontalAlignment="Stretch"
                      Content="{l:Tr Main_CancelButton}"
                      IsVisible="{Binding RoutingDeletePending}"
                      Command="{Binding CancelDeleteRoutingCommand}" />
            </Grid>
          </Grid>
          <TextBlock Text="{Binding RoutingDeleteStatus}" Classes="fieldwarn" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding RoutingDeleteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </StackPanel>
</UserControl>
