<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
        x:Class="AmneziaGeo.Windows.Ui.ConfigEditorDialog"
        Title="{Binding Title}"
        Width="560" Height="600"
        MinWidth="420" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AgBgBrush}"
        Foreground="{DynamicResource AgFgBrush}">

  <DockPanel Margin="16">

    <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" />
    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,0" Classes="muted" FontSize="12" TextWrapping="Wrap"
               Text="{l:Tr ConfigEditor_Hint}" />

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,12,0,0">
      <Button Classes="softbtn" Content="{l:Tr ConfigEditor_CancelButton}" Click="OnCancel" />
      <Button Classes="accent" Content="{l:Tr ConfigEditor_SaveButton}" Click="OnSave" IsDefault="True" />
    </StackPanel>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
               Foreground="{DynamicResource AgDownBrush}" FontSize="12"
               TextWrapping="Wrap" Margin="0,10,0,0" />

    <Border Margin="0,12,0,0" BorderBrush="{DynamicResource AgBorder2Brush}" BorderThickness="1"
            CornerRadius="8" Background="{DynamicResource AgPanelBrush}">
      <TextBox Text="{Binding Text, Mode=TwoWay}" AcceptsReturn="True" AcceptsTab="True"
               TextWrapping="NoWrap" VerticalContentAlignment="Top"
               ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
               BorderThickness="0" Background="Transparent"
               FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12"
               Watermark="[Interface]&#x0a;PrivateKey = ...&#x0a;Address = ...&#x0a;&#x0a;[Peer]&#x0a;PublicKey = ...&#x0a;Endpoint = host:port" />
    </Border>

  </DockPanel>
</Window>
