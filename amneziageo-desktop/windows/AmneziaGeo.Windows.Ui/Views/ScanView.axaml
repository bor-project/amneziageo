<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             x:Class="AmneziaGeo.Windows.Ui.Views.ScanView"
             x:CompileBindings="True"
             x:DataType="vm:ScanViewModel">
  <DockPanel>
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}"
               Classes="muted" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" />
    <Border Background="Black" CornerRadius="8" ClipToBounds="True"
            HorizontalAlignment="Center" MaxWidth="380" MaxHeight="300">
      <Image Source="{Binding Preview}" Stretch="Uniform" />
    </Border>
  </DockPanel>
</UserControl>
