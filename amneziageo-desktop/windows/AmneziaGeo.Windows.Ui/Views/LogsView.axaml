<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.LogsView"
             x:CompileBindings="True"
             x:DataType="vm:LogsViewModel">
  <StackPanel>
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="0,9">
      <TextBlock Text="{l:Tr Main_AgentLogSection}" Classes="section" />
    </Border>
    <!-- Capture verbosity: minimum level WRITTEN to the log; applies live. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="0,11">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{l:Tr Main_LogVerbosityTitle}" FontSize="13.5" />
          <TextBlock Text="{l:Tr Main_LogVerbosityHint}"
                     Classes="muted" FontSize="11.5" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left" />
        </StackPanel>
        <ComboBox Grid.Column="1" VerticalAlignment="Center" MinWidth="150"
                  ItemsSource="{Binding LogLevels}"
                  SelectedItem="{Binding LogLevel, Mode=TwoWay}" />
      </Grid>
    </Border>
    <!-- Routing log: toggleable log of route changes and DNS resolutions. -->
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="0,0,0,1" Padding="0,11">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
          <TextBlock Text="{l:Tr Main_RouteLogTitle}" FontSize="13.5" />
          <TextBlock Text="{l:Tr Main_RouteLogHint}"
                     Classes="muted" FontSize="11.5" TextWrapping="Wrap" MaxWidth="380" HorizontalAlignment="Left" />
        </StackPanel>
        <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding RouteLogEnabled, Mode=TwoWay}" />
      </Grid>
    </Border>
    <!-- Viewer toolbar: file picker + live-tail follow, then search over the shown tail. -->
    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8" Margin="0,12,0,0" VerticalAlignment="Center">
      <TextBlock Grid.Column="0" Text="{l:Tr Main_LogFileLabel}" Classes="muted" FontSize="11.5" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1" Classes="field" HorizontalAlignment="Stretch"
                ItemsSource="{Binding LogFiles}" SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:LogFileChoice">
            <TextBlock Text="{Binding Display}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock Grid.Column="2" Text="{l:Tr Main_LogFollowLabel}" Classes="muted" FontSize="11.5" VerticalAlignment="Center" />
      <ToggleSwitch Grid.Column="3" IsChecked="{Binding LogFollow, Mode=TwoWay}" VerticalAlignment="Center" />
    </Grid>
    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,8,0,0" VerticalAlignment="Center">
      <TextBox Grid.Column="0" Classes="field" Text="{Binding SearchQuery, Mode=TwoWay}"
               Watermark="{l:Tr Main_LogSearchWatermark}" />
      <TextBlock Grid.Column="1" Text="{Binding SearchSummary}" Classes="muted" FontSize="11.5"
                 VerticalAlignment="Center" />
    </Grid>
    <Button Classes="softbtn" Margin="0,10,0,0" HorizontalAlignment="Center"
            Content="{l:Tr Main_LogLoadOlderButton}" Command="{Binding LoadOlderLogCommand}"
            IsVisible="{Binding LogCanPageOlder}" />
    <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
            Background="{DynamicResource AgInsetBrush}" Margin="0,12,0,15"
            CornerRadius="12" MaxHeight="520">
      <Panel>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <SelectableTextBlock Text="{Binding LogText}" IsVisible="{Binding HasLogs}"
                               FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace"
                               FontSize="11.5" LineHeight="18"
                               Foreground="{DynamicResource AgMutedBrush}"
                               TextWrapping="Wrap" Margin="16,13" />
        </ScrollViewer>
        <TextBlock IsVisible="{Binding !HasLogs}" Classes="muted" FontSize="12"
                   Text="{l:Tr Main_LogEmptyHint}"
                   Margin="18,15" VerticalAlignment="Top" />
      </Panel>
    </Border>
  </StackPanel>
</UserControl>
