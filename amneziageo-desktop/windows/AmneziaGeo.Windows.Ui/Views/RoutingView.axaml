<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AmneziaGeo.Windows.Ui.ViewModels"
             xmlns:l="clr-namespace:AmneziaGeo.Windows.Ui.Localization"
             x:Class="AmneziaGeo.Windows.Ui.Views.RoutingView"
             x:CompileBindings="True"
             x:DataType="vm:RoutingViewModel">
  <StackPanel Spacing="14">
    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
      <TextBlock Grid.Column="0" Classes="section" Text="{l:Tr Main_RoutingSection}" VerticalAlignment="Center" />
      <Border Grid.Column="1" Background="{DynamicResource AgInsetBrush}" CornerRadius="20"
              Padding="8,1" Margin="8,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="{Binding RoutingLists.Count}" FontSize="11" Classes="muted" FontWeight="SemiBold" />
      </Border>
      <Button Grid.Column="3" Classes="softbtn" Command="{Binding CreateRoutingListCommand}"
              IsEnabled="{Binding !IsEditing}">
        <StackPanel Orientation="Horizontal" Spacing="4">
          <TextBlock Text="+" />
          <TextBlock Text="{l:Tr Main_NewListButton}" />
        </StackPanel>
      </Button>
    </Grid>

    <StackPanel Spacing="6">
      <TextBlock Classes="label" Text="{l:Tr Main_ChooseListLabel}" />
      <ComboBox Classes="field" HorizontalAlignment="Stretch"
                IsEnabled="{Binding !IsEditing}"
                ItemsSource="{Binding RoutingCatalogueOptions}"
                SelectedItem="{Binding SelectedCatalogueRouting, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:RoutingListChoice">
            <!-- «- не выбрано -» for the none sentinel. -->
            <Panel>
              <TextBlock Text="{l:Tr Main_NotSelected}" IsVisible="{Binding IsNone}" />
              <TextBlock Text="{Binding Name}" IsVisible="{Binding !IsNone}" />
            </Panel>
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock IsVisible="{Binding !HasRoutingLists}" Classes="muted" FontSize="12" TextWrapping="Wrap"
                 Text="{l:Tr Main_NoRoutingListsHint}" />
    </StackPanel>

    <!-- Rule editor for the selected/new list. -->
    <StackPanel IsVisible="{Binding HasRoutingEditor}" Spacing="12">
      <Border Background="Transparent"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="9" Padding="12">
        <StackPanel Spacing="12" DataContext="{Binding RoutingEditor}" x:DataType="vm:RoutingListEditorViewModel">
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_ListNameLabel}" />
            <TextBox Classes="field" Classes.invalid="{Binding IsNameMissing}"
                     Text="{Binding Name, Mode=TwoWay}" Watermark="{l:Tr Main_ListNameWatermark}" />
            <TextBlock Classes="fieldwarn" IsVisible="{Binding IsNameMissing}"
                       Text="{l:Tr Main_RequiredEmptyWarning}" />
          </StackPanel>

          <!-- Per-app tunneling. -->
          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_PerAppRoutingLabel}" />
            <Grid ColumnDefinitions="Auto,*,Auto">
              <Button Grid.Column="0" Classes="softbtn" Margin="0,0,8,0" Content="{l:Tr Main_SourceDropdown}">
                <Button.Flyout>
                  <MenuFlyout>
                    <MenuItem Header="{l:Tr Main_AppSourceRunning}" Click="OnAppSourceRunning" />
                    <MenuItem Header="{l:Tr Main_AppSourceInstalled}" Click="OnAppSourceInstalled" />
                    <MenuItem Header="{l:Tr Main_AppSourceFolder}" Click="OnAppSourceFolder" />
                    <MenuItem Header="{l:Tr Main_AppSourceFile}" Click="OnAppSourceFile" />
                  </MenuFlyout>
                </Button.Flyout>
              </Button>
              <AutoCompleteBox Grid.Column="1" Margin="0,0,8,0"
                               Watermark="{Binding AppWatermark}"
                               Text="{Binding AppInput, Mode=TwoWay}"
                               SelectedItem="{Binding AppSelected, Mode=TwoWay}"
                               ItemsSource="{Binding AppSuggestions}"
                               FilterMode="ContainsOrdinal" MaxDropDownHeight="220"
                               IsEnabled="{Binding IsAppPickerActive}" />
              <Button Grid.Column="2" Classes="accent" Command="{Binding AddAppCommand}"
                      IsEnabled="{Binding IsAppPickerActive}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="{l:Tr Main_AddButton}" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_AddEntryLabel}" />
            <Grid ColumnDefinitions="*,Auto">
              <AutoCompleteBox Grid.Column="0" Margin="0,0,8,0"
                               Watermark="{l:Tr Main_AddEntryWatermark}"
                               Text="{Binding RuleInput, Mode=TwoWay}"
                               ItemsSource="{Binding GeoSuggestions}"
                               FilterMode="ContainsOrdinal" MaxDropDownHeight="220" />
              <Button Grid.Column="1" Classes="accent" Command="{Binding AddRuleCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="+" />
                  <TextBlock Text="{l:Tr Main_AddButton}" />
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>

          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12" TextWrapping="Wrap" />
          <!-- Required-field validation ("add at least one entry"), red; clears on any edit (#2/#3). -->
          <TextBlock Text="{Binding ValidationMessage}" Classes="fieldwarn" FontSize="12" TextWrapping="Wrap"
                     IsVisible="{Binding ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

          <StackPanel Spacing="6" IsVisible="{Binding Rules.Count}">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="label" Text="{l:Tr Main_EntriesLabel}" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="icon" Content="{l:Tr Main_ClearButton}" FontSize="11"
                      Command="{Binding ClearRulesCommand}"
                      ToolTip.Tip="{l:Tr Main_ClearRulesTooltip}" />
            </Grid>
            <Border BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                    Background="{DynamicResource AgPanelBrush}" CornerRadius="10">
              <ItemsControl ItemsSource="{Binding Rules}" Margin="8,8">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Border Background="{DynamicResource AgInsetBrush}"
                            BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="10,7" Margin="0,3">
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding}" Classes="mono" FontSize="12.5"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Classes="icon" Content="✕"
                                Command="{Binding $parent[ItemsControl].((vm:RoutingListEditorViewModel)DataContext).RemoveRuleCommand}"
                                CommandParameter="{Binding}" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </Border>
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_ImportExportLabel}" />
            <WrapPanel>
              <Button Classes="softbtn" Content="{l:Tr Main_CopyButton}" Margin="0,0,6,6"
                      Click="OnRoutingExportCopy" ToolTip.Tip="{l:Tr Main_RoutingCopyTooltip}" />
              <Button Classes="softbtn" Content="{l:Tr Main_SaveToFileButton}" Margin="0,0,6,6"
                      Click="OnRoutingExportSave" />
              <Button Classes="softbtn" Content="{l:Tr Main_ShowQrButton}" Margin="0,0,6,6"
                      Click="OnRoutingShowQr" ToolTip.Tip="{l:Tr Main_ShowQrTooltip}" />
              <Button Classes="softbtn" Content="{l:Tr Main_PasteButton}" Margin="0,0,6,6"
                      Click="OnRoutingImportPaste" ToolTip.Tip="{l:Tr Main_RoutingPasteTooltip}" />
              <Button Classes="softbtn" Content="{l:Tr Main_LoadFileButton}" Margin="0,0,6,6"
                      Click="OnRoutingImportFile" />
            </WrapPanel>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Per-routing traffic settings: local DNS + exclusions + all-UDP. -->
      <Border Background="Transparent"
              BorderBrush="{DynamicResource AgBorderBrush}" BorderThickness="1"
              CornerRadius="9" Padding="12" IsVisible="{Binding RoutingSettings, Converter={x:Static ObjectConverters.IsNotNull}}">
        <StackPanel Spacing="12" DataContext="{Binding RoutingSettings}" x:DataType="vm:RoutingSettingsViewModel">
          <TextBlock Classes="label" Text="{l:Tr Main_ListTrafficLabel}" />

          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="DNS" />
            <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                       Text="{l:Tr Main_DnsHint}" />
            <TextBox Classes="field" Text="{Binding LocalDns, Mode=TwoWay}"
                     Watermark="{l:Tr Main_DnsWatermark}" />
          </StackPanel>

          <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="{l:Tr Main_ExclusionsLabel}" />
            <TextBlock Classes="muted" FontSize="11.5" TextWrapping="Wrap"
                       Text="{l:Tr Main_ExclusionsHint}" />
            <Button Classes="softbtn" HorizontalAlignment="Left" Content="{l:Tr Main_AddLocalSubnetsButton}"
                    Command="{Binding AddLocalSubnetsCommand}" IsEnabled="{Binding !IsBusy}" />
            <TextBox Classes="field" AcceptsReturn="True" TextWrapping="NoWrap" Height="110"
                     VerticalContentAlignment="Top"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="IBM Plex Mono, Cascadia Mono, Consolas, monospace" FontSize="12"
                     Text="{Binding Exclusions, Mode=TwoWay}"
                     Watermark="corp.local&#x0a;nas&#x0a;10.50.0.0/16&#x0a;192.168.10.5" />
          </StackPanel>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
              <TextBlock Text="{l:Tr Main_AllUdpTitle}" FontSize="13.5" />
              <TextBlock Text="{l:Tr Main_AllUdpHint}"
                         Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding AllUdp, Mode=TwoWay}" />
          </Grid>

          <Grid ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2" MaxWidth="430" HorizontalAlignment="Left">
              <TextBlock Text="{l:Tr Main_UseIpv6Title}" FontSize="13.5" />
              <TextBlock Text="{l:Tr Main_UseIpv6Hint}"
                         Classes="muted" FontSize="11.5" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding UseIpv6, Mode=TwoWay}" />
          </Grid>

          <!-- Edits commit atomically with the header Save (#143). -->
          <TextBlock Text="{Binding StatusMessage}" Classes="muted" FontSize="12"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <!-- Delete: trigger + inline error. When armed, the inline Confirm/Cancel pair replaces the
           trigger in place (#4). Hidden for an unsaved new-list draft. -->
      <StackPanel Spacing="6" IsVisible="{Binding !RoutingEditor.IsNew}">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Button Classes="danger" HorizontalAlignment="Left" VerticalAlignment="Top"
                  IsVisible="{Binding !RoutingDeletePending}" IsEnabled="{Binding !IsEditing}"
                  Command="{Binding RequestDeleteSectionRoutingListCommand}" Content="{l:Tr Main_DeleteListButton}" />
          <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding RoutingDeletePending}">
            <Button Classes="danger" Content="{l:Tr Main_ConfirmDeleteButton}" VerticalAlignment="Top"
                    Command="{Binding ConfirmDeleteSectionRoutingListCommand}" />
            <Button Classes="softbtn" Content="{l:Tr Main_CancelButton}" VerticalAlignment="Top"
                    Command="{Binding CancelDeleteRoutingCommand}" />
          </StackPanel>
          <TextBlock Text="{Binding RoutingDeleteStatus}" Classes="fieldwarn" FontSize="12"
                     VerticalAlignment="Center" TextWrapping="Wrap"
                     IsVisible="{Binding RoutingDeleteStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </StackPanel>
</UserControl>
