<?xml version="1.0" encoding="UTF-8"?>
<!--
  AmneziaGeo Windows installer (per-machine MSI, x64, self-contained payload).

  Service model (privileged daemon + unprivileged GUI, the standard Windows VPN split):
    * AmneziaGeo.Windows.App.exe  -> installed AND registered as the "AmneziaGeoAgent" Windows
      service under LocalSystem (auto-start). This is the privileged VPN backend: it creates the
      AmneziaWG/Wintun adapter, programs routes, the WFP kill-switch and DNS, all of which need
      SYSTEM/admin, which is why the per-machine MSI (elevated once at install) is the right place
      for it. Idle-tolerant: with no profile configured yet it just serves the pipe. The tunnel is
      brought up only while a GUI client is connected (the agent disconnects it shortly after the
      last UI session drops), so the always-on service costs nothing when the app is closed.
    * AmneziaGeo.Windows.Ui.exe   -> the GUI, run by the normal user via the shortcut, NO elevation.
      It is a pure named-pipe client (the pipe ACL already allows Authenticated Users), so there is
      no UAC prompt on launch.
    * everything else from the self-contained publish (the .NET runtime, tunnel.dll, wintun.dll,
      wstunnel.exe, Avalonia natives, ...) is harvested verbatim from the staged publish directory.

  Per-tunnel work runs as transient "AmneziaGeo$<name>" services the agent creates on connect and
  deletes on disconnect (the upstream wireguard-windows model); they are not laid down by the MSI,
  but a leftover one (e.g. an agent crash mid-connect) is mopped up on uninstall by AgCleanup.

  Runtime data (state.db, Configurations\, geo\, logs\) lives in ProgramData\AmneziaGeo and is
  created by the service at runtime, so the MSI does not lay it down.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="AmneziaGeo"
           Manufacturer="AmneziaGeo"
           Version="1.0.1.0"
           UpgradeCode="CF01DE97-3FF5-4A9A-B106-DAD6D3D95CB5"
           Scope="perMachine"
           Compressed="yes">

    <!-- AllowDowngrades: the Burn bundle (AmneziaGeo.Windows.Installer) drives install / update /
         repair / remove and may reinstall the same code or downgrade. AllowDowngrades makes the MSI
         accept an equal-or-lower version (a major upgrade that removes the prior install and lays the
         new files down fresh) instead of blocking it. -->
    <MajorUpgrade AllowDowngrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <!-- "Delete configuration on removal" choice (#105), passed by the Burn bundle from the BA checkbox
         (DELETECONFIG). "1" => wipe the runtime data tree on full removal (AgWipeConfig below); anything else
         (incl. the default 0) => keep it, so a reinstall preserves the user's profiles/settings. Secure so it
         survives into the elevated execute sequence. -->
    <Property Id="DELETECONFIG" Value="0" Secure="yes" />

    <!-- Optional shortcuts (#183): the BA passes DESKTOPSHORTCUT / STARTMENUSHORTCUT from the two checkboxes
         (both default 1 = create). Each shortcut's component is gated on its property, so an unticked box lays
         nothing down and a repair/upgrade with it unticked removes the existing one. Secure to survive into the
         elevated execute sequence. -->
    <Property Id="DESKTOPSHORTCUT" Value="1" Secure="yes" />
    <Property Id="STARTMENUSHORTCUT" Value="1" Secure="yes" />

    <!-- ProgramFiles\AmneziaGeo (x64) for the binaries; a Start-menu folder for the shortcut. -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AmneziaGeo" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AgMenuFolder" Name="AmneziaGeo" />
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="Main" Title="AmneziaGeo" Level="1">
      <ComponentGroupRef Id="Payload" />
      <ComponentRef Id="AgentServiceExe" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <!-- App icon (same .ico embedded into Ui.exe) for the shortcuts and the Add/Remove Programs entry.
         Sourced from the UI publish output staged under Assets\ by build-installer.ps1. Omitted entirely
         when the installer config supplies no icon (HasIcon=false). -->
    <?if $(var.HasIcon) = "true" ?>
    <Icon Id="AgIcon.ico" SourceFile="$(var.StageDir)\Assets\AmneziaGeo.ico" />
    <Property Id="ARPPRODUCTICON" Value="AgIcon.ico" />
    <?endif?>

    <!-- On full removal (including the remove phase of a major upgrade) mop up any leftover transient
         per-tunnel services. The active tunnel is already torn down by the AmneziaGeoAgent service's
         own graceful stop (ServiceControl below), which reverts its routes / DNS / firewall; this only
         catches a per-tunnel service orphaned by an agent crash. Runs the installed agent exe with the
         uninstall-cleanup verb, which enumerates and deletes the "AmneziaGeo$*" services in-process via the
         Service Control Manager API (no powershell/sc.exe child, keeping the AV footprint low - #167).
         Sequenced Before RemoveFiles so the exe is still on disk. Fixed verb (no installer properties), so
         the action needs no deferred CustomActionData. DEFERRED + Impersonate="no" runs it as SYSTEM on
         session 0. Best-effort: Return="ignore" so a hiccup never blocks uninstall. -->
    <CustomAction Id="AgCleanup"
                  FileRef="AppExe"
                  ExeCommand="--uninstall-cleanup"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- #105/#114: optionally wipe the runtime data tree (ProgramData\AmneziaGeo: state.db, Configurations\,
         geo\, logs\) when the user ticked the wipe toggle in the BA (DELETECONFIG=1, passed by the bundle):
         «Удалить конфигурацию и кэш» on removal, or «Сбросить настройки» on install/update/repair (start the
         app from a clean config). Off by default, so a plain (un)install keeps profiles/settings. The WHOLE
         tree is removed, not just state.db: leaving legacy Configurations\*.conf behind would let them migrate
         back into a fresh DB. Runs the installed agent exe with the wipe-config verb, which removes the tree
         in-process via the file API with a short retry (no powershell child - #167). Deferred + Impersonate="no"
         runs it as SYSTEM (the data is owned by the service account); sequenced Before RemoveFiles so the exe is
         still on disk, yet AFTER StopServices has stopped the agent (its process exit unlocks state.db) and
         before the service is (re)started. On a fresh install / a
         machine with no config the tree is absent (and the exe not yet laid), so the action is a Return="ignore"
         no-op. The exe's retry loop (~3s) rides out the narrow window where the service is SCM-stopped but its
         process has not yet released state.db / the current log file. -->
    <CustomAction Id="AgWipeConfig"
                  FileRef="AppExe"
                  ExeCommand="--wipe-config"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />
    <InstallExecuteSequence>
      <Custom Action="AgCleanup" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="AgWipeConfig" Before="RemoveFiles" Condition="DELETECONFIG=&quot;1&quot;" />
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <!-- Bundled payload: the whole staged publish EXCEPT App.exe (handled explicitly below as the
         service) and pdbs (the runtime does not need them). Subfolders (Avalonia natives, etc.)
         preserved. Ui.exe stays in the payload and is targeted by the shortcuts. -->
    <ComponentGroup Id="Payload" Directory="INSTALLFOLDER">
      <Files Include="$(var.StageDir)\**">
        <Exclude Files="$(var.StageDir)\AmneziaGeo.Windows.App.exe" />
        <Exclude Files="$(var.StageDir)\**\*.pdb" />
      </Files>
    </ComponentGroup>

    <!-- The backend agent, registered as the LocalSystem auto-start service the GUI talks to.
         Service name MUST match TunnelPaths.AgentServiceName() ("AmneziaGeoAgent") so the in-app
         service controls line up. The agent flag with no launch target (see Arguments below) ships a
         clean install with NO phantom binding: the agent idles (serves the pipe) and picks up the
         user's persisted profile selection once one is created and selected. -->
    <Component Id="AgentServiceExe" Directory="INSTALLFOLDER">
      <File Id="AppExe" Source="$(var.StageDir)\AmneziaGeo.Windows.App.exe" KeyPath="yes" />
      <ServiceInstall Id="AgentSvcInstall"
                      Name="AmneziaGeoAgent"
                      DisplayName="AmneziaGeo Agent"
                      Description="Бэкенд AmneziaGeo VPN (туннель AmneziaWG, маршрутизация, kill-switch, DNS)."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem"
                      Arguments="--agent"
                      Vital="yes" />
      <ServiceControl Id="AgentSvcControl"
                      Name="AmneziaGeoAgent"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <!-- Shortcuts to the unprivileged GUI (Ui.exe itself is harvested with the payload). Split into two
         optional components (#183): one in the Start menu, one on the (all-users) Desktop, each gated on its
         BA property and each with its own HKCU keypath (the per-user shortcut data) so the non-advertised
         shortcut passes ICE43/ICE57; both target the exe by path. System.AppUserModel.ID matches the ID the
         Ui process sets at startup, so a taskbar pin keeps grouping with the running window across a
         major-upgrade file swap. -->
    <Component Id="StartMenuShortcut" Directory="AgMenuFolder" Condition="Installed OR STARTMENUSHORTCUT = 1">
<?if $(var.HasIcon) = "true" ?>
      <Shortcut Id="UiStartMenuShortcut"
                Name="AmneziaGeo"
                Description="AmneziaGeo VPN"
                Target="[INSTALLFOLDER]AmneziaGeo.Windows.Ui.exe"
                Icon="AgIcon.ico" IconIndex="0"
                WorkingDirectory="INSTALLFOLDER">
        <ShortcutProperty Key="System.AppUserModel.ID" Value="AmneziaGeo.AmneziaGeo" />
      </Shortcut>
<?else?>
      <Shortcut Id="UiStartMenuShortcut"
                Name="AmneziaGeo"
                Description="AmneziaGeo VPN"
                Target="[INSTALLFOLDER]AmneziaGeo.Windows.Ui.exe"
                WorkingDirectory="INSTALLFOLDER">
        <ShortcutProperty Key="System.AppUserModel.ID" Value="AmneziaGeo.AmneziaGeo" />
      </Shortcut>
<?endif?>
      <RemoveFolder Id="RemoveAgMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\AmneziaGeo" Name="installed"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcut" Directory="DesktopFolder" Condition="Installed OR DESKTOPSHORTCUT = 1">
<?if $(var.HasIcon) = "true" ?>
      <Shortcut Id="UiDesktopShortcut"
                Name="AmneziaGeo"
                Description="AmneziaGeo VPN"
                Target="[INSTALLFOLDER]AmneziaGeo.Windows.Ui.exe"
                Icon="AgIcon.ico" IconIndex="0"
                WorkingDirectory="INSTALLFOLDER">
        <ShortcutProperty Key="System.AppUserModel.ID" Value="AmneziaGeo.AmneziaGeo" />
      </Shortcut>
<?else?>
      <Shortcut Id="UiDesktopShortcut"
                Name="AmneziaGeo"
                Description="AmneziaGeo VPN"
                Target="[INSTALLFOLDER]AmneziaGeo.Windows.Ui.exe"
                WorkingDirectory="INSTALLFOLDER">
        <ShortcutProperty Key="System.AppUserModel.ID" Value="AmneziaGeo.AmneziaGeo" />
      </Shortcut>
<?endif?>
      <RegistryValue Root="HKCU" Key="Software\AmneziaGeo" Name="desktopshortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
