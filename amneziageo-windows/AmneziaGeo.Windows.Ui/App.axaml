<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AmneziaGeo.Windows.Ui.App"
             RequestedThemeVariant="Light">

  <!-- All shared control styles + sizes + interaction behaviour live here, in one place. Interaction
       rule (app-wide): NO hover effect anywhere (no background / border / colour / opacity change on
       pointer-over); the only feedback is a subtle press opacity. Selection uses an .active background.
       Button heights are uniform and compact (vertical padding 4), matching the softbtn. -->
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Border.card">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BoxShadow" Value="0 1 3 0 #14000000" />
    </Style>

    <Style Selector="Border.subcard">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.inset">
      <Setter Property="Background" Value="{DynamicResource AgInsetBrush}" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <Style Selector="TextBlock.section">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="LetterSpacing" Value="0.7" />
    </Style>

    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
    </Style>

    <Style Selector="TextBlock.mono">
      <Setter Property="FontFamily" Value="IBM Plex Mono, Cascadia Mono, Consolas, monospace" />
    </Style>

    <!-- Button.seg : sidebar nav segment — compact, stretches to fill its (equal) column. -->
    <Style Selector="Button.seg">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="4,4" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.seg.active">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.chip">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Button.chip.active">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.softbtn">
      <Setter Property="Background" Value="{DynamicResource AgInsetBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="10,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style Selector="Button.accent">
      <Setter Property="Background" Value="{DynamicResource AgAccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="14,4" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>

    <!-- danger : a destructive action (delete profile). Outlined red — literal colours so it reads on
         both themes without depending on a theme brush. -->
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="#E0A0A0" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#D64545" />
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="12,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <Style Selector="Button.icon">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- powerctl : the round on/off connection control. Static control chrome (like every other control);
         only the round circle reflects connection state, not the whole plaque. -->
    <Style Selector="Button.powerctl">
      <Setter Property="Background" Value="{DynamicResource AgInsetBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="5,3,11,3" />
    </Style>

    <!-- powerbig : the large round connection control shown in the right pane on the profiles list.
         Chrome-less (only the drawn rings + circle show); the round circle reflects connection state. -->
    <Style Selector="Button.powerbig">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="120" />
    </Style>

    <!-- backbtn : header "back to the previous menu" control. Chrome-less and subtle, like the rest;
         the only feedback is the shared press opacity. -->
    <Style Selector="Button.backbtn">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- connectpill : the connect / stop button (compact, white text on a bound status-coloured fill) -->
    <Style Selector="Button.connectpill">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="14,4" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinWidth" Value="104" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <!-- radiopick : the active-profile radio (chrome-less) -->
    <Style Selector="Button.radiopick">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="2" />
      <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- rowselect : a flat, borderless, full-width selectable list row with a radio -->
    <Style Selector="Button.rowselect">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.rowselect.active">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
    </Style>

    <Style Selector="Button.sourcerow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ============================================================================================
         ONE place that governs ALL button interaction (classed buttons here AND plain buttons in the
         dialogs). The rule: a button never recolours on pointer-over / press / disabled — the
         content-presenter is pinned to the control's OWN Background / Foreground / BorderBrush in
         every state, so whatever a class sets (or .active sets) is exactly what shows, hovered or not.
         The ONLY feedback is a subtle press opacity; disabled is dimmed. No per-class hover styles
         exist, so there is nothing to forget when a new button class is added.
         ============================================================================================ -->
    <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}" />
      <Setter Property="BorderBrush" Value="{Binding $parent[Button].BorderBrush}" />
      <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>
    <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}" />
      <Setter Property="BorderBrush" Value="{Binding $parent[Button].BorderBrush}" />
      <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>
    <Style Selector="Button:disabled /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{Binding $parent[Button].Background}" />
      <Setter Property="BorderBrush" Value="{Binding $parent[Button].BorderBrush}" />
      <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="Button:pressed">
      <Setter Property="RenderTransform" Value="none" />
      <Setter Property="Opacity" Value="0.85" />
    </Style>
    <Style Selector="Button:disabled">
      <Setter Property="Opacity" Value="0.5" />
    </Style>

    <Style Selector="TextBox.field">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- ONE place for text-input borders (classed .field AND plain dialog text boxes / the
         AutoCompleteBox's inner text box). FluentTheme paints the hover/focus border on the template
         PART (Border#PART_BorderElement), so it MUST be pinned there — a control-level setter never
         reaches it. Same neutral secondary border in every state: no pointer-over / focus recolour,
         no accent focus underline, no transition fade. -->
    <Style Selector="TextBox /template/ Border#PART_BorderElement">
      <Setter Property="Transitions" Value="{x:Null}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
    </Style>
    <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
    </Style>

    <Style Selector="ComboBox.field">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>

    <!-- Strict, flicker-free ComboBox.field (closed box): null the part transition and hold resting
         colours in every state; feedback is the subtle press opacity below. -->
    <Style Selector="ComboBox.field /template/ Border#Background">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="ComboBox.field:pointerover /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:pressed /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:pressed">
      <Setter Property="Opacity" Value="0.85" />
    </Style>
    <Style Selector="ComboBox.field:focus-visible /template/ Border#HighlightBackground">
      <Setter Property="IsVisible" Value="True" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="ComboBox.field /template/ ContentControl#ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBox.field /template/ PathIcon#DropDownGlyph">
      <Setter Property="Foreground" Value="{DynamicResource AgMutedBrush}" />
    </Style>
    <Style Selector="ComboBox.field:disabled /template/ Border#Background">
      <Setter Property="Background" Value="{DynamicResource AgPanel2Brush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AgBorder2Brush}" />
    </Style>
    <Style Selector="ComboBox.field:disabled /template/ ContentControl#ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource AgMuted2Brush}" />
    </Style>

    <!-- Control.spin : continuous rotation (source refresh icon, connect-control spinner ring, ...) -->
    <Style Selector="Control.spin">
      <Setter Property="RenderTransformOrigin" Value="50%,50%" />
      <Setter Property="RenderTransform" Value="rotate(0)" />
    </Style>
    <Style Selector="Control.spin">
      <Style.Animations>
        <Animation Duration="0:0:0.9" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="RotateTransform.Angle" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="RotateTransform.Angle" Value="360" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Control.pulse : opacity breathing — a robust "busy" indicator (pure opacity, no transform so it
         cannot silently fail on a transform-origin/RenderTransform quirk the way a rotation can). -->
    <Style Selector="Control.pulse">
      <Style.Animations>
        <Animation Duration="0:0:1" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="0.25" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Power-button ring wave: three accent rings (r1 inner → r3 outer) light up in sequence during a
         transient connect (waveout: r1→r2→r3, outward) or disconnect (wavein: r3→r2→r1, inward). Each ring
         runs the same opacity pulse; only the start delay differs, producing the travelling wave. Idle
         opacity is 0 (invisible). -->
    <Style Selector="Ellipse.ring">
      <Setter Property="Opacity" Value="0" />
    </Style>
    <Style Selector="Ellipse.r1.waveout">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Ellipse.r2.waveout">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0.45" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Ellipse.r3.waveout">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0.9" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Ellipse.r1.wavein">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0.9" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Ellipse.r2.wavein">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0.45" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Ellipse.r3.wavein">
      <Style.Animations>
        <Animation Duration="0:0:1.35" Delay="0:0:0" IterationCount="INFINITE">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0" /></KeyFrame>
          <KeyFrame Cue="30%"><Setter Property="Opacity" Value="0.85" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Strict, flicker-free ComboBox dropdown rows. The popup lives outside any window's template
         scope, so these must be app-level. -->
    <Style Selector="ComboBoxItem /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Transitions" Value="{x:Null}" />
    </Style>
    <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgHoverBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgHoverBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
    <Style Selector="ComboBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource AgAccentSoftBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource AgFgBrush}" />
    </Style>
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <Color x:Key="AgBg">#eceef1</Color>
          <Color x:Key="AgPanel">#ffffff</Color>
          <Color x:Key="AgPanel2">#f7f8fa</Color>
          <Color x:Key="AgSidebar">#e7e9ec</Color>
          <Color x:Key="AgBorder">#e4e6ea</Color>
          <Color x:Key="AgBorder2">#d2d6dd</Color>
          <Color x:Key="AgFg">#181b20</Color>
          <Color x:Key="AgMuted">#646c78</Color>
          <Color x:Key="AgMuted2">#9aa1ab</Color>
          <Color x:Key="AgAccent">#2a6fdb</Color>
          <Color x:Key="AgAccentSoft">#1A2a6fdb</Color>
          <Color x:Key="AgInset">#f0f2f5</Color>
          <Color x:Key="AgHover">#eef0f3</Color>
          <Color x:Key="AgUp">#1f9d57</Color>
          <Color x:Key="AgDown">#e0533d</Color>
          <Color x:Key="AgWarn">#cf9a17</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <Color x:Key="AgBg">#0d1014</Color>
          <Color x:Key="AgPanel">#171a1f</Color>
          <Color x:Key="AgPanel2">#1d212a</Color>
          <Color x:Key="AgSidebar">#101317</Color>
          <Color x:Key="AgBorder">#262b33</Color>
          <Color x:Key="AgBorder2">#343a45</Color>
          <Color x:Key="AgFg">#e8ebf0</Color>
          <Color x:Key="AgMuted">#98a0ac</Color>
          <Color x:Key="AgMuted2">#5f6772</Color>
          <Color x:Key="AgAccent">#4d8df0</Color>
          <Color x:Key="AgAccentSoft">#294d8df0</Color>
          <Color x:Key="AgInset">#22272f</Color>
          <Color x:Key="AgHover">#1e232b</Color>
          <Color x:Key="AgUp">#34c77b</Color>
          <Color x:Key="AgDown">#f1664c</Color>
          <Color x:Key="AgWarn">#e6b23a</Color>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

      <SolidColorBrush x:Key="AgBgBrush" Color="{DynamicResource AgBg}" />
      <SolidColorBrush x:Key="AgPanelBrush" Color="{DynamicResource AgPanel}" />
      <SolidColorBrush x:Key="AgPanel2Brush" Color="{DynamicResource AgPanel2}" />
      <SolidColorBrush x:Key="AgSidebarBrush" Color="{DynamicResource AgSidebar}" />
      <SolidColorBrush x:Key="AgBorderBrush" Color="{DynamicResource AgBorder}" />
      <SolidColorBrush x:Key="AgBorder2Brush" Color="{DynamicResource AgBorder2}" />
      <SolidColorBrush x:Key="AgFgBrush" Color="{DynamicResource AgFg}" />
      <SolidColorBrush x:Key="AgMutedBrush" Color="{DynamicResource AgMuted}" />
      <SolidColorBrush x:Key="AgMuted2Brush" Color="{DynamicResource AgMuted2}" />
      <SolidColorBrush x:Key="AgAccentBrush" Color="{DynamicResource AgAccent}" />
      <SolidColorBrush x:Key="AgAccentSoftBrush" Color="{DynamicResource AgAccentSoft}" />
      <SolidColorBrush x:Key="AgInsetBrush" Color="{DynamicResource AgInset}" />
      <SolidColorBrush x:Key="AgHoverBrush" Color="{DynamicResource AgHover}" />
      <SolidColorBrush x:Key="AgUpBrush" Color="{DynamicResource AgUp}" />
      <SolidColorBrush x:Key="AgDownBrush" Color="{DynamicResource AgDown}" />
      <SolidColorBrush x:Key="AgWarnBrush" Color="{DynamicResource AgWarn}" />
    </ResourceDictionary>
  </Application.Resources>

</Application>
